model XX_cos_recast()

  // Recasting of: dX/dt = X*cos(t),  X(0) = 1
  // Lifted 3D autonomous system:
  //   X_1 = X
  //   X_2 = cos(t) + 2
  //   X_3 = sin(t) + 2
  //
  // ODEs:
  //   dX_1/dt = X_1*X_2 - 2*X_1
  //   dX_2/dt = 2 - X_3
  //   dX_3/dt = X_2 - 2
  //
  // ICs:
  //   X_1(0) = 1
  //   X_2(0) = 3
  //   X_3(0) = 2

  species X_1, X_2, X_3;

  // Initial conditions
  X_1 = 1;
  X_2 = 3;
  X_3 = 2;

  // Dynamics
  X_1' = X_1*X_2 - 2*X_1;
  X_2' = 2 - X_3;
  X_3' = X_2 - 2;

end