////////////////////////////////////////////////////////////////////////////////
// 24_scalarExpLog_scaled_truth.ant
//
// Exact S-system recast of dZ/dt = k * exp[(ln Z)^2] via two lifting steps.
// Variables:
//   X1 = Z
//   X2 = exp[(ln Z)^2]
//   X3 = ln Z
//
// Scaled S-system:
//   X1' = k * X2
//   X2' = 2*k * X1^-1 * X2^2 * X3
//   X3' = k * X1^-1 * X2
////////////////////////////////////////////////////////////////////////////////

model scalarExpLog_scaled_truth_24()

  species X1, X2, X3;

  // Time-scale parameter, consistent with original model
  k = 0.04;

  // S-system dynamics for the scaled model
  X1' = k*X2;
  X2' = 2*k*X1^-1*X2^2*X3;
  X3' = k*X1^-1*X2;

  // Initial conditions corresponding to Z(0) = 2
  // X1(0) = Z(0)
  // X3(0) = log Z(0)
  // X2(0) = exp[(log Z(0))^2]
  X1 = 2;
  X3 = log(2);
  X2 = exp((log(2))^2);

end// @SIM T_START=0 T_END=20 N_STEPS=400
