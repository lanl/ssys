model exp_decay_SSystem_exact()

  species S;
  k = 0.3

  // Positive slack keeps both coefficients > 0; dynamics are unchanged.
  eps = 1.0

  // Canonical S-system: two single monomials
  S' =  eps * (S^1)  -  (eps + k) * (S^1)

  // Initial condition
  S = 10
end// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
