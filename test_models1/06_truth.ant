// Exact S-system recast of model `feedback`
//
// Original ODEs:
//   dX1/dt = a - c*X2 - b*X1
//   dX2/dt = b*X1 - b*X2
//
// Change of variables (on the same state space):
//   X  := X1 + X2
//   Y  := X2
//
// Then:
//   X1 = X - Y
//   X2 = Y
//
// In terms of (X, Y), the dynamics become:
//
//   X' = X1' + X2'
//      = (a - c*X2 - b*X1) + (b*X1 - b*X2)
//      = a - (b + c)*X2
//      = a - (b + c)*Y
//
//   Y' = X2' = b*X1 - b*X2
//      = b*(X - Y) - b*Y
//      = b*X - 2*b*Y
//
// Both right-hand sides are now in canonical S-system form:
//   X' = a * X^0*Y^0 - (b + c)*X^0*Y^1
//   Y' = b * X^1*Y^0 - (2*b)*X^0*Y^1
//
// Mapping back via observables reproduces the original system exactly.

model feedback_SSystem_exact()

  // S-system state variables
  species X, Y;

  // Parameters (same as original)
  a = 5;
  b = 1;
  c = 4;

  // Canonical S-system dynamics
  X' = a - (b + c)*Y;
  Y' = b*X - 2*b*Y;

  // Observables: original variables reconstructed from S-system variables
  var X1_obs, X2_obs;
  X1_obs := X - Y;   // corresponds to original X_1
  X2_obs := Y;       // corresponds to original X_2

  // Initial conditions
  // Original had X_1(0) = 0, X_2(0) = 0
  // ⇒ X(0) = X_1(0) + X_2(0) = 0,  Y(0) = X_2(0) = 0
  X = 0;
  Y = 0;

end