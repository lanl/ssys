model m_27_spiral()

  // Scalar ODE:
  //   dZ/dt = (Z - t)/(Z + t)
  //   Z(0) = 4
  //
  // Implemented by treating t as an explicit time state with t' = 1.

  species t, Z;

  // Initial conditions
  t = 0;
  Z = 4;

  // Dynamics
  t' = 1;
  Z' = (Z - t)/(Z + t);

end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
