model Lotka_Volterra_SSystem_exact()

   // The original model is already in canonical S-system form. Recasting should not change anything substantive. 

  species X, Y;

  // Parameters (positive)
  a = 1.1;  // prey growth
  b = 0.4;  // predation
  c = 0.1;  // predator growth per prey
  d = 0.4;  // predator death

  // Canonical S-system dynamics (exact)
  X' =  a * (X^1)            -  b * (X^1) * (Y^1);
  Y' =  c * (X^1) * (Y^1)    -  d * (Y^1);

  // Initial conditions
  X = 1;
  Y = 1;
end// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
