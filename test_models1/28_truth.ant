model 28_torus_SSystem_exact()

  // Mapping:
  //   X1 = Z_1
  //   X2 = Z_2
  //   X3 = Z_3
  //   X4 = sqrt(Z_1^2 + Z_2^2)

  species X1, X2, X3, X4;

  // Dynamics (all RHSs are sums of power-law monomials):
  // X1' = -X2 - X1*X3/X4
  X1' = - X2 - X1*X3*X4^(-1);

  // X2' =  X1 - X2*X3/X4
  X2' =   X1 - X2*X3*X4^(-1);

  // X3' =  X1/X4
  X3' =   X1*X4^(-1);

  // X4' = -X3
  X4' = - X3;

  // Initial conditions corresponding to:
  //   Z_1(0)=3, Z_2(0)=0, Z_3(0)=0
  //   X4(0) = sqrt(3^2+0^2) = 3
  X1 = 3;
  X2 = 0;
  X3 = 0;
  X4 = 3;

  // Optional observables for the original variables
  var Z_1_obs, Z_2_obs, Z_3_obs, r_obs;
  Z_1_obs := X1;
  Z_2_obs := X2;
  Z_3_obs := X3;
  r_obs   := X4;

end