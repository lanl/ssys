model 25_CSTR_SSystem_exact()

  // Parameters (same symbols as original)
  A   = 1;
  B   = 1;
  a   = 0.5;
  b   = 1;
  c   = 1;
  Z10 = 0.2;
  Z20 = 0.2;

  // Derived constant needed for exact matching:
  // C = a*b + 2*(1 + b)
  C := a*b + 2*(1 + b);

  // States
  species X1, X2, X3, X4, X5, X6, X7, X8;

  // S-system ODEs (each RHS is a difference of power-law monomials)

  // dX1/dt = 1/X2 - X1
  X1' = X2^(-1) - X1;

  // dX2/dt = 2 A X5 X6 / X1 - A X2 X5 X6
  X2' = 2*A*X5*X6*X1^(-1) - A*X2*X5*X6;

  // dX3/dt = C/X4 - (1 + b) X3
  X3' = C*X4^(-1) - (1 + b)*X3;

  // dX4/dt = 2 B X5 X6 / X3 - B X1 X2 X5 X6 / X3
  X4' = 2*B*X5*X6*X3^(-1) - B*X1*X2*X5*X6*X3^(-1);

  // dX5/dt = C X5 / (X7^2 X8^2) - (1 + b) X3 X4 X5 /(X7^2 X8^2)
  X5' = C*X5*X7^(-2)*X8^(-2)
      - (1 + b)*X3*X4*X5*X7^(-2)*X8^(-2);

  // dX6/dt = 2 B X5 X6^2 / (X7^2 X8^2) - B X1 X2 X5 X6^2 / (X7^2 X8^2)
  X6' = 2*B*X5*X6^2*X7^(-2)*X8^(-2)
      - B*X1*X2*X5*X6^2*X7^(-2)*X8^(-2);

  // dX7/dt = (C / c)/X8 - [(1 + b) / c] X3 X4 / X8
  X7' = (C/c)*X8^(-1)
      - ((1 + b)/c)*X3*X4*X8^(-1);

  // dX8/dt = (2 B / c) X5 X6 / X7 - (B / c) X1 X2 X5 X6 / X7
  X8' = (2*B/c)*X5*X6*X7^(-1)
      - (B/c)*X1*X2*X5*X6*X7^(-1);

  // Initial conditions (as given)
  X1 = 1;
  X2 = Z10 + 1;
  X3 = 1;
  X4 = Z20 + 2;
  X5 = 1;
  X6 = exp(c*Z20/(c + Z20));
  X7 = 1;
  X8 = (c + Z20)/c;

  // Observables: original variables
  var Z1_obs, Z2_obs;
  Z1_obs := X1*X2 - 1;
  Z2_obs := X3*X4 - 2;

end// @SIM T_START=0 T_END=20 N_STEPS=400
