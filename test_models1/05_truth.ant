// Exact S-system recast of model m5:
//
// Original scalar ODE:
//   Z' = a_1*Z^(2/3) - a_2*Z^2 - a_3*Z^(1/2),   Z(0) = 2
//
// Change of variables (on the positive orthant):
//   Z = X*Y
//
// Then Z' = X'*Y + X*Y' can be made to match the RHS exactly with
// two-monomial (canonical) S-system equations for X and Y.

model m5_SSystem_exact()

  // Parameters (same numerical values as original)
  a_1 = 0.2;
  a_2 = 0.1;
  a_3 = 0.05;

  // Slack for canonical two-term S-system form (ε > 0 arbitrary).
  // It keeps both monomials present in Y' without changing net dynamics.
  eps = 1.0;

  // S-system state variables (positive)
  species X, Y;

  // ------------------------------------------------------------------
  // Dynamics
  //
  // Choose:
  //   X' =  a_1*X^(2/3)*Y^(-1/3)  −  a_2*X^2*Y
  //   Y' =  eps*X^(-1/2)*Y^(-1/2) − (eps + a_3)*X^(-1/2)*Y^(-1/2)
  //
  // Then Z = X*Y satisfies:
  //   Z' = X'*Y + X*Y'
  //      = a_1*X^(2/3)*Y^(2/3) − a_2*X^2*Y^2 − a_3*X^(1/2)*Y^(1/2)
  //      = a_1*Z^(2/3) − a_2*Z^2 − a_3*Z^(1/2)
  // exactly.
  // ------------------------------------------------------------------

  X' =  a_1*X^(2/3)*Y^(-1/3)  -  a_2*X^2*Y;
  Y' =  eps*X^(-1/2)*Y^(-1/2) - (eps + a_3)*X^(-1/2)*Y^(-1/2);

  // Observable to reconstruct the original variable
  var Z_obs;
  Z_obs := X*Y;

  // ------------------------------------------------------------------
  // Initial conditions
  //
  // Original: Z(0) = 2. Choose any X(0),Y(0) > 0 with X(0)*Y(0) = 2.
  // For example:
  //   X(0) = 2, Y(0) = 1  ⇒ Z_obs(0) = 2.
  // ------------------------------------------------------------------

  X = 2;
  Y = 1;

end// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
