model A_plus_B_to_C_SSystem_exact()

  // Exact canonical S-system for: A'=-kf*A*B, B'=-kf*A*B, C'=kf*A*B

  // States
  species A, B, C;

  // Parameters
  kf = 0.01;   // given
  eps = 1.0;   // arbitrary slack > 0 (can be any positive value)

  // Canonical S-system dynamics (two single monomials per ODE)
  A' =  eps * A * B  -  (eps + kf) * A * B;
  B' =  eps * A * B  -  (eps + kf) * A * B;
  C' =  (eps + kf) * A * B  -  eps * A * B;

  // Initial conditions (from the original problem)
  A = 10;
  B = 8;
  C = 0;

end// @SIM T_START=0 T_END=20 N_STEPS=400
