model Bertalanffy_SSystem_exact()

   // The original model is already in canonical S-system form. Recasting should not change anything substantive. 

  // Canonical S-system for: x' = p*x^a - q*x
  species x;

  // Parameters (positive)
  p = 7;
  a = 2/3;   // 0 < a < 1
  q = 2;

  // Dynamics: two monomials (production − degradation)
  x' = p * (x^a) - q * (x^1);

  // Initial condition
  x = 10;

  // (Optional) observable: carrying capacity / asymptote (not used by dynamics)
  var mmax;
  mmax := (p/q)^(1/(1 - a));   // = 42.875 with numbers above

end// @SIM T_START=0 T_END=20 N_STEPS=400
