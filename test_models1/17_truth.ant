model central_t_S_system()
  // X1 = t + c, X2 = nu + t^2, X3 = f(t)
  species X1, X2, X3
  nu = 8
  c  = 1.0                 // shift > 0

  // Canonical S-system
  X1' = 1                                  // = 1 - 0
  X2' = 2*X1 - 2*c                         // = (2)*X1^1 - (2*c)*X1^0
  X3' = (nu+1)*c * X2^(-1) * X3            // production
       - (nu+1)   * X1 * X2^(-1) * X3      // loss

  // ICs matching t=0
  X1 = c
  X2 = nu
  X3 = gamma((nu+1)/2) / (sqrt(nu*pi) * gamma(nu/2))
end// @SIM T_START=0 T_END=20 N_STEPS=400
