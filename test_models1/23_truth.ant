model MWC_GMA_recast()

  // ------------------------------------------------------------
  // Monod-Wyman-Changeux (MWC) model — exact GMA (BST) recast
  // Each ODE is a sum/difference of monomials (mass-action terms).
  // ------------------------------------------------------------

  compartment cell = 1;

  // ===== Parameters (copied/kept) =====

  const N_A   = 6.02214076e23;   // molecules per mole
  const V_cyt = 1e-12;           // L per cell

  const K_T = 1e6/(N_A*V_cyt);
  const K_R = 5e6/(N_A*V_cyt);

  const c = K_T/K_R;
  const n = 4;

  const L_0 = 0.1;
  const L   = 1/L_0;

  const L_1 = L_0*(K_R/K_T)^1;
  const L_2 = L_0*(K_R/K_T)^2;
  const L_3 = L_0*(K_R/K_T)^3;
  const L_4 = L_0*(K_R/K_T)^4;

  const k_off = 0.1;

  const k_mT = k_off;
  const k_pT = k_mT*K_T;

  const k_mR = k_off;
  const k_pR = k_mR*K_R;

  const k_mL_0 = k_off;
  const k_pL_0 = k_mL_0*L_0;

  const k_mL_1 = k_off;
  const k_pL_1 = k_mL_1*L_1;

  const k_mL_2 = k_off;
  const k_pL_2 = k_mL_2*L_2;

  const k_mL_3 = k_off;
  const k_pL_3 = k_mL_3*L_3;

  const k_mL_4 = k_off;
  const k_pL_4 = k_mL_4*L_4;

  const P_0 = 1e5;
  const S_0 = 1e5;

  // ===== State variables (species) =====
  species S in cell;
  species P_T0 in cell, P_T1 in cell, P_T2 in cell, P_T3 in cell, P_T4 in cell;
  species P_R0 in cell, P_R1 in cell, P_R2 in cell, P_R3 in cell, P_R4 in cell;

  // ===== Flux definitions (all monomials) =====

  // T binding/unbinding
  v_T0 := (k_pT*4)*P_T0*S;
  u_T1 := (k_mT*1)*P_T1;

  v_T1 := (k_pT*3)*P_T1*S;
  u_T2 := (k_mT*2)*P_T2;

  v_T2 := (k_pT*2)*P_T2*S;
  u_T3 := (k_mT*3)*P_T3;

  v_T3 := (k_pT*1)*P_T3*S;
  u_T4 := (k_mT*4)*P_T4;

  // R binding/unbinding
  v_R0 := (k_pR*4)*P_R0*S;
  u_R1 := (k_mR*1)*P_R1;

  v_R1 := (k_pR*3)*P_R1*S;
  u_R2 := (k_mR*2)*P_R2;

  v_R2 := (k_pR*2)*P_R2*S;
  u_R3 := (k_mR*3)*P_R3;

  v_R3 := (k_pR*1)*P_R3*S;
  u_R4 := (k_mR*4)*P_R4;

  // T <-> R isomerization
  iso0_f := k_pL_0*P_T0;  iso0_b := k_mL_0*P_R0;
  iso1_f := k_pL_1*P_T1;  iso1_b := k_mL_1*P_R1;
  iso2_f := k_pL_2*P_T2;  iso2_b := k_mL_2*P_R2;
  iso3_f := k_pL_3*P_T3;  iso3_b := k_mL_3*P_R3;
  iso4_f := k_pL_4*P_T4;  iso4_b := k_mL_4*P_R4;

  // ===== ODEs (exact mass-action balances; GMA form) =====

  // Ligand S: consumed by binding, produced by unbinding (no isomerization effect)
  S' = -(v_T0 + v_T1 + v_T2 + v_T3 + v_R0 + v_R1 + v_R2 + v_R3) + (u_T1 + u_T2 + u_T3 + u_T4 + u_R1 + u_R2 + u_R3 + u_R4);

  // T ladder with isomerization
  P_T0' = -v_T0 + u_T1 - iso0_f + iso0_b;
  P_T1' = +v_T0 - u_T1 - v_T1 + u_T2 - iso1_f + iso1_b;
  P_T2' = +v_T1 - u_T2 - v_T2 + u_T3 - iso2_f + iso2_b;
  P_T3' = +v_T2 - u_T3 - v_T3 + u_T4 - iso3_f + iso3_b;
  P_T4' = +v_T3 - u_T4          - iso4_f + iso4_b;

  // R ladder with isomerization
  P_R0' = -v_R0 + u_R1 + iso0_f - iso0_b;
  P_R1' = +v_R0 - u_R1 - v_R1 + u_R2 + iso1_f - iso1_b;
  P_R2' = +v_R1 - u_R2 - v_R2 + u_R3 + iso2_f - iso2_b;
  P_R3' = +v_R2 - u_R3 - v_R3 + u_R4 + iso3_f - iso3_b;
  P_R4' = +v_R3 - u_R4          + iso4_f - iso4_b;

  // ===== Initial conditions (same as original) =====
  P_T0 = P_0*(1/(1 + L_0));
  P_R0 = P_0*(L_0/(1 + L_0));

  P_T1 = 0.001;
  P_T2 = 0.001;
  P_T3 = 0.001;
  P_T4 = 0.001;

  P_R1 = 0.001;
  P_R2 = 0.001;
  P_R3 = 0.001;
  P_R4 = 0.001;

  S    = S_0;

end
// @SIM T_START=0 T_END=20 N_STEPS=400
