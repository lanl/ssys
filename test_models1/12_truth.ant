model toy_mass_action_SSystem_exact()

  // Exact recast of:
  //   X1' = a*X1*X2 - b*X1^2*X2 - c*X1^2
  //   X2' = X1 - X2
  // via change of variables X1 = X3*X4.
  // Dynamic states: X2, X3, X4  (X1 is observed as X3*X4).

  // Parameters
  a = 1.2;   // >0
  b = 0.3;   // >0
  c = 0.1;   // >0

  // Choose positive S-system rate constants with (alpha4 - beta4) = -c
  alpha4 = 1.0;          // arbitrary >0
  beta4  = 1.0 + c;      // ensures alpha4 - beta4 = -c

  // States
  species X2, X3, X4;

  // Canonical S-system dynamics (two monomials per ODE)
  // X3' =  a * X3 * X2        −  b * X3^2 * X4 * X2
  X3' =  a * X3 * X2 - b * (X3^2) * X4 * X2;

  // X4' = (alpha4) * X3 * X4^2 − (beta4) * X3 * X4^2  ⇒ net = (alpha4 - beta4) * X3 * X4^2 = -c * X3 * X4^2
  X4' =  alpha4 * X3 * (X4^2) - beta4 * X3 * (X4^2);

  // X2' =  1 * X3 * X4        −  1 * X2
  X2' =  X3 * X4 - X2;

  // (Optional) observable for the original variable
  var X1_obs;
  X1_obs := X3 * X4;

  // Initial conditions (consistent with original X1(0)=0.5, X2(0)=0.4)
  X3 = 0.5;   // pick any positive pair with X3*X4 = 0.5
  X4 = 1.0;
  X2 = 0.4;

end