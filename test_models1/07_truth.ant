model SIR_SSystem_exact()

  // States
  species S, I, R;

  // Parameters (from original)
  S0 = 20000000
  beta_rate = 5e-8
  gamma_rate = 1/7

  // Canonical S-system requires two monomials per ODE with positive coefficients.
  // Use arbitrary positive "slack" epsilons; dynamics are unchanged.
  epsS = 1.0   // for S'
  epsR = 1.0   // for R'

  // Dynamics (each: production monomial − degradation monomial)
  S' =  epsS * S * I        -  (epsS + beta_rate) * S * I;   // net = -beta_rate*S*I
  I' =  beta_rate * S * I        -  gamma_rate * I;               // already two monomials
  R' =  (gamma_rate + epsR) * I  -  epsR * I;                // net =  gamma_rate*I

  // Initial conditions (NYC-scale)
  S = 19999999
  I = 1
  R = 0
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
