// Model for first-order decay: S' = -k*S
// This model is essentially the same as S1987_A1_exponential.
// Recast into canonical S-system form: 
// eps = 1.0 // slack
// S' =  eps * (S^1)  -  (eps + k) * (S^1)

model exp_decay()
// Initial condition
S = 10
// Parameter
k = 0.3
// Equation
S' = -k*S
end
// @SIM T_START=0 T_END=20 N_STEPS=400// Model for logistic growth: X' = r*X*(1 - X/K)
// This model is essentially the same as S1987_A4_logistic.
// Canonical S-system: X' = r * (X^1) - (r/K) * (X^2)

model logistic()
X = 1
r = 0.5
K = 5
X' = r*X*(1 - X/K)
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Predator-prey classic Lotka-Volterra model
// Volterra V (1928) Variations and fluctuations of the
//   number of individuals in animals species living together.
//   Journal du Conseil 3: 3-51.
// This model is essentially the same as S1987_B1_lotka_volterra.
// The original model is already in canonical S-system form. 
// Recasting should not change anything substantive. 

model Lotka_Volterra()
X = 1; Y = 1
a = 1.1; b = 0.4; c = 0.1; d = 0.4
X' = a*X - b*X*Y
Y' = c*X*Y - d*Y
end
// @SIM T_START=0 T_END=20 N_STEPS=400 // Model for a branched biochemical pathway
//
// Original model:
//   A' = -k_1*A
//   B' =  k_1*A - (k_2 + k_3)*B + k_4*D
//   C' =  k_2*B
//   D' =  k_3*B - k_4*D
//
// Change of variables:
//   A = X1
//   B = X2*X3
//   C = X5
//   D = X4
//
// S-system (with ε-splitting):
//   X1' =  epsA*X1                - (epsA + k1)*X1
//   X2' =  (eps2 + k1)*X1*X3^(-1) - eps2*X1*X3^(-1)
//   X3' =  k4*X4*X2^(-1)          - (k2 + k3)*X3
//   X4' =  k3*X2*X3               - k4*X4
//   X5' =  (epsC + k2)*X2*X3      - epsC*X2*X3
//
// Initial conditions
// S-systems require strictly positive states when negative exponents
// are present. Since X2 and X3 appear with exponent −1, we cannot set
// X2(0)=0 or X3(0)=0. We approximate B(0) by taking X2(0)=δ (small positive), 
// and X3(0)=1, so that B(0)=δ ≈ 0. The value of δ can be set as small as possible.
//   X1 = 5;        // A(0) = 5
//   X2 = 1e-9;     // small positive
//   X3 = 1;        // B(0) = X2(0)*X3(0) ≈ 0
//   X4 = 0;        // D(0) = 0
//   X5 = 0;        // C(0) = 0

model mass_action_branch()
A = 5; B = 0; C = 0; D = 0
k_1 = 0.1; k_2 = 0.2; k_3 = 0.15; k_4 = 0.3
A -> B; k_1*A
B -> C; k_2*B
B -> D; k_3*B
D -> B; k_4*D
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-3
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// A model with a RHS that is a 
//   sum of three terms requiring splitting
// This model is essentially the same as S1987_4D_sum_reduction.
//
// Slack for canonical two-term S-system form (ε > 0 arbitrary).
// It keeps both monomials present in Y' without changing net dynamics.
// eps = 1.0;
//
// S-system state variables (positive)
// species X, Y;
//
// ------------------------------------------------------------------
// Dynamics
//
// Choose:
//   X' =  a_1*X^(2/3)*Y^(-1/3)  −  a_2*X^2*Y
//   Y' =  eps*X^(-1/2)*Y^(-1/2) − (eps + a_3)*X^(-1/2)*Y^(-1/2)
//
// Then Z = X*Y satisfies:
//   Z' = X'*Y + X*Y'
//      = a_1*X^(2/3)*Y^(2/3) − a_2*X^2*Y^2 − a_3*X^(1/2)*Y^(1/2)
//      = a_1*Z^(2/3) − a_2*Z^2 − a_3*Z^(1/2)
// exactly.
// ------------------------------------------------------------------

model three_term_sum()
Z = 2
a_1 = 0.2; a_2 = 0.1; a_3 = 0.05
Z' = a_1*Z^(2/3) - a_2*Z^2 - a_3*Z^(1/2)
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Model for biochemical pathway with negative feedback
// ODEs: 
//   dX1/dt = a - c*X2 - b*X1
//   dX2/dt = b*X1 - b*X2
// ICs: X1(0)=0, X2(0)=0
// Params: a=5 (M/s), b=1 (/s), c=4 (/s)
//
// Change of variables:
//   X  := X1 + X2
//   Y  := X2
//
// Then:
//   X1 = X - Y
//   X2 = Y
//
// In terms of (X, Y), the dynamics become:
//
//   X' = X1' + X2'
//      = (a - c*X2 - b*X1) + (b*X1 - b*X2)
//      = a - (b + c)*X2
//      = a - (b + c)*Y
//
//   Y' = X2' = b*X1 - b*X2
//      = b*(X - Y) - b*Y
//      = b*X - 2*b*Y
//
// Both right-hand sides are in canonical S-system form.
//
model feedback()
  // initial conditions
  X_1 = 0.0 
  X_2 = 0.0 

  // parameters
  a = 1
  b = 0.2
  c = 0.8

  // reactions (mass-action style)
  // 0 -> X_1  with rate a - c*X_2
  J_1: ->  X_1; a - c*X_2

  // X_1 -> X_2 with rate b*X_1
  J_2: X_1 -> X_2; b*X_1

  // X_2 -> 0  with rate b*X_2
  J_3: X_2 ->   ; b*X_2
  
  // Analytic solution:
  // X_1_analytic(t) = (a/(b+c)) * (1 + (sqrt(c/b)*sin(t*sqrt(b*c)) - cos(t*sqrt(b*c))) * exp(-b*t))
  // X_2_analytic(t) = (a/(b+c)) * (1 - (sqrt(b/c)*sin(t*sqrt(b*c)) + cos(t*sqrt(b*c))) * exp(-b*t))
end
// @SIM T_START=0 T_END=20 N_STEPS=400// SIR model
// Related: m29_time_varying_beta.ant (SIR with time-varying β)
// Kermack WO, McKendrick AG (1927) A contribution to the
//   the mathematical theory of epidemics. Proc R Soc A 115: 700-721.
// States and ICs (NYC-scale):
//   S(0) = 2e7 - 1 = 19999999
//   I(0) = 1
//   R(0) = 0
// Parameters:
//   beta_rate  = 1 / S0 = 5e-8   [/d/person]
//   gamma_rate = 1/7 ≈ 0.142857 [/d]
//
// Canonical S-system requires two monomials per ODE with positive coefficients.
// Use arbitrary positive "slack" epsilons; dynamics are unchanged.
// epsS = 1.0   // for S'
// epsR = 1.0   // for R'
//
// Dynamics (each RHS: production monomial − degradation monomial)
// S' =  epsS * S * I        -  (epsS + beta_rate) * S * I;   // net = -beta_rate*S*I
// I' =  beta_rate * S * I        -  gamma_rate * I;               // already two monomials
// R' =  (gamma_rate + epsR) * I  -  epsR * I;       
//
model SIR()
  // initial conditions
  S = 19999999
  I = 1
  R = 0

  // parameters
  S0 = 20000000
  I0 = 1
  beta_rate = 1e-7
  gamma_rate = 0.142857142857143

  // infection: S -> I at rate beta_rate * S * I
  R1: S -> I; beta_rate*S*I

  // recovery: I -> R at rate gamma_rate * I
  R2: I -> R; gamma_rate*I
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Model for Bertalanffy growth with linear loss
// von Bertalanffy L (1938) A quantitative theory of organic growth
//   (inquiries on growth laws. II) Human Biology 10: 181-213.
// ODE (already in S-system form):
//   x' = p*x^a - q*x
// ICs: x(0)=10
// Params: p=7, a=2/3, q=2
// Note: mmax = (p/q)^(1/(1-a)) = (7/2)^(3) = 42.875 (not used directly)

// Analytic solution (for reference only; not parsed):
//   x(t) = mmax * ( 1 - (1 - (x(0)/mmax)^(1-a)) * exp(-q*(1-a)*t) )^(1/(1-a))

model Bertalanffy()
  // initial conditions
  x = 10

  // parameters
  p = 7
  a = 2/3  // 0 < a < 1
  q = 2

  // observable: carrying capacity / asymptote
  // var mmax;
  // mmax := (p/q)^(1/(1 - a));   // = 42.875 with settings above

  // flows
  G:  -> x; p*x^a      // growth
  L:  x -> ; q*x       // linear loss
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Model for irreversible chemical reaction: A + B -> C (mass-action kinetics)
// ODEs:
//   A' = -kf*A*B
//   B' = -kf*A*B
//   C' =  kf*A*B
// ICs: A(0)=10, B(0)=8, C(0)=0
// Params: kf = 0.01 (units depend on the concentration/time units)
//
// Canonical S-system dynamics (two single monomials per ODE)
//   eps = 1.0;   // arbitrary slack > 0 (can be any positive value)
//   A' =  eps * A * B  -  (eps + kf) * A * B;
//   B' =  eps * A * B  -  (eps + kf) * A * B;
//   C' =  (eps + kf) * A * B  -  eps * A * B;
//
model A_plus_B_to_C()
  // initial conditions
  A = 10
  B = 8
  C = 0

  // parameter
  k_f = 0.01

  // reaction
  R_1: A + B -> C; k_f*A*B
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// van der Pol oscillator
// This model is essentially the same as S1987_E2_van_der_pol().
// van der Pol B (1926) On relaxation-oscillations.
//   The London, Edinburgh, and Dublin Philosophical Magazine
//   and Journal of Science 2: 978-992.
// This model is essentially the same as S1987_E2_van_der_pol.
// ODEs:
//   x' = y
//   y' = mu*(1 - x^2)*y - x
// ICs: x(0)=2, y(0)=1
// Params: mu=5
// 
// Recast:
// slack
//   eps1 = 1; eps2 = 1; eps3 = 1; eps4 = 1;
//
// x' = y
//   X1' = (eps1 + 1)*X2*X3*X4  -  eps1*X2*X3*X4;
//
// choose X2' = - X1 * X3^(-1) * X4^(-1)  (with ε-splitting)
//   X2' =  eps2*X1*(X3^(-1))*(X4^(-1))  -  (eps2 + 1)*X1*(X3^(-1))*(X4^(-1));
//
// X3' =  mu*X3          (ε-split)
//   X3' = (eps3 + mu)*X3  -  eps3*X3;
//
// X4' = - mu*X1^2*X4    (ε-split)
//   X4' =  eps4*X1^2*X4    -  (eps4 + mu)*X1^2*X4;
//
// ICs
//   X1 = 2;
//   X2 = 1;  X3 = 1;  X4 = 1;
model van_der_Pol()
  // initial conditions
  x = 2
  y = 1

  // parameter
  mu = 5

  // flows (mass-action-style reactions with general rate laws)
  R1:  -> x; y
  R2:  -> y; mu*(1 - x^2)*y - x
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as S1988_monod_chemostat.
//
// There is no exact recasting of the original model into canonical S-system form.
// We can find a recasting in GMA form.
//  
// States
//   species X1, X2, Y;   // Y := 1 + X2
//
// Dynamics (all terms are power-law monomials; negatives appear via subtraction)
// X1' = alpha1 * X1 * X2 / (1 + X2) - X1  =>  alpha1*X1*X2*Y^(-1) - 1*X1
//   X1' = alpha1 * X1 * X2 * (Y^(-1)) - 1 * X1;
// X2' = X_r - X2 - beta2 * X1 * X2 / (1 + X2)
//   X2' = X_r - 1 * X2 - beta2 * X1 * X2 * (Y^(-1));
//
// Ancillary identity (exact): Y = 1 + X2  ⇒  Y' = X2'
//   Y' = X_r - 1 * X2 - beta2 * X1 * X2 * (Y^(-1));
//
// Initial conditions (consistent with the original)
//   X1 = 0.1;
//   X2 = 0.1;
//   Y  = 1 + X2;
model Monod_chemostat()

  // Original general ODE model (not the S-system recast).
  // Source: Savageau (1988), "Introduction to S-Systems and the Underlying Power-Law Formalism",
  // Proc. 6th Int. Conf. on Mathematical Modelling, pp. 549–550, Eq. (19).
  // This version keeps the paper’s normalization: time scaled by dilution rate D (so D=1),
  // substrate X2 normalized by Monod constant K_s (so K_s=1).

  // Variables (species)
  species X1, X2;

  // Parameters
  // alpha1    : max specific growth rate (in excess substrate)
  // beta2     : alpha1 / Y (Y = yield), treated here as independent parameter
  // X_r        : reservoir substrate concentration (normalized)
  alpha1 = 0.2;
  beta2  = 0.1;
  X_r     = 2.0;

  // Dynamics (exactly as Eq. (19) in the paper)
  X1' = alpha1*X1*X2/(X2 + 1) - X1;
  X2' = (X_r - X2) - beta2*X1*X2/(X2 + 1);

  // Initial conditions (placeholders; adjust as needed)
  X1 = 0.1;
  X2 = 0.1;

  // Notes:
  // * Positive orthant invariance expected for X1, X2 given positive ICs/params.
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Starting model:
//   X1' = a*X1*X2 - b*X1^2*X2 - c*X1^2
//   X2' = X1 - X2
// We recast into S-system form via a change of variables:
//   X1 = X3*X4.
// Dynamic states: X2, X3, X4  (X1 is observed as X3*X4).
// Parameters
//   a = 0.15;   // >0
//   b = 0.03;   // >0
//   c = 0.01;   // >0
//
// Choose positive S-system rate constants with (alpha4 - beta4) = -c
//   alpha4 = 1.0;          // arbitrary >0
//   beta4  = 1.0 + c;      // ensures alpha4 - beta4 = -c
//
// States
//   species X2, X3, X4;
//
// Canonical S-system dynamics (two monomials per ODE)
// X3' =  a * X3 * X2        −  b * X3^2 * X4 * X2
//   X3' =  a * X3 * X2 - b * (X3^2) * X4 * X2;
//
// X4' = (alpha4) * X3 * X4^2 − (beta4) * X3 * X4^2  ⇒ net = (alpha4 - beta4) * X3 * X4^2 = -c * X3 * X4^2
//   X4' =  alpha4 * X3 * (X4^2) - beta4 * X3 * (X4^2);
//
// X2' =  1 * X3 * X4        −  1 * X2
//   X2' =  X3 * X4 - X2;
//
// Observable for the original variable
//   var X1_obs;
//   X1_obs := X3 * X4;
//
// Initial conditions (consistent with original X1(0)=1, X2(0)=3)
//   X3 = 0.5;   // pick any positive pair with X3*X4 = 1
//   X4 = 2.0;
//   X2 = 3.0;
//
model toy_mass_action()

  // ODE model for mass-action kinetics, from the illustrative example
  // used to demonstrate Operation (4) (product rule) and auxiliary variables (X1 = X3*X4).
  // Voit (1988), pp. 223–224: X2' = X1 - X2 and X1' built from four positive-rate terms that are
  // later split across X3 and X4 before elimination. Summing those terms gives:
  //    X1' = (gamma1 + gamma3)*X1*X2 - gamma2*X1^2*X2 - gamma4*X1^2
  // We rename parameters as follows: a = gamma1 + gamma3, b = gamma2, c = gamma4.

  species X1, X2;
  a = 0.15;   // net coefficient on X1*X2
  b = 0.03;   // coefficient on X1^2*X2
  c = 0.01;   // coefficient on X1^2
  k = 0.5;

  // Dynamics (original system prior to S-system recast)
  X1' = a*X1*X2 - b*X1^2*X2 - c*X1^2;
  X2' = X1 - k*X2;

  // Initial conditions
  X1 = 1.0;
  X2 = 3.0;

  // Notes:
  // * This is the unreduced, original form implied by the text; Voit then introduces X3, X4 with X1 = X3*X4
  //   to arrive at canonical S-system equations. 
  // * All parameters are positive, as stated.
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as V1988b_exponential_ode.
//
// Exact canonical S-system for: X' = exp(k*X)
// Introduce Y = exp(k*X). IC must satisfy Y(0) = exp(k*X(0)).
//
//   species X, Y;
//
// Parameter
//   k = -0.5;    // any real k; here negative to avoid blow-up
//
// Choose positive rate constants so that:
//   (alpha1 - beta1) = 1   and   (alpha2 - beta2) = k
// The two terms per ODE are canonical monomials (same variables allowed).
//   b1 = 1.0;                // arbitrary > 0
//   alpha1 = b1 + 1.0;       // => alpha1 - beta1 = 1
//   beta1  = b1;
//
//  alpha2 = 1.0;            // pick any > 0
//  beta2  = 1.0 - k;        // ensures alpha2 - beta2 = k (positive since k < 1)
//
// Canonical S-system dynamics (two monomials per equation)
//   X' = alpha1 * (Y^1) - beta1 * (Y^1);   // net = (alpha1 - beta1)*Y = Y
//   Y' = alpha2 * (Y^2) - beta2 * (Y^2);   // net = (alpha2 - beta2)*Y^2 = k*Y^2
//
// Initial conditions (consistent with Y = exp(k*X))
//   X = 0.0;
//   Y = 1.0;   // exp(k*X0) with X0=0, k=-0.5
//
model composite_func_decomp()

  // Original general ODE (composite function), used to illustrate recasting Operation (3)
  // in Voit (1988), "NEW NONLINEAR METHODOLOGIES FOR MODELING MOLECULAR AND CELLULAR SYSTEMS".
  // Example: x' = exp(x) (see discussion around decomposition of composite functions).
  // This is a synthetic test case to exercise the recaster's handling of exp() via variable introduction.

  species X;

  k = -0.5; // no finite-time explosion for k < 0

  // Dynamics
  X' = exp(k*X); // X >= 0 for X(0) >= 0

  // Initial condition (placeholder)
  X = 0.0; // non-negative initial condition

  // Notes:
  // * No parameters appear in the paper's minimal example; treat as unit scaling.
  // * Recasting typically introduces an auxiliary variable Z = exp(X) to obtain S-system form.
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// This model is essentially the same as MS2007_MM_to_GMA.
//
// Exact canonical S-system of:
//   X1' = (Vmax1*cX0)/(Km1 + cX0) - (Vmax2*X1)/(Km2 + X1)
// Ancillary: Y2 = Km2 + X1  (enforced by Y2' = X1')
//
//   species X1, Y2;
//
// Parameters (as in the original)
//   Vmax1 = 1.0;
//   Km1   = 1.0;
//   Vmax2 = 0.8;
//   Km2   = 1.0;
//   cX0   = 1.0;
//
// S-system rate constants
//   alpha0 = (Vmax1*cX0)/(Km1 + cX0);   // constant production monomial
//   beta1  = Vmax2;                     // degradation coefficient
//
// Canonical S-system dynamics (two single monomials per ODE)
//   X1' = alpha0 - beta1 * X1 * (Y2^(-1));
//   Y2' = alpha0 - beta1 * X1 * (Y2^(-1));
//
// Consistent initial conditions
//   X1 = 0.1;
//   Y2 = Km2 + X1;   // ensures Y2(t) - X1(t) = Km2 for all t
//
model Michaelis_Menten_prod_deg()

  // Michaelis–Menten production/degradation example
  // Source: Marin-Sanguino et al. (2007), Optimization of biotechnological systems through GP.
  // See derivation around Eqs. (14–16): dX1/dt = Vmax1 * X0/(Km1 + X0) - Vmax2 * X1/(Km2 + X1)
  // X0 is treated as an independent (constant) input.

  species X_1;

  // Parameters (positive)
  V_1 = 1.0;
  K_1   = 1.0;
  V_2 = 0.8;
  K_2   = 1.0;
  X_0   = 1.0;   // independent input (constant)

  // Dynamics
  X_1' = (V_1*X_0)/(K_1 + X_0) - (V_2*X_1)/(K_2 + X_1);

  // Initial condition
  X_1 = 0.1;
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as MS2007_tryptophan_operon.
//
// Exact GMA (power-law) recast of the original trp-operon ODEs.
// There is no exact recasting of the original model into canonical S-system form.
//
// ===== Independent constants =====
//   cX4 = 0.003;
//   cX5 = 1.0;
//   cX6 = 2000.0;
//   cX7 = 1000.0;
//
// ===== Derived constants (assignment rules) =====
//   cX6sq := cX6^2;
//   X8    := 1 + cX5;        // 1 + cX5
//   X11   := 0.9 + cX4;
//   X12   := 0.02 + cX4;
//   X15   := 1 - 7.5*cX4;
//   alpha5 := 0.0022 * cX5;
//
// ===== Dynamic states =====
//   species X1, X2, X3;           // original species
//   species X9, X10, X13, X14;    // ancillaries depending on X3
//
// ===== ODEs for original species (all terms are monomials) =====
  // v1 = (X3+1)/(1+(1+cX5)X3)  =  X9 * X10^(-1)
  // v2 = (0.9 + cX4) * X1      =  X11 * X1
  // v3 = X1
  // v4 = (0.02 + cX4) * X2     =  X12 * X2
  // v5 = (X3^2 cX6^2)/(cX6^2 + X3^2) = cX6^2 * X3^2 * X13^(-1)
  // v6 = cX4 * X3
  // v7 = 0.0022 * cX5 * X3 / (1+X3)  = alpha5 * X3 * X9^(-1)
  // v8 = (1 - 7.5*cX4) * X3 * cX7 / (X3 + 0.005) = (X15*cX7) * X3 * X14^(-1)
//
//   X1' =  (X9 * (X10^(-1))) - (X11 * X1);
//   X2' =  (X11 * X1)        - (1 * X1);
//   X3' = alpha5*X3*(X9^(-1)) + (X15*cX7)*X3*(X14^(-1)) - X1 - X12*X2 - cX6sq*(X3^2)*(X13^(-1)) - cX4*X3;
//
// ===== Ancillary identity ODEs (exact via chain rule) =====
  // X9  = X3 + 1        => X9'  = X3'
  // X10 = 1 + X8*X3     => X10' = X8 * X3'
  // X14 = X3 + 0.005    => X14' = X3'
  // X13 = cX6^2 + X3^2  => X13' = 2*X3*X3'
//
//   X9' = alpha5*X3*(X9^(-1)) + (X15*cX7)*X3*(X14^(-1)) - X1 - X12*X2 - cX6sq*(X3^2)*(X13^(-1)) - cX4*X3;
//
//   X10' = X8*(alpha5*X3*(X9^(-1)) + (X15*cX7)*X3*(X14^(-1)) - X1 - X12*X2 - cX6sq*(X3^2)*(X13^(-1)) - cX4*X3);
//
//   X14' = alpha5*X3*(X9^(-1)) + (X15*cX7)*X3*(X14^(-1)) - X1 - X12*X2 - cX6sq*(X3^2)*(X13^(-1)) - cX4*X3;
//
//   X13' = 2*X3*(alpha5*X3*(X9^(-1)) + (X15*cX7)*X3*(X14^(-1)) - X1 - X12*X2 - cX6sq*(X3^2)*(X13^(-1)) - cX4*X3);
//
// ===== Initial conditions (match your original) =====
//   X1 = 0.185;
//   X2 = 7.99;
//   X3 = 100.0;
//   X9  = X3 + 1;
//   X10 = 1 + X8*X3;
//   X13 = cX6sq + X3^2;
//   X14 = X3 + 0.005;
//
model tryptophan_operon()

  // Tryptophan operon model (ORIGINAL ODE form before ancillary-variable recast)
  // Source: Marin-Sanguino et al. (2007), Fig. 4 and Eqs. (41–42).
  // States: X1 (mRNA), X2 (enzyme), X3 (tryptophan).
  // X4–X7 are treated as independent (constant) variables affecting the rates.

  species X_1, X_2, X_3;

  // Independent variables (constants)
  X_4 = 0.05;     // regulator
  X_5 = 0.5;       // auxiliary factor
  X_6 = 50.0;    // saturation scale
  X_7 = 150.0;    // growth/excretion factor
  tau = 0.1;

  // Dynamics via original rational-rate definitions (Eq. 42)
  // v1 = (X_3 + 1) / (1 + (1 + X_5) * X_3)
  // v2 = (0.9 + X_4) * X_1
  // v3 = X_1
  // v4 = (0.02 + X_4) * X_2
  // v5 = (X_3^2 * X_6^2) / (X_6^2 + X_3^2)
  // v6 = X_3 * X_4
  // v7 = 0.0022 * X_3 * X_5 / (1 + X_3)
  // v8 = (1 - 7.5*X_4) * X_3 * X_7 / (X_3 + 0.005)

  X_1' = tau*((X_3 + 1)/(1 + (1 + X_5)*X_3) - (0.9 + X_4)*X_1);
  X_2' = tau*((0.9 + X_4)*X_1 - (X_1));
  X_3' = tau*(-(X_1) - (0.02 + X_4)*X_2 - ((X_3^2 * X_6^2)/(X_6^2 + X_3^2)) - (X_3*X_4) + (0.0022 * X_3 * X_5)/(1 + X_3) + ((1 - 7.5*X_4) * X_3 * X_7)/(X_3 + 0.005));

  // Initial conditions
  X_1 = 2;
  X_2 = 12;
  X_3 = 25.0;
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Recasting
//   species X1, F            // X1 = t + c ; F = f
//   c = 1.0                  // shift > 0 to keep X1>0
//
// Canonical S-system (difference of power-law monomials)
//   X1' = 1                  // = 1*X1^0  - 0
//   F'  = c*F - X1*F         // = (c)*X1^0*F^1  - (1)*X1^1*F^1
//
// ICs corresponding to t=0, f(0)=1/sqrt(2*pi)
//   X1 = c
//   F  = 1/sqrt(2*pi)
model normal_dens()
  // f'(t) = -t f(t); t is the independent variable
  species t, f
  t' = 1                   // march along the abscissa
  f' = -t * f              // original linear ODE
  // ICs (example)
  t = 0
  f = 1/sqrt(2*pi)        
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as RV1990_central_t_density.
// Recasting:
// X1 = t + c, X2 = nu + t^2, X3 = f(t)
//   species X1, X2, X3
//   nu = 8
//   c  = 1.0                 // shift > 0
//
// Canonical S-system
//   X1' = 1                                  // = 1 - 0
//   X2' = 2*X1 - 2*c                         // = (2)*X1^1 - (2*c)*X1^0
//   X3' = (nu+1)*c * X2^(-1) * X3 - (nu+1) * X1 * X2^(-1) * X3;
//
// ICs matching t=0
// gamma((nu+1)/2) / (sqrt(nu*pi) * gamma(nu/2)) for nu=8 ≈ 0.386
//   X1 = c;
//   X2 = nu;
//   X3 = 0.3866990209613933;
//
model central_t()
  // Central t density: f'(t) = -((nu+1)*t/(nu + t^2)) * f(t)
  species t, f
  nu = 8                   // degrees of freedom (example)

  t' = 1
  f' = - ( (nu+1) * t / (nu + t^2) ) * f

  // ICs (example): start at t=0 with exact value
  // f(0) = Gamma((nu+1)/2) / (sqrt(nu*pi) * Gamma(nu/2))
  // For nu=8: gamma(4.5) / (sqrt(8*pi) * gamma(4)) = 0.3866990209613933
  t = 0
  f = 0.3866990209613933
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Goodwin BC (1965) Oscillatory behavior in enzymatic control processes
//   Advances in Enzyme Regulation 3: 425-428.
//
// Recasting:
//
// States
//   species X1, X2, X3, Y    // Y := 1 + (X3/K)^n
//
// Parameters (positive)
//   k1 = 5;   K = 2;   n = 3;   d1 = 1;
//   k2 = 1.5; d2 = 1;
//   k3 = 1.2; d3 = 1;
//
// Canonical S-system (two monomials per ODE)
//   X1' =  k1 * (Y^(-1))              -  d1 * X1;
//   X2' =  k2 * X1                    -  d2 * X2;
//   X3' =  k3 * X2                    -  d3 * X3;
//   Y'  =  (n*k3)/(K^n) * X2*(X3^(n-1))  -  (n*d3)/(K^n) * (X3^n);
//
// Initial conditions (consistent with Y definition)
//   X1 = 1;  X2 = 1;  X3 = 1;
//   Y  = 1 + (X3/K)^n;   // = 1.125 with K=2, n=3, X3=1
//
model Goodwin()

  species X1, X2, X3   // mRNA, enzyme, product (repressor)

  // parameters (example values; keep positive)
  k1 = 5;   K = 2;   n = 3;   d1 = 1;
  k2 = 1.5; d2 = 1;
  k3 = 1.2; d3 = 1;

  // X1' = k1 / (1 + (X3/K)^n) - d1*X1
  X1' = k1 / (1 + (X3/K)^n) - d1*X1;
  X2' = k2*X1 - d2*X2;
  X3' = k3*X2 - d3*X3;

  // ICs (example)
  X1 = 1;  X2 = 1;  X3 = 1;
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Rosenzweig ML, MacArthur RH (1963) Am Nat 97: 209-223.
// Holling SC (1959) Canadian Entomologist 91: 385-398.
//
// There is no exact recasting of the original model into canonical S-system form.
// We can recast into GMA form.
// ===== States =====
//   species x, y, Y    // Y := 1 + a*h*x
//
// ===== Parameters (positive) =====
//   r = 1.0; K = 10.0; a = 0.5; h = 0.4; e = 0.6; m = 0.2;
//
// ===== Exact GMA dynamics =====
// Original:
//   x' = r*x*(1 - x/K) - (a*x*y)/(1 + a*h*x)
//   y' = e*(a*x*y)/(1 + a*h*x) - m*y
//
// With Y = 1 + a*h*x:
//   x' =  r*x  -  (r/K)*x^2  -  a*x*y*(Y^(-1));
//   y' =  (a*e)*x*y*(Y^(-1)) -  m*y;
//
// Ancillary identity (exact via chain rule): Y' = a*h*x'
//   Y' =  a*h*( r*x - (r/K)*x^2 - a*x*y*(Y^(-1)) );
//
// ===== Initial conditions (consistent with Y definition) =====
//   x = 2;
//   y = 1;
//   Y = 1 + a*h*x;   // = 1 + 0.5*0.4*2 = 1.4
//
model RM_predator_prey()

  species x, y
  r = 1.0; K = 10.0; a = 0.5; h = 0.4; e = 0.6; m = 0.2;

  x' = r*x*(1 - x/K) - (a*x*y)/(1 + a*h*x);
  y' = e*(a*x*y)/(1 + a*h*x) - m*y;

  x = 2; y = 1;
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Briggs GE, Haldane JB (1925) A note on the kinetics of enzyme action.
//   Biochem J 19: 338-339.
// Recasting:
// States: S (substrate), ES (complex), P (product), Y (free enzyme)
//   species S, ES, P, Y;
//
// Canonical S-system (each RHS is production monomial − degradation monomial)
// S'  =  km1*ES        −  k1*S*Y
//   S'  =  km1 * ES        -  k1 * S * Y;
//
// ES' =  k1*S*Y        −  (km1 + k2)*ES
//   ES' =  k1 * S * Y      -  (km1 + k2) * ES;
//
// P'  =  (k2 + epsP)*ES −  epsP*ES   (ε-splitting keeps both coefficients > 0; net = k2*ES)
//   epsP = 1.0;
//   P'  =  (k2 + epsP) * ES -  epsP * ES;
//
// Y'  =  (km1 + k2)*ES  −  k1*S*Y    (so Y' = -ES' ⇒ Y + ES = Etot)
//   Y'  =  (km1 + k2) * ES -  k1 * S * Y;
//
// Initial conditions (consistent with conservation)
//   S  = 1.0;
//   ES = 0.0;
//   P  = 0.0;
//   Y  = Etot - ES;   // = 1.0
//
model Briggs_Haldane()

  species S, C, P
  // enzyme conservation: E = E_T - C (implicit)
  E_T = 1.0;
  k_1 = 1.0; k_m_1 = 0.5; k_2 = 0.3;

  // S' = -k_1*S*E + k_m_1*C   with E = E_T - C
  S'  = -k_1*S*(E_T - C) + k_m_1*C;
  C' =  k_1*S*(E_T - C) - (k_m_1 + k_2)*C;
  P'  =  k_2*C;

  S = 1.0; C = 0.0; P = 0.0;
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Andrews JF (1968) Biotechnol Bioeng 10: 707-723. 
// Exact GMA recast of:
  //   mu := mu_max * S / (K_S + S + S^2 / K_I)
  //   X' = (mu - D) * X
  //   S' = D*(S_in - S) - (1/Y_xs)*mu*X
  //
  // Auxiliary variable:
  //   Y = K_S + S + S^2 / K_I
  // so that
  //   mu = mu_max * S * Y^(-1)
  //
  // Then:
  //   X' = mu_max * X * S * Y^(-1) - D * X
  //   S' = D*S_in - D*S - (mu_max/Y_xs) * X * S * Y^(-1)
  //
  // and using Y = K_S + S + S^2/K_I ⇒ Y' = (1 + 2S/K_I) * S'
  // gives, after expansion:
  //
  //   Y' =  D*S_in
  //       + (2*D*S_in/K_I) * S
  //       - D*S
  //       - (2*D/K_I) * S^2
  //       - (mu_max/Y_xs)        * X * S      * Y^(-1)
  //       - (2*mu_max/(K_I*Y_xs))* X * S^2    * Y^(-1)
  //
  // Every term is a power-law monomial,
  // so this is an exact GMA representation of the original system.

model Haldane_chemostat()

  species X, S
  mu_max = 1.0; K_S = 0.5; K_I = 2.0;  // kinetics
  Y_xs = 0.5;                           // yield
  D = 0.1;  S_in = 5.0;                 // chemostat

  mu := mu_max * S / (K_S + S + (S^2)/K_I);

  X' = (mu - D) * X;
  S' = D*(S_in - S) - (1/Y_xs)*mu*X;

  X = 0.1; S = 4.0;
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Prigogine I, Lefever R (1968) J Chem Phys 48: 1695-1700.
// Related: test_models3/HBF1998_brusselator.ant
// This model is essentially the same as HBF1998.
// Recast:
// Mapping (exact):
//    x = X1 * X2
//    y = X3
//
//   species X1, X2, X3;
//
// Parameters (carry-over)
//   A = 1.0;
//   B = 3.0;
// 
// Canonical S-system (two monomials per ODE; positive coefficients)
// From product rule: (X1*X2)' = X1'*X2 + X1*X2'
//   X1' =  A * (X2^(-1))     -  B * X1;
//   X2' =  1 * X1*(X2^2)*X3  -  1 * X2;
//   X3' =  B * X1*X2         -  1 * (X1^2)*(X2^2)*X3;
//
// Initial conditions (consistent with x=1, y=1)
//   X1 = 1;
//   X2 = 1;
//   X3 = 1;
//
// Observables (original variables)
//   var x_obs, y_obs;
//   x_obs := X1 * X2;
//   y_obs := X3;
//
model Brusselator()

  species x, y
  A = 1.0; B = 3.0;

  x' =  A - (B + 1)*x + x^2*y;
  y' =  B*x - x^2*y;

  x = 1; y = 1;
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Monod J, Wyman J, Changeux JP (1965) J Mol Biol 12: 88-118.
// This model has GMA form.
model MWC()

  // Monod-Wyman-Changeux (MWC) model

  // ===== Parameters =====

  N_A   = 6.02214076e23;   // molecules per mole
  V_cyt = 1e-12;           // L per cell

  K_T = 1e6/(N_A*V_cyt);   // /(molecule/cell)
  K_R = 5e6/(N_A*V_cyt);   // /(molecule/cell)

  c = K_T/K_R;             // dimensionless
  n = 4;                   // tetramer

  L_0 = 0.1;               // dimensionless
  L   = 1/L_0;             // dimensionless

  L_1 = L_0*(K_R/K_T)^1;
  L_2 = L_0*(K_R/K_T)^2;
  L_3 = L_0*(K_R/K_T)^3;
  L_4 = L_0*(K_R/K_T)^4;

  k_off = 0.1;             // /s

  k_mT = k_off;            // /s
  k_pT = k_mT*K_T;         // /(molecule/cell)/s

  k_mR = k_off;            // /s
  k_pR = k_mR*K_R;         // /(molecule/cell)/s

  k_mL_0 = k_off;          // /s
  k_pL_0 = k_mL_0*L_0;     // /s

  k_mL_1 = k_off;          // /s
  k_pL_1 = k_mL_1*L_1;     // /s

  k_mL_2 = k_off;          // /s
  k_pL_2 = k_mL_2*L_2;     // /s

  k_mL_3 = k_off;          // /s
  k_pL_3 = k_mL_3*L_3;     // /s

  k_mL_4 = k_off;          // /s
  k_pL_4 = k_mL_4*L_4;     // /s

  P_0 = 1e5;               // total oligomer copies
  S_0 = 1e5;               // ligand copies

  // ===== State variables (species) =====

  species S;
  species P_T0, P_T1, P_T2, P_T3, P_T4;
  species P_R0, P_R1, P_R2, P_R3, P_R4;

  // ===== Initial conditions =====

  P_T0 = P_0*(1/(1 + L_0));
  P_R0 = P_0*(L_0/(1 + L_0));

  P_T1 = 0.0;
  P_T2 = 0.0;
  P_T3 = 0.0;
  P_T4 = 0.0;

  P_R1 = 0.0;
  P_R2 = 0.0;
  P_R3 = 0.0;
  P_R4 = 0.0;

  S    = S_0;

  // ===== Binding/unbinding: T state =====

  R_T_bind0:   P_T0 + S -> P_T1; k_pT*4*P_T0*S;
  R_T_unbind1: P_T1 -> P_T0 + S; k_mT*1*P_T1;

  R_T_bind1:   P_T1 + S -> P_T2; k_pT*3*P_T1*S;
  R_T_unbind2: P_T2 -> P_T1 + S; k_mT*2*P_T2;

  R_T_bind2:   P_T2 + S -> P_T3; k_pT*2*P_T2*S;
  R_T_unbind3: P_T3 -> P_T2 + S; k_mT*3*P_T3;

  R_T_bind3:   P_T3 + S -> P_T4; k_pT*1*P_T3*S;
  R_T_unbind4: P_T4 -> P_T3 + S; k_mT*4*P_T4;

  // ===== Binding/unbinding: R state =====

  R_R_bind0:   P_R0 + S -> P_R1; k_pR*4*P_R0*S;
  R_R_unbind1: P_R1 -> P_R0 + S; k_mR*1*P_R1;

  R_R_bind1:   P_R1 + S -> P_R2; k_pR*3*P_R1*S;
  R_R_unbind2: P_R2 -> P_R1 + S; k_mR*2*P_R2;

  R_R_bind2:   P_R2 + S -> P_R3; k_pR*2*P_R2*S;
  R_R_unbind3: P_R3 -> P_R2 + S; k_mR*3*P_R3;

  R_R_bind3:   P_R3 + S -> P_R4; k_pR*1*P_R3*S;
  R_R_unbind4: P_R4 -> P_R3 + S; k_mR*4*P_R4;

  // ===== T <-> R isomerization =====

  Iso0_f: P_T0 -> P_R0; k_pL_0*P_T0;
  Iso0_b: P_R0 -> P_T0; k_mL_0*P_R0;

  Iso1_f: P_T1 -> P_R1; k_pL_1*P_T1;
  Iso1_b: P_R1 -> P_T1; k_mL_1*P_R1;

  Iso2_f: P_T2 -> P_R2; k_pL_2*P_T2;
  Iso2_b: P_R2 -> P_T2; k_mL_2*P_R2;

  Iso3_f: P_T3 -> P_R3; k_pL_3*P_T3;
  Iso3_b: P_R3 -> P_T3; k_mL_3*P_R3;

  Iso4_f: P_T4 -> P_R4; k_pL_4*P_T4;
  Iso4_b: P_R4 -> P_T4; k_mL_4*P_R4;

end
// @SIM T_START=0 T_END=20 N_STEPS=400
// Exact S-system recast of dZ/dt = k * exp[(ln Z)^2] via two lifting steps.
// Variables:
//   X1 = Z
//   X2 = exp[(ln Z)^2]
//   X3 = ln Z
//
// Scaled S-system:
//   X1' = k * X2
//   X2' = 2*k * X1^-1 * X2^2 * X3
//   X3' = k * X1^-1 * X2
//
// Initial conditions
// X1(0) = Z(0)
// X3(0) = log Z(0)
// X2(0) = exp[(log Z(0))^2]
//
model scalarExpLog()

  // One-dimensional ODE with slowed dynamics
  species Z;

  // Time-scale parameter (dimension 1/time)
  k = 0.04

  // Dynamics: Z' = k * exp[(log Z)^2]
  Z' = k * exp((log(Z))^2);

  // Initial condition
  Z = 2;

end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as S1987_5_CSTR().
// Recast:
// Derived constant needed for exact matching:
//   C = a*b + 2*(1 + b)
// States
//   species X1, X2, X3, X4, X5, X6, X7, X8;
// S-system ODEs (each RHS is a difference of power-law monomials)
//   dX1/dt = 1/X2 - X1
//   dX2/dt = 2 A X5 X6 / X1 - A X2 X5 X6
//   dX3/dt = C/X4 - (1 + b) X3
//   dX4/dt = 2 B X5 X6 / X3 - B X1 X2 X5 X6 / X3
//   dX5/dt = C X5 / (X7^2 X8^2) - (1 + b) X3 X4 X5 /(X7^2 X8^2)
//   dX6/dt = 2 B X5 X6^2 / (X7^2 X8^2) - B X1 X2 X5 X6^2 / (X7^2 X8^2)
//   dX7/dt = (C / c)/X8 - [(1 + b) / c] X3 X4 / X8
//   dX8/dt = (2 B / c) X5 X6 / X7 - (B / c) X1 X2 X5 X6 / X7
// Initial conditions (as given)
//   X1 = 1;
//   X2 = Z10 + 1;
//   X3 = 1;
//   X4 = Z20 + 2;
//   X5 = 1;
//   X6 = exp(c*Z20/(c + Z20));
//   X7 = 1;
//   X8 = (c + Z20)/c;
// Observables: original variables
//   var Z1, Z2;
//   Z1 := X1*X2 - 1;
//   Z2 := X3*X4 - 2;
//
model CSTR()

  // Parameters
  A   = 1;
  B   = 1;
  a   = 0.5;
  b   = 1;
  c   = 1;
  Z10 = 0.2;
  Z20 = 0.2;

  species Z1, Z2;

  // Original ODEs consistent with the S-system you provided:
  Z1' = -Z1 + A*(1 - Z1)*exp(c*Z2/(c + Z2));
  Z2' = -Z2 + B*(1 - Z1)*exp(c*Z2/(c + Z2)) - b*(Z2 - a);

  // Initial conditions
  Z1 = Z10;
  Z2 = Z20;

end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as S1987_A3_cos_growth().
// Recasting of: dX/dt = X*cos(t),  X(0) = 1
// Lifted 3D autonomous system:
//   X_1 = X
//   X_2 = cos(t) + 2
//   X_3 = sin(t) + 2
//
// ODEs:
//   dX_1/dt = X_1*X_2 - 2*X_1
//   dX_2/dt = 2 - X_3
//   dX_3/dt = X_2 - 2
//
// ICs:
//   X_1(0) = 1
//   X_2(0) = 3
//   X_3(0) = 2

model cos_growth()
  // dX/dt = X*cos(t),  X(0) = 1

  species t, X

  // Independent variable
  t' = 1

  // State equation
  X' = X*cos(t)

  // Initial conditions
  t = 0
  X = 5
end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as S1987_A5_spiral().

// Exact S-system recast of:
//   t' = 1
//   Z' = (Z - t)/(Z + t)
//
// Transformation:
//   p   = 5
//   X1  = Z + p
//   X2  = t + p
//   X3  = Z + t
//
// Inverse:
//   Z = X1 - p
//   t = X2 - p
//
// Check:
//   Z' = X1' = X1/X3 - X2/X3 = (X1 - X2)/X3 = (Z - t)/(Z + t)
//   t' = X2' = 1
//   X3 = Z + t => X3' = Z' + t' = (Z - t)/(Z + t) + 1
//                 = 2Z/(Z + t) = 2 X1/X3 - 2p/X3

model spiral()

  // Scalar ODE:
  //   dZ/dt = (Z - t)/(Z + t)
  //   Z(0) = 4
  //
  // Implemented by treating t as an explicit time state with t' = 1.

  species t, Z;

  // Initial conditions
  t = 0;
  Z = 4;

  // Dynamics
  t' = 1;
  Z' = (Z - t)/(Z + t);

end
// @SIM T_START=0 T_END=20 N_STEPS=400
// This model is essentially the same as S1987_B4_torus().
// Recast:
// Mapping:
//   X1 = Z_1
//   X2 = Z_2
//   X3 = Z_3
//   X4 = sqrt(Z_1^2 + Z_2^2)
//
//   species X1, X2, X3, X4;
// Dynamics (all RHSs are sums of power-law monomials):
//   X1' = -X2 - X1*X3/X4
//   X2' =  X1 - X2*X3/X4
//   X3' =  X1/X4
//   X4' = -X3
//
// Initial conditions corresponding to:
// Z_1(0)=3, Z_2(0)=0, Z_3(0)=0
// X4(0) = sqrt(3^2+0^2) = 3
//   X1 = 3;
//   X2 = 0;
//   X3 = 0;
//   X4 = 3;
//
// Original variables
//  var Z_1, Z_2, Z_3;
//  Z_1 := X1;
//  Z_2 := X2;
//  Z_3 := X3;
//
model torus()

  // Torus-like trajectory system
  //
  // Original system:
  //   dZ_1/dt = -Z_2 - Z_1 Z_3 (Z_1^2 + Z_2^2)^(-1/2)
  //   dZ_2/dt =  Z_1 - Z_2 Z_3 (Z_1^2 + Z_2^2)^(-1/2)
  //   dZ_3/dt =  Z_1 (Z_1^2 + Z_2^2)^(-1/2)
  //
  // Initial conditions:
  //   Z_1(0) = 3
  //   Z_2(0) = 0
  //   Z_3(0) = 0

  species Z_1, Z_2, Z_3;

  // Initial conditions
  Z_1 = 3;
  Z_2 = 0;
  Z_3 = 0;

  // Dynamics
  Z_1' = -Z_2 - Z_1*Z_3*(Z_1^2 + Z_2^2)^(-0.5);
  Z_2' =  Z_1 - Z_2*Z_3*(Z_1^2 + Z_2^2)^(-0.5);
  Z_3' =  Z_1*(Z_1^2 + Z_2^2)^(-0.5);

end
// @SIM T_START=0 T_END=20 N_STEPS=400
// SIR model with time-dependent beta(t), exp-based step approximation.
// Related: m07_SIR.ant (standard SIR with constant β)
//   dS/dt = -beta_t*S*I + delta*R
//   dI/dt =  beta_t*S*I - gamma*I
//   dR/dt =  gamma*I - delta*R
//   dt/dt =  1
//
// Smooth step implemented with an exp-only approximation:
//
//   beta_t = beta0*0.5*(σ(t - tau0) - σ(t - tau1))
//          + beta1*0.5*(σ(t - tau1) + 1)
//
//   σ(x) ≈ (exp(2*k*x) - 1) / (exp(2*k*x) + 1)
//
// NOTE:
//   A tanh-based version would be:
//   beta_t = beta0*0.5*(tanh(k*(t - tau0)) - tanh(k*(t - tau1)))
//          + beta1*0.5*(tanh(k*(t - tau1)) + 1)

// Recast:
// Transformations:
  // E0 := exp(2*k*(t - tau0))
  // E1 := exp(2*k*(t - tau1))
  //
  // N0 := E0 - 1
  // Y0 := E0 + 1
  // N1 := E1 - 1
  // Y1 := E1 + 1
  //
  // σ0(t) := (E0 - 1)/(E0 + 1) = N0/Y0
  // σ1(t) := (E1 - 1)/(E1 + 1) = N1/Y1
  //
  // Original exp-based beta_t(t):
  //   beta_t(t) = beta0*0.5*(σ0(t) - σ1(t))
  //             + beta1*0.5*(σ1(t) + 1)
  //
  // After lifting:
  //   beta_t(t)*S*I =
  //       0.5*beta0 * S*I * N0*Y0^-1
  //     + 0.5*(beta1 - beta0) * S*I * N1*Y1^-1
  //     + 0.5*beta1 * S*I
  //
  // which is a sum of pure power-law monomials in (S, I, N0, Y0, N1, Y1).
// Dynamics:
  // Time variable
  //   t' = 1;
  // S dynamics:
  // dS/dt = -beta_t(t)*S*I + delta*R
  //   S' = -0.5*beta0*S*I*N0*Y0^(-1) - 0.5*(beta1-beta0)*S*I*N1*Y1^(-1) - 0.5*beta1*S*I + delta*R;
  // I dynamics:
  // dI/dt =  beta_t(t)*S*I - gamma_rate*I
  //   I' = 0.5*beta0*S*I*N0*Y0^(-1) + 0.5*(beta1-beta0)*S*I*N1*Y1^(-1) + 0.5*beta1*S*I - gamma_rate*I;
  // R dynamics:
  // dR/dt = gamma_rate*I - delta*R
  //   R' = gamma_rate*I - delta*R;
  // Exponential lifts:
  // E0(t) = exp(2*k*(t - tau0))  =>  E0' = 2*k*E0 * t' = 2*k*E0
  // E1(t) = exp(2*k*(t - tau1))  =>  E1' = 2*k*E1
  //   E0' = 2*k*E0;
  //   E1' = 2*k*E1;
  // Linear combinations N0, Y0, N1, Y1 that track (E0±1), (E1±1):
  // N0 = E0 - 1, Y0 = E0 + 1  =>  N0' = Y0' = E0' = 2*k*E0
  // N1 = E1 - 1, Y1 = E1 + 1  =>  N1' = Y1' = E1' = 2*k*E1
  //   N0' = 2*k*E0;
  //   Y0' = 2*k*E0;
  //   N1' = 2*k*E1;
  //   Y1' = 2*k*E1;
  // INITIAL CONDITIONS
  //   S = S0;
  //   I = I0;
  //   R = R0;
  //   t = 0;
  // E0(0) = exp(2*k*(0 - tau0)),  E1(0) = exp(2*k*(0 - tau1))
  //   E0 = exp(2*k*(0 - tau0));
  //   E1 = exp(2*k*(0 - tau1));
  // N0(0) = E0(0) - 1, Y0(0) = E0(0) + 1, etc.
  //   N0 = E0 - 1;
  //   Y0 = E0 + 1;
  //   N1 = E1 - 1;
  //   Y1 = E1 + 1;

model time_varying_beta()

  // -------------------------------------------------------------------
  // Parameters
  // -------------------------------------------------------------------
  S0    = 1e5;
  I0    = 1.0;
  R0    = 0.0;

  beta0 = 3e-6;
  beta1 = 15e-6;
  gamma_rate = 0.1;
  delta = 0.05;

  k     = 1.0;
  tau0  = 5.0;
  tau1  = 200.0;

  // -------------------------------------------------------------------
  // State variables
  // -------------------------------------------------------------------
  species S, I, R, t;

  // -------------------------------------------------------------------
  // Time-varying beta as assignment rule (uses model parameters)
  // -------------------------------------------------------------------
  beta_t := beta0*0.5 * ( (exp(2*k*(t - tau0)) - 1)/(exp(2*k*(t - tau0)) + 1) - (exp(2*k*(t - tau1)) - 1)/(exp(2*k*(t - tau1)) + 1) ) + beta1*0.5 * ( (exp(2*k*(t - tau1)) - 1)/(exp(2*k*(t - tau1)) + 1) + 1 );

  // -------------------------------------------------------------------
  // ODE system
  // -------------------------------------------------------------------
  S' = -beta_t*S*I + delta*R;
  I' =  beta_t*S*I - gamma_rate*I;
  R' =  gamma_rate*I    - delta*R;
  t' =  1;

  // -------------------------------------------------------------------
  // Initial conditions
  // -------------------------------------------------------------------
  S = S0;
  I = I0;
  R = R0;
  t = 0;

end
// @SIM T_START=0 T_END=200 N_STEPS=400
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Section 4C - Exponential composition (Equations 15-17)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 2
//
// Original ODE:
//   dZ/dt = exp[(ln Z)^2]
//
// Recast S-system (3 variables):
//   Define: X1 = Z, X2 = exp[(ln X1)^2], X3 = ln X1
//   X1(0) = 2, X2(0) = exp[(ln 2)^2], X3(0) = ln 2
//
//   dX1/dt = X2
//   dX2/dt = 2 * X1^(-1) * X2^2 * X3
//   dX3/dt = X1^(-1) * X2
//
// Constraints (invariant):
//   X2 = exp[(ln X1)^2]
//   X3 = ln X1
// =============================================================================

model S1987_4C_exp_composition()
    // Rate constant (controls timescale)
    // Small k prevents overflow while preserving S-system structure
    k = 0.001
    
    // Original single ODE (with rate constant)
    Z' = k * exp(ln(Z)^2)
    
    // Initial condition
    Z = 2
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Section 4D - Sum reduction (Equations 22-25)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 4
//
// Original ODE:
//   dZ/dt = 2*Z^(2/3) - Z^2 - Z^(1/2)
//
// Recast S-system (2 variables):
//   Define: Z = X1*X2
//   X1(0) = 1, X2(0) = 4
//
//   dX1/dt = -X1^(1/2) * X2^(-1/2)
//   dX2/dt = 2*X1^(2/3)*X2^(2/3) - X1*X2^2
//
// Logarithmic form (Equation 25):
//   dY1/dt = -exp[-(Y1+Y2)/2]
//   dY2/dt = 2*exp[-(Y1+Y2)/3] - exp[(Y1+Y2)]
//   where Y = log(X)
//
// Translation symmetry: Y1 + Q, Y2 - Q leaves system unchanged
// Three basins: 0 < Z < 0.0158123, 0.0158123 < Z < 1, Z > 1
// Fixed points: Z = 1 (attracting), Z = 0.0158123 (repelling)
// =============================================================================

model S1987_4D_sum_reduction()
    // Original single ODE with sum of power-law terms
    Z' = 2*Z^(2/3) - Z^2 - Z^(1/2)
    
    // Initial condition
    Z = 4
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Section 5 - CSTR (Continuous Stirred Tank Reactor)
//          Equations 28-39
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = Z10, Z2(0) = Z20
//
// Original ODEs (Equation 28):
//   dZ1/dt = -Z1 + A*(1-Z1)*exp[c*Z2/(c+Z2)]
//   dZ2/dt = -Z2 + B*(1-Z1)*exp[c*Z2/(c+Z2)] - b*(Z2-a)
//
// NOTE: Parameter values below were not specified in the original paper
//       and have been added for simulation purposes.
//
// Recast S-system (8 variables, Equation 36):
//   After translation X1=Z1+1, X2=Z2+2 and decomposition steps,
//   then replacing each variable by products of new variables:
//
//   dX1/dt = 2*A*X3^(-1)*X4*X5 - A*X1*X4*X5
//   dX2/dt = C*X3^(-1) - (1+b)*X3
//   dX3/dt = 2*A*X3^(-1)*X4*X5 - A*X1*X4*X5
//   dX4/dt = 2*B*X3^(-1)*X5*X6 - B*X1*X2*X3^(-1)*X5*X6
//   dX5/dt = c*X3*X4^(-2)*X5^(-2) - (1+b)*X3^2*X4^(-1)*X5*X6^(-2)*X7^(-2)
//   dX6/dt = 2*B*X3*X4^2*X5^(-2)*X6^(-2) - B*X1*X2*X3*X4^2*X5^(-2)*X6^(-2)
//   dX7/dt = (C/c)*X3^(-1) - ((1+b)/c)*X3*X5*X7^(-1)
//   dX8/dt = (2*B/c)*X3*X5*X7^(-1) - (B/c)*X1*X2*X3*X5*X7^(-1)
//
//   where C = a*b + 2*(1+b)
//
// Constraints (6 constraints reduce 8D to 2D manifold):
//   X5*X6 = exp[c*(X3*X4-2)/(c+X5*X6-2)]
//   X7*X8 = (c+X5*X6-2)/c
//   X1*X2 = old_X1, X3*X4 = old_X2, X5*X6 = old_X3, X7*X8 = old_X4
//
// Original variables reconstructed as:
//   Z1(t) = X1(t)*X2(t) - 1
//   Z2(t) = X3(t)*X4(t) - 2
// =============================================================================

model S1987_5_CSTR()
    // Parameters (added for simulation - not in original paper)
    A = 10.0    // Damköhler number for material balance
    B = 10.0    // Damköhler number for energy balance  
    c = 20.0    // Activation energy parameter
    b = 0.5     // Heat transfer coefficient
    a = 0.0     // Ambient temperature offset
    
    // Original ODEs for CSTR
    Z1' = -Z1 + A*(1-Z1)*exp(c*Z2/(c+Z2))
    Z2' = -Z2 + B*(1-Z1)*exp(c*Z2/(c+Z2)) - b*(Z2-a)
    
    // Initial conditions (added for simulation)
    Z1 = 0.1
    Z2 = 0.5
end
// @SIM T_START=0 T_END=6 N_STEPS=600 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Related: test_models1/m01_exp_decay.ant
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem A1 - Negative exponential decay (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 1
//
// Original ODE:
//   dZ/dt = -Z
//
// Recast S-system:
//   Already in S-system form (single term, no recasting needed)
//   dX1/dt = 0 - X1  (or equivalently: dX1/dt = -X1)
//
// Solution: Z(t) = exp(-t)
// =============================================================================

model S1987_A1_exponential()
    // Already in S-system canonical form
    Z' = -Z
    
    // Initial condition
    Z = 1
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem A2 - Riccati equation (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 1
//
// Original ODE:
//   dZ/dt = -Z^(3/2)
//
// Recast S-system:
//   Already in S-system form (single power-law term)
//   dX1/dt = 0 - X1^(3/2)
//
// This is a special case of the Riccati equation.
// =============================================================================

model S1987_A2_riccati()
    // Already in S-system canonical form
    Z' = -Z^(3/2)
    
    // Initial condition
    Z = 1
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem A3 - Cosine growth (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 1
//
// Original ODE:
//   dZ/dt = Z * cos(t)
//
// Recast S-system (3 variables):
//   Define: X1 = Z, X2 = cos(t) + 2, X3 = sin(t) + 2
//   X(0) = (1, 3, 2)
//
//   dX1/dt = X1*X2 - 2*X1
//   dX2/dt = 2 - X3
//   dX3/dt = X2 - 2
//
// Note: Translation by 2 ensures X2, X3 remain positive
// =============================================================================

model S1987_A3_cos_growth()
    // Original ODE with trigonometric function
    Z' = Z * cos(time)
    
    // Initial condition
    Z = 1
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Related: test_models1/m02_logistic.ant
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem A4 - Logistic growth (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 1
//
// Original ODE:
//   dZ/dt = 0.25 * Z * (1 - Z/20)
//
// Expanded form:
//   dZ/dt = 0.25*Z - 0.0125*Z^2
//
// Recast S-system:
//   Already in S-system form (difference of two power-law terms)
//   dX1/dt = 0.25*X1 - 0.0125*X1^2
//
// This is the classic logistic growth law with:
//   - Growth rate r = 0.25
//   - Carrying capacity K = 20
// =============================================================================

model S1987_A4_logistic()
    // Already in S-system canonical form
    Z' = 0.25 * Z * (1 - Z/20)
    
    // Initial condition
    Z = 1
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem A5 - Spiral curve (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 4
//
// Original ODE:
//   dZ/dt = (Z - t) / (Z + t)
//
// Recast S-system (3 variables):
//   Define: X1 = Z + p, X2 = t + p, X3 = X1 + X2 - 2p
//   where p > 4 is arbitrary (paper uses p = 5)
//   X(0) = (9, 1, 4)  [since Z(0)=4, t(0)=0, p=5]
//
//   dX1/dt = X3*X2^(-1) - X2*X2^(-1)    [simplifies with care]
//   dX2/dt = 1
//   dX3/dt = 2*X3*X2^(-1) - 2*p*X2^(-1)
//
// Note: Translation parameter p=5 ensures positivity
// =============================================================================

model S1987_A5_spiral()
    // Original ODE describing a spiral curve
    Z' = (Z - time) / (Z + time)
    
    // Initial condition
    Z = 4
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Related: test_models1/m03_Lotka_Volterra.ant
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem B1 - Lotka-Volterra equations (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 1, Z2(0) = 3
//
// Original ODEs:
//   dZ1/dt = 2*(Z1 - Z1*Z2)
//   dZ2/dt = -(Z2 - Z1*Z2)
//
// Recast S-system:
//   Already in S-system form!
//   dX1/dt = 2*X1 - 2*X1*X2
//   dX2/dt = X1*X2 - X2
//
// These are the classic Lotka-Volterra predator-prey equations
// describing population dynamics of conflicting species.
// =============================================================================

model S1987_B1_lotka_volterra()
    // Already in S-system canonical form
    Z1' = 2*(Z1 - Z1*Z2)
    Z2' = -(Z2 - Z1*Z2)
    
    // Initial conditions
    Z1 = 1
    Z2 = 3
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem B2 - Linear chemical reaction chain (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 2, Z2(0) = 0, Z3(0) = 1
//
// Original ODEs:
//   dZ1/dt = -Z1 + Z2
//   dZ2/dt = Z1 - 2*Z2 + Z3
//   dZ3/dt = Z2 - Z3
//
// Recast S-system (4 variables):
//   Define: X1 = Z1 + p, X2 = Z2 + p, X3 = Z3 + p, X4 = X1 + X3
//   where p = 2 (arbitrary positive constant)
//   X(0) = (4, 2, 3, 7)
//
//   dX1/dt = X2 - X1
//   dX2/dt = X4 - 2*X2
//   dX3/dt = X2 - X3
//   dX4/dt = 2*X2 - X4
//
// This represents a linear system of chemical reactions.
// =============================================================================

model S1987_B2_linear_chain()
    // Linear chemical chain (requires translation for S-system form)
    Z1' = -Z1 + Z2
    Z2' = Z1 - 2*Z2 + Z3
    Z3' = Z2 - Z3
    
    // Initial conditions
    Z1 = 2
    Z2 = 0
    Z3 = 1
end
// @SIM T_START=0 T_END=6 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem B3 - Nonlinear chemical reaction chain (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 1, Z2(0) = 0, Z3(0) = 0
//
// Original ODEs:
//   dZ1/dt = -Z1
//   dZ2/dt = Z1 - Z2^2
//   dZ3/dt = Z2^2
//
// Recast S-system (4 variables):
//   Since Z2(0) = Z3(0) = 0, translation is needed.
//   Define: X1 = Z1 + p, X2 = Z3 + q, X3 = X1 + p, X4 = Z2 + 4*p*X3
//   where p = 0.25, q = 1
//   X(0) = (p, q, 2p, 1+4p^2) = (0.25, 1, 0.5, 1.25)
//
//   dX1/dt = X3 - X1^2
//   dX2/dt = X1^2 - X3
//   dX3/dt = X3 - X1^2
//   dX4/dt = X1 - X3^2
//
// This represents a nonlinear system of chemical reactions.
// =============================================================================

model S1987_B3_nonlinear_chain()
    // Nonlinear chemical chain
    Z1' = -Z1
    Z2' = Z1 - Z2^2
    Z3' = Z2^2
    
    // Initial conditions
    Z1 = 1
    Z2 = 0
    Z3 = 0
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem B4 - Torus integral surface (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 3, Z2(0) = 0, Z3(0) = 0
//
// Original ODEs:
//   dZ1/dt = -Z1 - Z1*Z3*(Z1^2 + Z2^2)^(-1/2)
//   dZ2/dt = Z1 - Z2*Z3*(Z1^2 + Z2^2)^(-1/2)
//   dZ3/dt = Z1*(Z1^2 + Z2^2)^(-1/2)
//
// Recast S-system (8 variables):
//   Define translations and products to handle the radical term.
//   X1=Z1+p, X2=5+q, X3=Z3+r, X4=(Z1^2+Z2^2)^(-1/2)
//   Then replace X1 by X1*X2, X3 by X3*X4*X5, etc.
//
//   dX1/dt = X2*X3*X4*X5 - p*X5
//   dX2/dt = X1*X4^(-1) - r*X4^(-1)
//   dX3/dt = p*X3*X4*X5^(-1)*X6^(-1) - X3*X4*X5
//   dX4/dt = r*X3*X4 - p*r*X3*X5^(-1)*X6^(-1)
//   dX5/dt = q*X5^(-1)*X6^(-1) - X4^(-1)*X5^(-1)*X6*X7*X8
//   dX6/dt = q*X3*X4*X5^(-1)*X6^(-1) - X3*X4*X5
//   dX7/dt = r*X3*X4 - q*r*X3*X5^(-1)*X6^(-1)
//   dX8/dt = X3*X4*X5*X6*X5^(-1)*X6^(-1) - p*X5^(-1)*X6^(-1)
//
// This represents the integral surface of a torus.
// =============================================================================

model S1987_B4_torus()
    // Torus integral surface
    Z1' = -Z1 - Z1*Z3*(Z1^2 + Z2^2)^(-1/2)
    Z2' = Z1 - Z2*Z3*(Z1^2 + Z2^2)^(-1/2)
    Z3' = Z1*(Z1^2 + Z2^2)^(-1/2)
    
    // Initial conditions
    // Note: Z2 slightly off zero to avoid (Z1^2+Z2^2)^(-1/2) singularity
    Z1 = 3
    Z2 = 0.1
    Z3 = 0
end
// @SIM T_START=0 T_END=3.07 N_STEPS=307 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem B5 - Euler's rigid body equations (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 0, Z2(0) = 1, Z3(0) = 1
//
// Original ODEs (Euler's equations without external forces):
//   dZ1/dt = Z2*Z3
//   dZ2/dt = -Z1*Z3
//   dZ3/dt = -0.51*Z1*Z2
//
// Recast S-system (4 variables):
//   Since Z1 and Z2 become negative, translation is needed.
//   Define: X1 = Z1 + p, X2 = Z2 + q, X3 = Z3, X4 auxiliary
//   where p = q = 2
//   X(0) = (p, 1+q, 1, 1) = (2, 3, 1, 1)
//
//   dX1/dt = X2*X3*X4 - q*X3*X4
//   dX2/dt = p*X3*X4 - X1*X3*X4
//   dX3/dt = 0.51*p*X2*X3^(-1) - 0.51*p*q*X3^(-1)
//   dX4/dt = 0.51*q*X1*X3^(-1) - 0.51*X1*X2*X3^(-1)
//
// These are Euler's equations of motion for a rigid body.
// =============================================================================

model S1987_B5_rigid_body()
    // Euler's equations for rigid body motion
    Z1' = Z2*Z3
    Z2' = -Z1*Z3
    Z3' = -0.51*Z1*Z2
    
    // Initial conditions
    Z1 = 0
    Z2 = 1
    Z3 = 1
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Appendix B - Half system to Binary system transformation
//          Equations B4-B6
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = Z10, Z2(0) = Z20, Z3(0) = Z30
//
// Original Half system (Equation B4):
//   dZ1/dt = 3*Z1^(-1/3)*Z2^(1/2)
//   dZ2/dt = -Z1^2*Z3
//   dZ3/dt = 0.5*Z1*Z3
//
// Binary systems have exponents that are all 0 or 1.
// This is achieved by introducing new variables for each power-law factor.
//
// Recast Binary system (6 variables, Equation B6):
//   Define: V11 = Z1^(-1/3), V12 = Z2^(1/2), V21 = Z1^2, V33 = Z3
//   Then eliminate Z variables and add U1 = V11^2 to remove squares
//
//   dX1/dt = -X1*X2
//   dX2/dt = -0.5*X2*X3
//   dX3/dt = 12*X1*X2*X4
//   dX4/dt = 3*X1*X2*X4
//   dX5/dt = 0.5*X4*X6
//   dX6/dt = -2*X1*X2*X4
//
// where X1=V11, X2=V12, X3=V21, X4=V33, X5=Z3=V33, X6=U1
// X(0) = (Z10^(-1/3), Z20^(1/2), Z10^2, Z30, Z30, Z10^(-2/3))
//
// NOTE: Parameter values added for simulation purposes.
// =============================================================================

model S1987_B_binary()
    // Original Half system
    Z1' = 3*Z1^(-1/3)*Z2^(1/2)
    Z2' = -Z1^2*Z3
    Z3' = 0.5*Z1*Z3
    
    // Initial conditions (added for simulation)
    Z1 = 1.0
    Z2 = 1.0
    Z3 = 1.0
end
// @SIM T_START=0 T_END=0.387 N_STEPS=387 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem C1 - Radioactive decay chain (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 1, Z2(0) = ... = Z10(0) = 0
//
// Original ODEs:
//   dZ1/dt = -Z1
//   dZi/dt = Z(i-1) - Zi      for i = 2,...,9
//   dZ10/dt = Z9
//
// Recast S-system (10 variables):
//   Translation: Xi = Zi + p (p > 0 arbitrary)
//   X(0) = (1+p, p, p, ..., p)
//
//   dX1/dt = p - X1
//   dXi/dt = X(i-1) - Xi      for i = 2,...,9
//   dX10/dt = X9 - p
//
// This represents a radioactive decay chain.
// =============================================================================

model S1987_C1_decay_chain()
    // Radioactive decay chain (10 species)
    Z1' = -Z1
    Z2' = Z1 - Z2
    Z3' = Z2 - Z3
    Z4' = Z3 - Z4
    Z5' = Z4 - Z5
    Z6' = Z5 - Z6
    Z7' = Z6 - Z7
    Z8' = Z7 - Z8
    Z9' = Z8 - Z9
    Z10' = Z9
    
    // Initial conditions
    Z1 = 1; Z2 = 0; Z3 = 0; Z4 = 0; Z5 = 0
    Z6 = 0; Z7 = 0; Z8 = 0; Z9 = 0; Z10 = 0
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem C2 - Radioactive decay chain variant (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 1, Z2(0) = ... = Z10(0) = 0
//
// Original ODEs:
//   dZ1/dt = -Z1
//   dZi/dt = Z(i-1) - 2*Zi      for i = 2,...,9
//   dZ10/dt = Z9
//
// Recast S-system (10 variables):
//   Translation: pi = p1/i for i = 2,...,10, where p1 > 0
//   X(0) = (1+p1, p1/2, p1/3, ..., p1/10)
//
//   dX1/dt = p1 - X1
//   dXi/dt = (i-1)*X(i-1) - i*Xi      for i = 2,...,9
//   dX10/dt = 9*X9 - p1
//
// This is a variant decay chain with different decay rates.
// =============================================================================

model S1987_C2_decay_chain2()
    // Radioactive decay chain variant (10 species)
    Z1' = -Z1
    Z2' = Z1 - 2*Z2
    Z3' = Z2 - 2*Z3
    Z4' = Z3 - 2*Z4
    Z5' = Z4 - 2*Z5
    Z6' = Z5 - 2*Z6
    Z7' = Z6 - 2*Z7
    Z8' = Z7 - 2*Z8
    Z9' = Z8 - 2*Z9
    Z10' = Z9
    
    // Initial conditions
    Z1 = 1; Z2 = 0; Z3 = 0; Z4 = 0; Z5 = 0
    Z6 = 0; Z7 = 0; Z8 = 0; Z9 = 0; Z10 = 0
end
// @SIM T_START=0 T_END=6 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem C3 - Parabolic PDE derived system (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 1, Z2(0) = ... = Z10(0) = 0
//
// Original ODEs (derived from parabolic PDE discretization):
//   dZ1/dt = -2*Z1 + Z2
//   dZi/dt = Z(i-1) - 2*Zi + Z(i+1)    for i = 2,...,9
//   dZ10/dt = Z9 - 2*Z10
//
// Recast S-system (18 variables):
//   Translation: Xi = Zi + i*p1 (p1 > 0)
//   Then replace Xi (i=2,...,9) by products of two variables.
//   X(0) = (2, 2, 1, 3, 1, 4, 1, 5, 1, 6, 1, 7, 1, 8, 1, 9, 1, 10, 1)
//
//   dX1/dt = X2*X3 - 2*X1
//   dX2/dt = X4*X5^(-1) - X2
//   dXi/dt = (various products, see paper for full details)
//   dX9/dt = 11*p1*X8^(-1) - X9
//
// This is derived from a parabolic partial differential equation.
// =============================================================================

model S1987_C3_parabolic_pde()
    // Parabolic PDE discretization (10 species)
    Z1' = -2*Z1 + Z2
    Z2' = Z1 - 2*Z2 + Z3
    Z3' = Z2 - 2*Z3 + Z4
    Z4' = Z3 - 2*Z4 + Z5
    Z5' = Z4 - 2*Z5 + Z6
    Z6' = Z5 - 2*Z6 + Z7
    Z7' = Z6 - 2*Z7 + Z8
    Z8' = Z7 - 2*Z8 + Z9
    Z9' = Z8 - 2*Z9 + Z10
    Z10' = Z9 - 2*Z10
    
    // Initial conditions
    Z1 = 1; Z2 = 0; Z3 = 0; Z4 = 0; Z5 = 0
    Z6 = 0; Z7 = 0; Z8 = 0; Z9 = 0; Z10 = 0
end
// @SIM T_START=0 T_END=6 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Appendix C - Implicit differential equation transformation
//          Equations C1-C5
// =============================================================================
// Time horizon: t ∈ [0, 20]
//
// Original implicit differential equations (Equation C1):
//   (ln Z1')^2 + Z1'*exp(Z2') - t*Z1 = 0
//   Z1'^2 + Z1'*Z2' + Z2'^2 - Z2 - t = 0
//
// This is an example of how implicit differential equations can be
// transformed into explicit form and then recast as S-systems.
//
// Step 1: Define X1 = Z1' and X2 = Z2' (derivatives become new variables)
// Step 2: Implicit algebraic equations (C2)
// Step 3: Differentiate symbolically to get explicit ODEs (C3-C4)
// Step 4: The resulting explicit system (Equation C5):
//
//   dX1/dt = [1 + X2 - (X1 + 2*X2)*(X3 + X1*X4)*exp(-X1)] / 
//            [2*X1 + X2 - (X1 + 2*X2)*(2*X1^(-1)*ln(X1) + X4*exp(X1))*exp(-X1)]
//
//   dX2/dt = [(2*X1 + X2)*(X3 + X1*X4) - (1 + X2)*(2*X1^(-1)*ln(X1) + X4*exp(X1))] /
//            [(2*X1 + X2)*exp(X1) - (X1 + 2*X2)*(2*X1^(-1)*ln(X1) + X4*exp(X1))]
//
//   dX3/dt = X1
//   dX4/dt = 1
//
// where X3 = Z1, X4 = Z2, X5 = t
//
// NOTE: This is a complex implicit system. The explicit form requires
// careful handling and initial conditions must satisfy the implicit equations.
// Parameter values added for simulation purposes.
// =============================================================================

model S1987_C_implicit_de()
    // For simulation, we use the explicit first-order form.
    // The original system is implicit in the derivatives.
    // Here we define the system after transformation to explicit form.
    
    // State variables: X1 = dZ1/dt, X2 = dZ2/dt, X3 = Z1, X4 = Z2
    // The explicit ODEs are complex; simplified representation below
    
    // Original form for reference (implicit in Z1', Z2'):
    // (ln(Z1'))^2 + Z1'*exp(Z2') - t*Z1 = 0
    // Z1'^2 + Z1'*Z2' + Z2'^2 - Z2 - t = 0
    
    // Simplified explicit representation (for Z1, Z2 directly)
    // Note: This requires numerical solution of the implicit algebraic system
    // at each time step, which is beyond standard ODE solvers.
    
    // For demonstration, we show the structure:
    Z1' = V1  // where V1 satisfies implicit constraint
    Z2' = V2  // where V2 satisfies implicit constraint
    
    // Auxiliary algebraic constraints (would be implicit in original)
    // (ln(V1))^2 + V1*exp(V2) - time*Z1 = 0
    // V1^2 + V1*V2 + V2^2 - Z2 - time = 0
    
    // NOTE: Initial conditions must satisfy the implicit constraints.
    // These values are approximate starting points.
    Z1 = 1.0
    Z2 = 1.0
    V1 = 1.0  // auxiliary variable
    V2 = 0.5  // auxiliary variable
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem D1 - Orbit equation, eccentricity e=0.1 (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Eccentricity: e = 0.1
// Initial conditions: Z1(0) = 1-e = 0.9
//                     Z2(0) = 0
//                     Z3(0) = 0
//                     Z4(0) = sqrt((1+e)/(1-e)) = sqrt(1.1/0.9) ≈ 1.1055
//
// Original ODEs (2-body orbit problem):
//   dZ1/dt = Z3
//   dZ2/dt = Z4
//   dZ3/dt = -Z1*(Z1^2 + Z2^2)^(-3/2)
//   dZ4/dt = -Z2*(Z1^2 + Z2^2)^(-3/2)
//
// Recast S-system (8 variables):
//   Define: X1=Z1+3, X2=Z2+3, X3=Z3+5, X4=Z4+5, X5=Z1^2+Z2^2
//   Then replace X5 by product X5*X6*X7*X8
//
//   dX1/dt = X3 - 5
//   dX2/dt = X4 - 5
//   dX3/dt = 3*(X5*X6*X7*X8)^(-3/2) - X1*(X5*X6*X7*X8)^(-3/2)
//   dX4/dt = 3*(X5*X6*X7*X8)^(-3/2) - X2*(X5*X6*X7*X8)^(-3/2)
//   (additional equations for X5-X8, see paper)
// =============================================================================

model S1987_D1_orbit_e0p1()
    // Orbital mechanics with eccentricity e = 0.1
    e = 0.1
    
    Z1' = Z3
    Z2' = Z4
    Z3' = -Z1*(Z1^2 + Z2^2)^(-3/2)
    Z4' = -Z2*(Z1^2 + Z2^2)^(-3/2)
    
    // Initial conditions
    Z1 = 1 - e           // = 0.9
    Z2 = 0
    Z3 = 0
    Z4 = ((1+e)/(1-e))^(1/2)  // ≈ 1.1055
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem D2 - Orbit equation, eccentricity e=0.3 (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Eccentricity: e = 0.3
// Initial conditions: Z1(0) = 1-e = 0.7
//                     Z2(0) = 0
//                     Z3(0) = 0
//                     Z4(0) = sqrt((1+e)/(1-e)) = sqrt(1.3/0.7) ≈ 1.3628
//
// Original ODEs (2-body orbit problem):
//   dZ1/dt = Z3
//   dZ2/dt = Z4
//   dZ3/dt = -Z1*(Z1^2 + Z2^2)^(-3/2)
//   dZ4/dt = -Z2*(Z1^2 + Z2^2)^(-3/2)
//
// Recast S-system: Same structure as D1, see paper for details.
// =============================================================================

model S1987_D2_orbit_e0p3()
    // Orbital mechanics with eccentricity e = 0.3
    e = 0.3
    
    Z1' = Z3
    Z2' = Z4
    Z3' = -Z1*(Z1^2 + Z2^2)^(-3/2)
    Z4' = -Z2*(Z1^2 + Z2^2)^(-3/2)
    
    // Initial conditions
    Z1 = 1 - e           // = 0.7
    Z2 = 0
    Z3 = 0
    Z4 = ((1+e)/(1-e))^(1/2)  // ≈ 1.3628
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem D3 - Orbit equation, eccentricity e=0.5 (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Eccentricity: e = 0.5
// Initial conditions: Z1(0) = 1-e = 0.5
//                     Z2(0) = 0
//                     Z3(0) = 0
//                     Z4(0) = sqrt((1+e)/(1-e)) = sqrt(1.5/0.5) = sqrt(3) ≈ 1.7321
//
// Original ODEs (2-body orbit problem):
//   dZ1/dt = Z3
//   dZ2/dt = Z4
//   dZ3/dt = -Z1*(Z1^2 + Z2^2)^(-3/2)
//   dZ4/dt = -Z2*(Z1^2 + Z2^2)^(-3/2)
//
// Recast S-system: Same structure as D1, see paper for details.
// =============================================================================

model S1987_D3_orbit_e0p5()
    // Orbital mechanics with eccentricity e = 0.5
    e = 0.5
    
    Z1' = Z3
    Z2' = Z4
    Z3' = -Z1*(Z1^2 + Z2^2)^(-3/2)
    Z4' = -Z2*(Z1^2 + Z2^2)^(-3/2)
    
    // Initial conditions
    Z1 = 1 - e           // = 0.5
    Z2 = 0
    Z3 = 0
    Z4 = ((1+e)/(1-e))^(1/2)  // = sqrt(3) ≈ 1.7321
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem D4 - Orbit equation, eccentricity e=0.7 (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Eccentricity: e = 0.7
// Initial conditions: Z1(0) = 1-e = 0.3
//                     Z2(0) = 0
//                     Z3(0) = 0
//                     Z4(0) = sqrt((1+e)/(1-e)) = sqrt(1.7/0.3) ≈ 2.3805
//
// Original ODEs (2-body orbit problem):
//   dZ1/dt = Z3
//   dZ2/dt = Z4
//   dZ3/dt = -Z1*(Z1^2 + Z2^2)^(-3/2)
//   dZ4/dt = -Z2*(Z1^2 + Z2^2)^(-3/2)
//
// Recast S-system: Same structure as D1, see paper for details.
// =============================================================================

model S1987_D4_orbit_e0p7()
    // Orbital mechanics with eccentricity e = 0.7
    e = 0.7
    
    Z1' = Z3
    Z2' = Z4
    Z3' = -Z1*(Z1^2 + Z2^2)^(-3/2)
    Z4' = -Z2*(Z1^2 + Z2^2)^(-3/2)
    
    // Initial conditions
    Z1 = 1 - e           // = 0.3
    Z2 = 0
    Z3 = 0
    Z4 = ((1+e)/(1-e))^(1/2)  // ≈ 2.3805
end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem D5 - Orbit equation, eccentricity e=0.9 (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Eccentricity: e = 0.9
// Initial conditions: Z1(0) = 1-e = 0.1
//                     Z2(0) = 0
//                     Z3(0) = 0
//                     Z4(0) = sqrt((1+e)/(1-e)) = sqrt(1.9/0.1) = sqrt(19) ≈ 4.3589
//
// Original ODEs (2-body orbit problem):
//   dZ1/dt = Z3
//   dZ2/dt = Z4
//   dZ3/dt = -Z1*(Z1^2 + Z2^2)^(-3/2)
//   dZ4/dt = -Z2*(Z1^2 + Z2^2)^(-3/2)
//
// Recast S-system: Same structure as D1, see paper for details.
// Note: High eccentricity makes this problem numerically challenging.
// =============================================================================

model S1987_D5_orbit_e0p9()
    // Orbital mechanics with eccentricity e = 0.9 (highly elliptical)
    e = 0.9
    
    Z1' = Z3
    Z2' = Z4
    Z3' = -Z1*(Z1^2 + Z2^2)^(-3/2)
    Z4' = -Z2*(Z1^2 + Z2^2)^(-3/2)
    
    // Initial conditions
    // Note: Z2 slightly off zero to avoid (Z1^2+Z2^2)^(-3/2) singularity during orbit
    Z1 = 1 - e           // = 0.1
    Z2 = 0.001
    Z3 = 0
    Z4 = ((1+e)/(1-e))^(1/2)  // = sqrt(19) ≈ 4.3589
end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem E1 - Bessel equation derived (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 0.671396707141803
//                     Z2(0) = 0.09540051444747446
//
// Original 2nd-order ODE (Bessel's equation of order 1/2, shifted):
//   Z1'' = 0.25*(t+1)^(-2)*Z1 - Z2*(t+1)^(-1) - Z1
//
// Converted to first-order system:
//   dZ1/dt = Z2
//   dZ2/dt = 0.25*(t+1)^(-2)*Z1 - Z2*(t+1)^(-1) - Z1
//
// Recast S-system (5 variables):
//   Define: X1 = Z1 + p, X2 = Z2 + q (p, q > 0)
//   Then replace X4 by product of four new variables
//   X(0) = (Z1(0)+p, Z2(0)+q, 1, 1, 1)
//
//   dX1/dt = X2*X3*X4 - q
//   dX2/dt = q*X1^(-1)*X4^(-1)*X5^(-1) - X3*X4^(-1)
//   dX3/dt = p*X1^(-1)*X4^(-1) - X3*X4^(-1)*X5^(-1)
//   dX4/dt = 0.25*X1*X4^(-1)*X5^(-2) - 0.25*p*X4^(-1)*X5^(-2)
//   dX5/dt = 1
// =============================================================================

model S1987_E1_bessel()
    // Bessel equation derived (2nd order converted to 1st order system)
    Z1' = Z2
    Z2' = 0.25*(time+1)^(-2)*Z1 - Z2*(time+1)^(-1) - Z1
    
    // Initial conditions (from paper)
    Z1 = 0.671396707141803
    Z2 = 0.09540051444747446
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Related: test_models1/m10_van_der_Pol.ant
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem E2 - Van der Pol oscillator (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 2, Z2(0) = 0
//
// Original 2nd-order ODE (Van der Pol equation):
//   Z1'' = (1 - Z1^2)*Z1' - Z1
//
// Converted to first-order system:
//   dZ1/dt = Z2
//   dZ2/dt = (1 - Z1^2)*Z2 - Z1
//
// Recast S-system (5 variables):
//   Define: X1 = Z1 + p, X2 = Z2 + q (p, q > 0)
//   Then replace X2 by product of four new variables
//
//   dX1/dt = X2*X3*X4*X5 - q
//   dX2/dt = (p+q+p-q)*X2^(-1)*X3^(-1)*X4^(-1) - p^2*X2
//   dX3/dt = 2*p*X1*X3 - 2*p*q*X3*X2^(-1)*X4^(-1)*X5^(-1)
//   dX4/dt = q*X1^2*X2^(-1)*X4^(-1)*X5^(-1) - X1^2*X3
//   dX5/dt = X5 - X3*X2^(-1)*X4^(-1)*X5^(-1)
// =============================================================================

model S1987_E2_van_der_pol()
    // Van der Pol oscillator (2nd order converted to 1st order system)
    Z1' = Z2
    Z2' = (1 - Z1^2)*Z2 - Z1
    
    // Initial conditions
    Z1 = 2
    Z2 = 0
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem E3 - Duffing equation (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 0, Z2(0) = 0
//
// Original 2nd-order ODE (Duffing equation):
//   Z1'' = (1/6)*Z1^3 - Z1 + 2*sin(2.78525*t)
//
// Converted to first-order system:
//   dZ1/dt = Z2
//   dZ2/dt = (1/6)*Z1^3 - Z1 + 2*sin(2.78525*t)
//
// Recast S-system (6 variables):
//   Define: X1 = Z1 + p, X2 = Z2 + q, X3 = sin(2.78525*t)
//   The sine definition requires corresponding cosine X4 = cos(2.78525*t)
//   Then replace X2 by product of three variables
//   X(0) = (p, p, r+1, q, 1, 1) where p = q = r = 4
//
//   dX1/dt = X2*X3*X4 - q
//   dX2/dt = 5.5101*r - 5.5707*X3
//   dX3/dt = 1.392675*X4 - 1.392675*p
//   dX4/dt = X2*X4^(-1)*X5^(-1) - X3*X4^(-1)*X5^(-1)
//   dX5/dt = (p^2/2)*X3*X4^(-1)*X5^(-1) - (p^3/6)*X4^(-1)*X5^(-1)
//   dX6/dt = (1/6)*X1^3*X4^(-1)*X5^(-1) - (p/2)*X1^2*X4^(-1)*X5^(-1)
// =============================================================================

model S1987_E3_duffing()
    // Duffing equation (2nd order converted to 1st order system)
    Z1' = Z2
    Z2' = (1/6)*Z1^3 - Z1 + 2*sin(2.78525*time)
    
    // Initial conditions
    // Note: Small non-zero ICs to avoid singularities in recast equations
    Z1 = 0.01
    Z2 = 0.01
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem E4 - Falling body with air resistance (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 30, Z2(0) = 0
//
// Original 2nd-order ODE:
//   Z1'' = 0.032 - 0.4*Z1'^2
//   (position Z1, velocity Z2 = Z1')
//
// Converted to first-order system:
//   dZ1/dt = Z2
//   dZ2/dt = 0.032 - 0.4*Z2^2
//
// Recast S-system (2 variables):
//   Define: X1 = Z1, X2 = Z2 + p
//   For special choice p = sqrt(0.08) = 0.08^(1/2), the S-system simplifies:
//
//   dX1/dt = X2 - p
//   dX2/dt = 0.8*p*X2 - 0.4*X2^2
//
// This describes a falling body with quadratic air resistance.
// Terminal velocity: v_terminal = sqrt(0.032/0.4) = sqrt(0.08) ≈ 0.283
// =============================================================================

model S1987_E4_falling_body()
    // Falling body with air resistance (2nd order converted to 1st order system)
    Z1' = Z2
    Z2' = 0.032 - 0.4*Z2^2
    
    // Initial conditions
    Z1 = 30  // initial height
    Z2 = 0   // initial velocity (dropped from rest)
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem E5 - Implicit 2nd-order equation (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 0, Z2(0) = 0
//
// Original 2nd-order ODE:
//   Z1'' = (1 + Z1'^2)^(1/2) * (25 - t)^(-1)
//
// Converted to first-order system:
//   dZ1/dt = Z2
//   dZ2/dt = (1 + Z2^2)^(1/2) * (25 - t)^(-1)
//
// Recast S-system (4 variables):
//   Define: X1 = Z1 + p, X2 = Z2 + p, X3 = 1 + Z2^2, X4 = 25 - t
//   X(0) = (p, p, 1, 25) where p > 0 arbitrary
//
//   dX1/dt = X2 - p
//   dX2/dt = X3^(1/2) * X4^(-1)
//   dX3/dt = 2*X2*X3^(1/2)*X4^(-1) - 2*p*X3^(1/2)*X4^(-1)
//   dX4/dt = -1
// =============================================================================

model S1987_E5_implicit()
    // Implicit 2nd-order equation (converted to 1st order system)
    Z1' = Z2
    Z2' = (1 + Z2^2)^(1/2) * (25 - time)^(-1)
    
    // Initial conditions
    // Note: Small non-zero ICs recommended for numerical stability
    Z1 = 0.01
    Z2 = 0.01
end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Power System Stability - 2-Machine with Transfer Conductances
// Source: Anghel, Milano & Papachristodoulou, IEEE Trans. Circuits Syst. I (2013)
// Section V-B: Model B
//
// Original equations (swing equations with trigonometric nonlinearities and losses):
//   dθ₁/dt = ω₁
//   dω₁/dt = -2.6 sin(θ₁) + 0.2 cos(θ₁) - sin(θ₁-θ₂) - 0.1 cos(θ₁-θ₂) + 1.0
//   dθ₂/dt = ω₂  
//   dω₂/dt = - sin(θ₂-θ₁) + 0.1 cos(θ₂-θ₁) - 1.8 sin(θ₂) + 0.1 cos(θ₂) + 0.5
//
// where θ₁, θ₂ are relative angles w.r.t. infinite bus
// The cos() terms represent transfer conductances (system losses)
//
// Parameters: H₁=1, H₂=1, D=0 (no damping)
// Stable equilibrium: θ₁ˢ = 0.2, θ₂ˢ = 0.1
//
// ==============================================================================
// RECASTING TO POLYNOMIAL DAE (Section V-B):
// ==============================================================================
// To apply SOS/SDP techniques, trigonometric terms are recast to polynomial form.
// 
// Change of variables (shifted coordinates):
//   δ₁ = θ₁ - θ₁ˢ,  δ₂ = θ₂ - θ₂ˢ  (shift equilibrium to origin)
//
// Recasting variables:
//   c₁ = cos(δ₁),  s₁ = sin(δ₁)
//   c₂ = cos(δ₂),  s₂ = sin(δ₂)
//
// Algebraic constraints (required for exact equivalence):
//   c₁² + s₁² = 1
//   c₂² + s₂² = 1
//
// The dynamics become polynomial in (ω₁, ω₂, c₁, s₁, c₂, s₂) on the manifold.
//
// Note: No analytical energy function exists for this system (transfer 
// conductances violate the conditions). However, Lyapunov functions can 
// still be constructed algorithmically using the polynomial recast form.
// ==============================================================================

model A2013_power_system_2machine()
  // Variables (original trigonometric form, shifted coordinates)
  compartment cell = 1;var species delta1 in cell; var species omega1 in cell; var species delta2 in cell; var species omega2 in cell

  // Parameters (from paper)
  // Stable equilibrium shifted to origin
  theta1s := 0.2; theta2s := 0.1
  
  // Original trigonometric equations (in shifted coordinates)
  
  // dδ₁/dt = ω₁
  delta1' = omega1
  
  // dω₁/dt = -2.6 sin(θ₁) + 0.2 cos(θ₁) - sin(θ₁-θ₂) - 0.1 cos(θ₁-θ₂) + 1.0
  omega1' = -2.6 * sin(delta1 + theta1s) + 0.2 * cos(delta1 + theta1s) - sin(delta1 + theta1s - delta2 - theta2s) - 0.1 * cos(delta1 + theta1s - delta2 - theta2s) + 1.0
  
  // dδ₂/dt = ω₂
  delta2' = omega2
  
  // dω₂/dt = - sin(θ₂-θ₁) + 0.1 cos(θ₂-θ₁) - 1.8 sin(θ₂) + 0.1 cos(θ₂) + 0.5
  omega2' = -sin(delta2 + theta2s - delta1 - theta1s) + 0.1 * cos(delta2 + theta2s - delta1 - theta1s) - 1.8 * sin(delta2 + theta2s) + 0.1 * cos(delta2 + theta2s) + 0.5
  
  // Initial conditions (at shifted equilibrium = origin)
  delta1 = 0.0; omega1 = 0.0; delta2 = 0.0; omega2 = 0.0; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Power System Stability - 3-Machine Lossless Model
// Source: Anghel, Milano & Papachristodoulou, IEEE Trans. Circuits Syst. I (2013)
// Section V-A: Model A
//
// Original equations (swing equations with trigonometric nonlinearities):
//   dθ₁/dt = ω₁
//   dω₁/dt = -2.8 sin(θ₁) + 1.2 sin(θ₂-θ₁) + 0.5
//   dθ₂/dt = ω₂  
//   dω₂/dt = 1.2 sin(θ₁-θ₂) - 2.4 sin(θ₂) + 0.6
//
// where θ₁, θ₂ are relative angles w.r.t. reference machine 3
//
// Parameters: H₁=1, H₂=1, D=0 (no damping)
// Stable equilibrium: θ₁ˢ = 0.1, θ₂ˢ = 0.2
//
// ==============================================================================
// RECASTING TO POLYNOMIAL DAE (Section V-A):
// ==============================================================================
// To apply SOS/SDP techniques, trigonometric terms are recast to polynomial form.
// 
// Change of variables (shifted coordinates):
//   δ₁ = θ₁ - θ₁ˢ,  δ₂ = θ₂ - θ₂ˢ  (shift equilibrium to origin)
//
// Recasting variables:
//   c₁ = cos(δ₁),  s₁ = sin(δ₁)
//   c₂ = cos(δ₂),  s₂ = sin(δ₂)
//
// Algebraic constraints (required for exact equivalence):
//   c₁² + s₁² = 1
//   c₂² + s₂² = 1
//
// This gives polynomial dynamics + algebraic constraints (DAE system).
//
// Note: The recasting increases state dimension from 4 to 6, but adds 2 
// algebraic constraints, keeping the effective dimension at 4.
// ==============================================================================

model A2013_power_system_3machine()
  // Variables (original trigonometric form, shifted coordinates)
  compartment cell = 1;var species delta1 in cell; var species omega1 in cell; var species delta2 in cell; var species omega2 in cell

  // Parameters (from paper)
  // Stable equilibrium shifted to origin
  theta1s := 0.1; theta2s := 0.2
  
  // Original trigonometric equations (in shifted coordinates)
  // Using trig identities: sin(δ + θˢ) = sin(δ)cos(θˢ) + cos(δ)sin(θˢ)
  
  // dδ₁/dt = ω₁
  delta1' = omega1
  
  // dω₁/dt = -2.8 sin(θ₁) + 1.2 sin(θ₂-θ₁) + 0.5
  // In shifted coords with θ₁ = δ₁ + θ₁ˢ, θ₂ = δ₂ + θ₂ˢ
  omega1' = -2.8 * sin(delta1 + theta1s) + 1.2 * sin(delta2 + theta2s - delta1 - theta1s) + 0.5
  
  // dδ₂/dt = ω₂
  delta2' = omega2
  
  // dω₂/dt = 1.2 sin(θ₁-θ₂) - 2.4 sin(θ₂) + 0.6
  omega2' = 1.2 * sin(delta1 + theta1s - delta2 - theta2s) - 2.4 * sin(delta2 + theta2s) + 0.6
  
  // Initial conditions (at shifted equilibrium = origin)
  delta1 = 0.0; omega1 = 0.0; delta2 = 0.0; omega2 = 0.0; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Gompertz Growth Model Recasting
// Source: Anguelov et al., "On the chemical meaning of some growth models
//         possessing Gompertzian-type property"
//         Math. Methods Appl. Sci. 41:8365-8376 (2018)
//
// This paper explicitly cites Savageau & Voit (1987) as reference [7].
// From Remark 2 (p. 8369): "The procedure of passing from the dynamical model
// (V) to model (DV) is called 'recasting' in the work of Savageau."
//
// Original Gompertz growth model (1D) - Equation (G):
//   dy/dt = k·y·(c - ln(y))
//
// ==============================================================================
// RECASTING TO 2D SYSTEM (Eq. SG, pp. 8370-8371):
// ==============================================================================
// Introduce auxiliary variable:
//   s = c - ln(y)  (interpreted as "resource")
//
// Derive dynamics using chain rule:
//   ds/dt = -dy/dt / y = -k·(c - ln(y)) = -k·s
//   
// But substituting s back: dy/dt = k·s·y
//
// The recast 2D system (Eq. SG):
//   ds/dt = -k·s
//   dy/dt = k·s·y
//
// Conservation law (Eq. gg):
//   s + ln(y) = c = const
//
// From Remark 4: "System (SG) is considered as 'recasted' variant of equation
// (G) in the terminology of [Savageau 1987]"
//
// Note from Remark 6: "System (SG) shows that the Gompertz model cannot be
// realized as an MAK network" - the first equation says S doesn't interact
// with X, but the second says it does. This is why recasting is useful: it
// reveals structural properties.
// ==============================================================================

model A2017_gompertz_recasting()
  // Variables
  compartment cell = 1;var species y in cell

  // Parameters
  k := 1.0; c := 0.0
               // c=0 means y → 1 as t → ∞ (normalized)
  
  // Original Gompertz growth model
  // dy/dt = k·y·(c - ln(y))
  // For c=0: dy/dt = -k·y·ln(y)  (Eq. G0)
  y' = k * y * (c - ln(y))
  
  // Initial condition
  y = 0.01; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Planetary Motion (Two-Body Gravitational Problem)
// Source: Daniels & Nemenman, Nature Communications 6:8133 (2015)
// Supplementary Note 2, Equations 5-6
//
// Original 2nd-order ODE (rescaled units):
//   d²r/dt² = r₀²/r³ - 1/r²
//
// where:
//   r = radial distance from sun
//   r₀ = initial distance (determines angular momentum h = r₀)
//   Units: distance in GM/v₀², time in GM/v₀³
//
// The orbit type depends on r₀:
//   r₀ = 1: circular orbit
//   1 < r₀ < 2: elliptical orbit  
//   r₀ = 2: parabolic escape
//   r₀ > 2: hyperbolic escape
//
// For this example: r₀ = 1.5 (elliptical orbit)
//
// ==============================================================================
// POSITIVITY-PRESERVING TRANSFORMATION:
// ==============================================================================
// S-systems require all variables to be positive (for power-law terms X^g).
// However, v = dr/dt can become negative during orbital motion.
// 
// Solution: Define a shifted velocity χ = v + 1 = dr/dt + 1
// For bound orbits with |v| < 1, this ensures χ > 0 always.
//
// The transformed system becomes:
//   dr/dt = χ - 1
//   dχ/dt = r₀²·r⁻³ - r⁻²
//
// This is now in S-system form with all variables positive:
//   α₁ = 1, g₁_χ = 1;  β₁ = 1 (constant)
//   α₂ = r₀², g₂_r = -3;  β₂ = 1, h₂_r = -2
//
// Initial conditions:
//   r(0) = r₀ = 1.5 > 0
//   χ(0) = v(0) + 1 = 0 + 1 = 1 > 0  (perpendicular launch: v_r = 0)
// ==============================================================================

model DN2015_planetary_motion()
  // Variables (positivity-preserving S-system form)
  compartment cell = 1;var species r in cell; var species chi in cell

  // Parameters
  r0 := 1.5
  
  // S-system equations (positivity-preserving form)
  // dr/dt = χ - 1
  r' = chi - 1
  
  // dχ/dt = r₀²·r⁻³ - r⁻²  (centrifugal - gravitational)
  chi' = r0^2 * r^(-3) - r^(-2)
  
  // Initial conditions (both positive)
  r = 1.5; chi = 1.0; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Michaelis-Menten Kinetics Recasting
// Source: Daniels & Nemenman, PLOS ONE 10(3):e0119821 (2015)
// Equation 6
//
// This paper explicitly cites Savageau & Voit (1987) as reference [17].
//
// Original Michaelis-Menten kinetics (1D):
//   dx₁/dt = -A·x₁ / (B + x₁)
//
// ==============================================================================
// RECASTING TO S-SYSTEM FORM (Eq. 6):
// ==============================================================================
// "The classic Michaelis-Menten enzymatic kinetics can be recast by introducing
//  one hidden variable x₂" (p. 4)
//
// Let x₂ = B + x₁ (auxiliary variable)
//
// Then:
//   dx₁/dt = -A·x₁·x₂⁻¹           (power-law form)
//   x₂ = B + x₁                   (algebraic constraint)
//
// To get dynamics for x₂:
//   dx₂/dt = dx₁/dt = -A·x₁·x₂⁻¹
//
// This is now in S-system form: products of powers.
//
// Note: In the paper's notation, they write x₂⁻¹ but we need the constraint
// x₂ = B + x₁ as an initial condition (algebraic DAE).
// ==============================================================================

model DN2015b_michaelis_menten()
  // Variables
  compartment cell = 1;var species x1 in cell

  // Michaelis-Menten parameters
  A := 1.0; B := 0.5
  
  // Original Michaelis-Menten kinetics
  // dx₁/dt = -A·x₁ / (B + x₁)
  x1' = -A * x1 / (B + x1)
  
  // Initial condition
  x1 = 1.0; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Sinusoidal Dynamics Recasting
// Source: Daniels & Nemenman, PLOS ONE 10(3):e0119821 (2015)
// Equation 7
//
// This paper explicitly cites Savageau & Voit (1987) as reference [17].
//
// Original trigonometric dynamics (1D):
//   dx₁/dt = sin(x₁)
//
// ==============================================================================
// RECASTING TO S-SYSTEM FORM (Eq. 7):
// ==============================================================================
// "The dynamics x'₁ = sin(x₁) has a representation" (p. 4)
//
// Introduce auxiliary variables:
//   x₂ = sin(x₁)
//   x₃ = cos(x₁)
//
// Derive dynamics using chain rule:
//   dx₂/dt = cos(x₁)·dx₁/dt = x₃·x₂
//   dx₃/dt = -sin(x₁)·dx₁/dt = -x₂·x₂ = -x₂²
//
// The recast S-system (Eq. 7 in paper):
//   dx₁/dt = x₂
//   dx₂/dt = x₃·x₂
//   dx₃/dt = -x₂²
//
// Algebraic constraint (Pythagorean identity):
//   x₂² + x₃² = 1
//
// This is polynomial in the recast variables.
// ==============================================================================

model DN2015b_sinx_recasting()
  // Variables
  compartment cell = 1;var species x1 in cell

  // Original trigonometric ODE
  // dx₁/dt = sin(x₁)
  x1' = sin(x1)
  
  // Initial condition
  x1 = 0.1; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Brusselator - Recasting to Unimonomial Form
// Related: test_models1/m22_Brusselator.ant
// Source: Hernandez-Bermejo, Fairen & Brenig, "Algebraic recasting of nonlinear
//         systems of ODEs into universal formats"
//         J. Phys. A: Math. Gen. 31:2415-2430 (1998)
//         Section 4.2, Equations (45)-(54)
//
// The Brusselator (Nicolis & Prigogine 1977) is a model system for the
// Belousov-Zhabotinskii reaction showing limit cycle oscillations.
//
// Original QP form (Eq. 45):
//   x1' = x1*[-(b+1) + x1*x2 + a*x1^(-1)]
//   x2' = x2*[b*x1*x2^(-1) - x1^2]
//
// This is NOT a standard chemical kinetics form - it's already in QP format.
// Expanded to standard form:
//   x1' = a - (b+1)*x1 + x1^2*x2
//   x2' = b*x1 - x1^2*x2
//
// ==============================================================================
// EXACT RECASTING TO UNIMONOMIAL FORM (Eq. 49):
// ==============================================================================
// Via unimonomial embedding (2 -> 4 variables), system becomes:
//   z1' = z1*[-(b+1) + z1*z2^b*z3^a*z4^(-1)]
//   z2' = z2*[z1*z2^(-b)*z3^a*z4]
//   z3' = z3*[z1^(-1)*z3^(-a)]
//   z4' = z4*[z1^2*z3^(2a)]
//
// First integral introduced: z1^(1/2)*z3 = const
// Only one nonlinear term per equation (maximal simplification).
// ==============================================================================

model HBF1998_brusselator()
  // State variables
  compartment cell = 1
  var species x1 in cell
  var species x2 in cell

  // Parameters (typical values for limit cycle)
  a = 1.0
  b = 3.0
  
  // ORIGINAL ODEs (standard Brusselator)
  // Trimolecular reaction model: A -> X, B + X -> Y + D, 2X + Y -> 3X, X -> E
  x1' = a - (b + 1) * x1 + x1^2 * x2
  x2' = b * x1 - x1^2 * x2
  
  // Initial conditions (off steady state for oscillation)
  x1 = 1.5
  x2 = 3.0
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Morse Oscillator - Recasting to Lotka-Volterra Form
// Source: Hernández-Bermejo, Fairén & Brenig, "Algebraic recasting of nonlinear
//         systems of ODEs into universal formats"
//         J. Phys. A: Math. Gen. 31:2415-2430 (1998)
//         Section 3.2, Equations (17)-(25)
//
// This paper develops the quasipolynomial (QP) formalism for systematic recasting.
// The Morse oscillator from molecular physics (Bransden & Joachain 1990).
//
// Original system (Eq. 17):
//   ẋ = y
//   ẏ = -2d·e^(-x)·(1 - e^(-x))
//
// After phase-space translation by c and introducing z = e^(-x):
//   ẋ = y - c
//   ẏ = a·z - a·b·z² where a = -2d, b = e^c
//   ż = c·z - y·z
//
// ==============================================================================
// EXACT RECASTING TO QP FORM (Eq. 18):
// ==============================================================================
// With X₁ = x, X₂ = y, X₃ = z = e^(-x), the system becomes:
//   Ẋ₁ = X₁·[X₁⁻¹·X₂ - c·X₁⁻¹]
//   Ẋ₂ = X₂·[a·X₂⁻¹·X₃ - a·b·X₂⁻¹·X₃²]
//   Ẋ₃ = X₃·[c - X₂]
//
// After Lotka-Volterra embedding (5 variables), system is purely quadratic.
// ==============================================================================

model HBF1998_morse_oscillator()
  // State variables
  compartment cell = 1;var species x in cell; var species y in cell

  // Parameters (Morse potential)
  d := 1.0
  
  // ORIGINAL ODEs (Eq. 17)
  // Morse potential: V(x) = d·(1 - e^(-x))²
  x' = y; y' = -2 * d * exp(-x) * (1 - exp(-x))
  
  // Initial conditions (bound oscillation)
  x = 0.5; y = 0.5;
end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Semiconductor Electron-Hole/Exciton Oscillations
// Source: Hernandez-Bermejo, Fairen & Brenig, "Algebraic recasting of nonlinear
//         systems of ODEs into universal formats"
//         J. Phys. A: Math. Gen. 31:2415-2430 (1998)
//         Section 3.3, Equations (29)-(36)
//
// Original model from Cuerno & Velarde (1988) for sustained time-oscillations
// in electron-hole pairs (x1) and excitons (x2) in an intrinsic semiconductor.
//
// Physical processes:
//   photogeneration: gamma -> e + h (rate g)
//   stimulated exciton production: e + h + x2 -> 2x2 (rate c)
//   radiative decay: x2 -> gamma (rate k with high-order kinetics)
//
// Original system (Eq. 29):
//   x1' = g - c*x1^2*x2
//   x2' = c*x1^2*x2 - k*x2/(1 + q*x2)^m
//
// ==============================================================================
// EXACT RECASTING TO QP FORM (Eq. 30):
// ==============================================================================
// Introduce x3 = (1 + q*x2)^(-1) to handle the saturable decay term.
// QP system (3 variables, 4 quasimonomials):
//   X1' = X1*[g*X1^(-1) - c*X1*X2]
//   X2' = X2*[c*X1^2 - k*X3^m]
//   X3' = X3*[-c*q*X1^2*X2*X3 + q*k*X2*X3^(m+1)]
//
// Can be further reduced to Lotka-Volterra form (6 variables).
// ==============================================================================

model HBF1998_semiconductor_exciton()
  // State variables
  compartment cell = 1
  var species x1 in cell
  var species x2 in cell

  // Parameters
  g = 1.0
  c = 0.5
  k = 1.0
  q = 0.5
  m = 2
  
  // ORIGINAL ODEs (Eq. 29)
  // High-order kinetics model with saturable decay
  x1' = g - c * x1^2 * x2
  x2' = c * x1^2 * x2 - k * x2 / (1 + q * x2)^m
  
  // Initial conditions
  x1 = 1.0
  x2 = 0.5
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Three-Wave Interaction - Recasting to Unimonomial Form
// Source: Hernández-Bermejo, Fairén & Brenig, "Algebraic recasting of nonlinear
//         systems of ODEs into universal formats"
//         J. Phys. A: Math. Gen. 31:2415-2430 (1998)
//         Section 4.3, Equations (55)-(61)
//
// From Brenig & Goriely (1989). Models nonlinear interaction of three waves
// in plasma physics / nonlinear optics. Includes mode competition and resonance.
//
// Original system (Eq. 55):
//   ẋ₁ = x₁·[ω₁ + Σⱼ N₁ⱼ·xⱼ² + γ·x₁⁻¹·x₂·x₃]
//   ẋ₂ = x₂·[ω₂ + Σⱼ N₂ⱼ·xⱼ²]
//   ẋ₃ = x₃·[ω₃ + Σⱼ N₃ⱼ·xⱼ²]
//
// Where:
//   xᵢ = wave amplitudes
//   ωᵢ = dissipation (when negative)
//   Nᵢⱼ = mode competition coefficients  
//   γ = resonance coupling term
//
// ==============================================================================
// EXACT RECASTING (Eq. 58):
// ==============================================================================
// Using quasimonomial transformation with matrix C = N (competition matrix),
// system reduces from 10 to 6 nonlinear terms (dimension preserved).
//
// Full unimonomial embedding (3 → 4 variables, Eq. 61):
//   ż₁ = z₁·[ω̃₁ + z₁^(2N₁₁)·z₂^(2N₁₂)·z₃^(2N₁₃)·z₄^(2γ)]
//   ż₂ = z₂·[ω̃₂ + z₁^(2N₂₁)·z₂^(2N₂₂)·z₃^(2N₂₃)]
//   ż₃ = z₃·[ω̃₃ + z₁^(2N₃₁)·z₂^(2N₃₂)·z₃^(2N₃₃)]
//   ż₄ = z₄·[ω̃₄ + z₁^λ₁·z₂^λ₂·z₃^λ₃·z₄^(-γ)]
//
// where λᵢ = -N₁ᵢ + N₂ᵢ + N₃ᵢ
// Maximum simplification: only 4 nonlinear terms (one per equation).
// ==============================================================================

model HBF1998_three_wave()
  // State variables - wave amplitudes
  compartment cell = 1;var species x1 in cell; var species x2 in cell; var species x3 in cell

  // Parameters
  // Dissipation rates (negative for damping)
  omega1 := -0.1;
  omega2 := -0.1;
  omega3 := -0.1;
  
  // Mode competition matrix (symmetric for conservative case)
  N11 := 0.5;
  N12 := 0.3;
  N13 := 0.2;
  N21 := 0.3;
  N22 := 0.4;
  N23 := 0.3;
  N31 := 0.2;
  N32 := 0.3;
  N33 := 0.5;
  
  // Resonance coupling
  gamma_rate := 0.5;
  
  // ORIGINAL ODEs (Eq. 55)
  // Three-wave interaction with mode competition and resonance
  x1' = x1 * (omega1 + N11*x1^2 + N12*x2^2 + N13*x3^2 + gamma_rate*x2*x3/x1);
  x2' = x2 * (omega2 + N21*x1^2 + N22*x2^2 + N23*x3^2);
  x3' = x3 * (omega3 + N31*x1^2 + N32*x2^2 + N33*x3^2);
  
  // Initial conditions
  x1 = 1.0; x2 = 0.8; x3 = 0.6;
end
// @SIM T_START=0; T_END=0.65; N_STEPS =200 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Unbranched Metabolic Pathway with Michaelis-Menten Kinetics
// Source: Irvine, "Efficient Solution of Nonlinear Models Expressed in
//         S-System Canonical Form"
//         Math. Comput. Modelling 11:123-128 (1988)
//         Equations (8)-(9)
//
// The paper references Savageau & Voit (1986/1987) for the recasting algorithm.
//
// Original System (Eq. 8) - 9 equations with Michaelis-Menten kinetics:
//   V₀ = Vm₀·Xc·Kc⁻¹·K₁ / (K₁ + Xc·Kc⁻¹·K₁ + X₉)  [end-product inhibition]
//   Vᵢ = Vmᵢ·Xᵢ / (Xᵢ + Kᵢ)                       [Michaelis-Menten, i=1..9]
//   dXᵢ/dt = Vᵢ₋₁ - Vᵢ                            [i=1..9]
//
// ==============================================================================
// EXACT RECASTING TO S-SYSTEM (Eq. 9):
// ==============================================================================
// Introduce auxiliary variables:
//   X₁₀ = K₁ + Xc·Kc⁻¹·K₁ + X₉  (denominator of V₀)
//   Xⱼ = Xⱼ₋₁₀ + Kⱼ₋₁₀         (denominators of Vᵢ, j=11..19)
//
// The recast S-system (9 → 19 variables):
//   dX₁/dt = Vm₀·Xc·Kc⁻¹·K₁·X₁₀⁻¹ - Vm₁·X₁·X₁₁⁻¹
//   dXᵢ/dt = Vmᵢ₋₁·Xᵢ₋₁·Xᵢ₊₉⁻¹ - Vmᵢ·Xᵢ·Xᵢ₊₁₀⁻¹   [i=2..9]
//   dX₁₀/dt = dX₉/dt
//   dXⱼ/dt = dXⱼ₋₁₀/dt                            [j=11..19]
//
// Key result from Table VI:
//   - Cost of recasting: ~2x more equations
//   - Benefit with ESSYNS: 3-24x faster than RKF45 direct
//   - Net improvement: 10x faster at 10⁻¹² tolerance
// ==============================================================================

model I1988_metabolic_pathway()
  // Metabolic intermediates (original 9 variables)
  compartment cell = 1;var species X1 in cell; var species X2 in cell; var species X3 in cell; var species X4 in cell; var species X5 in cell; var species X6 in cell; var species X7 in cell; var species X8 in cell; var species X9 in cell

  // Parameters
  Xc = 1.0; Kc = 1.0; K1 = 0.1
  
  // Michaelis-Menten parameters
  Vm0 = 10.0; Vm1 = 5.0; Vm2 = 5.0; Vm3 = 5.0; Vm4 = 5.0; Vm5 = 5.0; Vm6 = 5.0; Vm7 = 5.0; Vm8 = 5.0; Vm9 = 5.0; K_1 = 0.5; K_2 = 0.5; K_3 = 0.5; K_4 = 0.5; K_5 = 0.5; K_6 = 0.5; K_7 = 0.5; K_8 = 0.5; K_9 = 0.5
  
  // Reaction rates (Michaelis-Menten with end-product inhibition on V0)
  V0 := Vm0 * Xc / Kc * K1 / (K1 + Xc / Kc * K1 + X9);
  V1 := Vm1 * X1 / (X1 + K_1);
  V2 := Vm2 * X2 / (X2 + K_2);
  V3 := Vm3 * X3 / (X3 + K_3);
  V4 := Vm4 * X4 / (X4 + K_4);
  V5 := Vm5 * X5 / (X5 + K_5);
  V6 := Vm6 * X6 / (X6 + K_6);
  V7 := Vm7 * X7 / (X7 + K_7);
  V8 := Vm8 * X8 / (X8 + K_8);
  V9 := Vm9 * X9 / (X9 + K_9);
  
  // Original ODEs (Eq. 8)
  X1' = V0 - V1; X2' = V1 - V2; X3' = V2 - V3; X4' = V3 - V4; X5' = V4 - V5; X6' = V5 - V6; X7' = V6 - V7; X8' = V7 - V8; X9' = V8 - V9
  
  // Initial conditions
  X1 = 1.0; X2 = 1.0; X3 = 1.0; X4 = 1.0; X5 = 1.0; X6 = 1.0; X7 = 1.0; X8 = 1.0; X9 = 1.0;
end
// @SIM T_START=0; T_END=4; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Lifting a Nonpolynomial System (Exponential ODE)
// Source: Kramer, Peherstorfer & Willcox, Annu. Rev. Fluid Mech. 56:521-548 (2024)
// Sidebar "LIFTING A NONPOLYNOMIAL SYSTEM" on p. 526
//
// Original 1st-order ODE with exponential nonlinearity:
//   ẋ(t) = a·x(t) + e^(-x(t))
//
// Parameters: a < 0 for stability (we use a = -1)
//
// ==============================================================================
// LIFTING TO QUADRATIC FORM (citing Savageau & Voit 1987):
// ==============================================================================
// The paper cites Savageau & Voit (1987) in Section 2.1.3:
// "Bringing nonlinear systems into canonical and abstract forms can further 
//  improve their numerical solution, analysis, and verification, as shown by 
//  Savageau & Voit (1987), Liu et al. (2015), Brenig (2018), and Guillot et al. (2019)."
//
// Lifting transformation:
//   x₁ = x  (original variable)
//   x₂ = e^(-x₁)  (auxiliary variable to eliminate exponential)
//
// Derive dynamics for x₂ using chain rule:
//   dx₂/dt = d/dt[e^(-x₁)] = -e^(-x₁) · dx₁/dt = -x₂ · (a·x₁ + x₂)
//          = -a·x₁·x₂ - x₂²
//
// The lifted quadratic system:
//   dx₁/dt = a·x₁ + x₂            (linear + linear = linear-quadratic)
//   dx₂/dt = -a·x₁·x₂ - x₂²       (quadratic terms only)
//
// This is now in polynomial (specifically quadratic) form.
//
// In matrix notation (from the sidebar):
//   [ẋ₁]   [a 1] [x₁]   [0 0 0  0 ] [x₁⊗x₁]
//   [ẋ₂] = [0 0] [x₂] + [0 0 -a -1] [x₁⊗x₂]
//                                    [x₂⊗x₁]
//                                    [x₂⊗x₂]
//
// Note: The lifted system is used for "Operator Inference" - learning reduced
// models from data. The polynomial structure enables efficient learning.
// ==============================================================================

model KPW2024_exponential_lifting()
  // Variables (original form - will be lifted by ssys recaster)
  compartment cell = 1;var species x in cell

  // Parameters
  a := -1.0
  
  // Original nonpolynomial ODE
  // dx/dt = a·x + e^(-x)
  x' = a * x + exp(-x)
  
  // Initial condition
  x = 1.0; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Marin-Sanguino et al. (2007) "Optimization of biotechnological
//         systems through geometric programming"
//         Theor. Biol. Med. Model. 4:38
// Example: Michaelis-Menten to GMA recasting (Equations 14-16)
// =============================================================================
// Time horizon: t ∈ [0, 20] (not specified in paper, added for simulation)
//
// Original ODE with Michaelis-Menten kinetics (Equation 14):
//   dX1/dt = Vmax,1*X0/(KM,1 + X0) - Vmax,2*X1/(KM,2 + X1)
//
// Recast to GMA form (Equations 15-16):
//   Define auxiliary variables:
//     X2 = KM,2 + X1
//     X3 = KM,1 + X0  (constant if X0 is independent)
//
//   GMA system:
//     dX1/dt = Vmax,1*X0*X3^(-1) - Vmax,2*X1*X2^(-1)
//     dX2/dt = Vmax,1*X0*X3^(-1) - Vmax,2*X1*X2^(-1)
//
//   Initial conditions:
//     X1(0) = X10
//     X2(0) = KM,2 + X10
//
// NOTE: Parameter values added for simulation - not specified in original paper.
// =============================================================================

model MS2007_MM_to_GMA()
    // Parameters (added for simulation)
    Vmax1 = 1.0   // Maximum rate for production
    Vmax2 = 0.5   // Maximum rate for degradation
    KM1 = 1.0     // Michaelis constant for production
    KM2 = 0.5     // Michaelis constant for degradation
    X0 = 2.0      // Substrate (constant, independent variable)
    
    // Original Michaelis-Menten form
    X1' = Vmax1*X0/(KM1 + X0) - Vmax2*X1/(KM2 + X1)
    
    // Initial condition
    X1 = 0.5
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Marin-Sanguino et al. (2007) "Optimization of biotechnological
//         systems through geometric programming"
//         Theor. Biol. Med. Model. 4:38
// Example: Anaerobic fermentation in S. cerevisiae (Equations 39-40)
//          Based on Curto et al. (1995) Math. Biosci. 130:25-50
// =============================================================================
// Time horizon: t ∈ [0, 20] (added for simulation)
//
// GMA model for glycolytic pathway (already in GMA form):
//   5 dependent variables: X1-X5 (metabolite pools)
//   9 independent variables: X6-X14 (enzyme activities, etc.)
//
// Original ODEs (Equation 39):
//   dX1/dt = v_in - v_HK
//   dX2/dt = v_HK - v_PFK - v_POL
//   dX3/dt = v_PFK - v_GAPD - v_GOL
//   dX4/dt = 2*v_GAPD - v_PK
//   dX5/dt = 2*v_PK - v_HK - v_PFK - v_POL - v_ATP
//
// Flux equations (Equation 40, all monomials/power-laws):
//   v_in = 0.8122 * X2^(-0.2344) * X6
//   v_HK = 2.8632 * X1^(0.7464) * X5^(0.0243) * X7
//   v_PFK = 0.5232 * X2^(0.7318) * X5^(0.3941) * X8^(-0.0009) * X11^(2.8632)
//   v_GAPD = 0.011 * X2^(0.7318) * X5^(0.3941) * X8^(0.6159) * X5^(0.1308) * X9 * X14^(0.6088)
//   v_PK = 3.005 * X4^(0.533) * X5^(0.0822) * X10
//   v_POL = 0.0945 * X2^(8.6107) * X11^(-0.0009)
//   v_GOL = 0.0945 * X3^(0.05) * X4^(0.533) * X5^(0.0822) * X12
//   v_ATP = 5 * X13
//
// Note: This is already in GMA form - no recasting needed.
// =============================================================================

model MS2007_fermentation_yeast()
    // Metabolite pools (dependent variables)
    // X1: Glucose
    // X2: G6P/F6P pool
    // X3: FBP/DHAP/GAP pool  
    // X4: 3PG/2PG/PEP pool
    // X5: ATP
    
    // Flux definitions (power-law/monomial form)
    v_in := 0.8122 * X2^(-0.2344) * X6
    v_HK := 2.8632 * X1^(0.7464) * X5^(0.0243) * X7
    v_PFK := 0.5232 * X2^(0.7318) * X5^(0.3941) * X8^(-0.0009) * X11^(2.8632)
    v_GAPD := 0.011 * X2^(0.7318) * X5^(0.3941) * X8^(0.6159) * X9 * X14^(0.6088)
    v_PK := 3.005 * X4^(0.533) * X5^(0.0822) * X10
    v_POL := 0.0945 * X2^(8.6107) * X11^(-0.0009)
    v_GOL := 0.0945 * X3^(0.05) * X4^(0.533) * X5^(0.0822) * X12
    v_ATP := 5 * X13
    
    // ODEs
    X1' = v_in - v_HK
    X2' = v_HK - v_PFK - v_POL
    X3' = v_PFK - v_GAPD - v_GOL
    X4' = 2*v_GAPD - v_PK
    X5' = 2*v_PK - v_HK - v_PFK - v_POL - v_ATP
    
    // Initial conditions (basal state from paper)
    X1 = 0.03456
    X2 = 1.0110
    X3 = 9.1876
    X4 = 0.009532
    X5 = 1.1278
    
    // Independent variables (enzyme activities, etc.)
    X6 = 19.7     // v_in enzyme
    X7 = 68.5     // Hexokinase
    X8 = 31.7     // Phosphofructokinase
    X9 = 49.9     // GAPDH
    X10 = 3440    // Pyruvate kinase
    X11 = 14.3    // ATPase (glycogen/trehalose)
    X12 = 203     // G3P dehydrogenase (glycerol)
    X13 = 25.1    // Other ATP consumption
    X14 = 0.042   // NAD+/NADH ratio
end
// @SIM T_START=0 T_END=0.002 N_STEPS=200 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Related: test_models1/m15_tryptophan_operon.ant
// Source: Marin-Sanguino et al. (2007) "Optimization of biotechnological
//         systems through geometric programming"
//         Theor. Biol. Med. Model. 4:38
// Example: Tryptophan operon in E. coli (Equations 41-44)
//          Based on Xiu et al. (2002) Biotechnol. Prog. 18:686-93
// =============================================================================
// Time horizon: t ∈ [0, 20] (added for simulation)
//
// Original model (not in GMA form, Equation 41-42):
//   dX1/dt = v1 - v2   (mRNA)
//   dX2/dt = v3 - v4   (enzyme)
//   dX3/dt = v5 - v6 - v7 - v8   (tryptophan)
//
// Rate equations (Equation 42, complex rational functions):
//   v1 = X3 / ((X5+X3)*(1+X3)*(1+0.9+X3))
//   v2 = X4 * X1
//   v3 = 1 + 0.9 * X1
//   v4 = X4 * X2
//   v5 = X2 * X6^2 / (X6^2 + X3^2)
//   v6 = 0.0022 * X3 * X4
//   v7 = X3 / (1.75 + X3)
//   v8 = 0.005 * X3 / (X4^(-1) + 0.437 * X3)
//
// Recast GMA form with auxiliary variables (Equations 43-44):
//   Define:
//     X8 = X5 + X3
//     X9 = 1 + X3
//     X10 = X8 + X3 (from paper: 1 + 0.9 + X3)
//     X11 = 1 + X4
//     X12 = 1 + X4
//     X13 = X6^2 + X3^2
//     X14 = X4^(-1) + 0.437*X3
//     X15 = 1.75 + X3
//
//   GMA rates (Equation 44):
//     v1 = X9^(-1) * X10^(-1)
//     v2 = X11^(-1) * X1
//     v3 = X1
//     v4 = X12^(-1) * X2
//     v5 = X2 * X6^2 * X13^(-1)
//     v6 = 0.0022 * X3 * X4
//     v7 = X3 * X15^(-1)
//     v8 = 0.005 * X3 * X14^(-1)
// =============================================================================

model MS2007_tryptophan_operon()
    // State variables
    // X1: mRNA (dimensionless)
    // X2: Enzyme level (dimensionless)
    // X3: Tryptophan concentration (dimensionless)
    
    // Rate equations (original complex form)
    v1 := X3 / ((X5+X3)*(1+X3)*(1+0.9+X3))
    v2 := X4 * X1
    v3 := 1 + 0.9 * X1
    v4 := X4 * X2
    v5 := X2 * X6^2 / (X6^2 + X3^2)
    v6 := 0.0022 * X3 * X4
    v7 := X3 / (1.75 + X3)
    v8 := 0.005 * X3 / (X4^(-1) + 0.437 * X3)
    
    // ODEs
    X1' = v1 - v2
    X2' = v3 - v4
    X3' = v5 - v6 - v7 - v8
    
    // Initial conditions (basal state from paper)
    X1 = 0.18465    // mRNA
    X2 = 7.9868     // Enzyme
    X3 = 1418       // Tryptophan
    
    // Independent variables (parameters)
    X4 = 0.00312    // Dilution rate
    X5 = 544        // Repressor binding constant
    X6 = 228        // Feedback inhibition constant
    X7 = 430        // (unused in this version)
end
// @SIM T_START=0 T_END=400 N_STEPS=800 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Branched Network with SC (Saturable and Cooperative) Kinetics
// Source: Pozo et al., "Steady-state global optimization of metabolic non-linear
//         dynamic models through recasting into power-law canonical models"
//         BMC Systems Biology 5:137 (2011)
//         Equation (2), Figure 1
//
// Network structure (Figure 1):
//   X5 -> X1 -> X2 -> X3 -> (output via v4)
//                  \-> X4 -> (output via v6)
//   X3 inhibits reaction 2 (feedback)
//   X1 activates reaction 5 (feedforward)
//
// Original SC model (Eq. 2) - 4 dependent variables with SC kinetics:
// ==============================================================================
// dX1/dt = 20*k1*X5^1/(X5^1+1) - 40*k2*X1^1*X3^(-1)/[(X1^1+1)(X3^(-1)+1)]
// dX2/dt = 40*k2*X1^1*X3^(-1)/[(X1^1+1)(X3^(-1)+1)] - 7.5*k3*X2^2.5/(X2^2.5+0.25)
//          - 16*k5*X1^1*X2^1/[(X1^1+1)(X2^1+1)]
// dX3/dt = 7.5*k3*X2^2.5/(X2^2.5+0.25) - 12*k4*X3^1/(X3^1+1)
// dX4/dt = 16*k5*X1^1*X2^1/[(X1^1+1)(X2^1+1)] - 8*k6*X4^1/(X4^1+1)
//
// SC formalism: v = V*X^n / (K + X^n)
// where n can represent cooperativity
// ==============================================================================

model P2011_branched_SC()
  // State variables
  compartment cell = 1
  var species X1 in cell
  var species X2 in cell
  var species X3 in cell
  var species X4 in cell

  // External (fixed) variable
  X5 = 1.0

  // Enzyme activity modulation parameters (k_r = 1 at basal level)
  k1 = 1.0
  k2 = 1.0
  k3 = 1.0
  k4 = 1.0
  k5 = 1.0
  k6 = 1.0

  // Reaction rates with SC form
  v1 := 20 * k1 * X5 / (X5 + 1)

  // FIXED: avoid (1/X3)/(1/X3+1) cancellable singularity
  // (1/X3)/(1/X3+1) == 1/(1+X3) algebraically, but is numerically safer this way.
  v2 := 40 * k2 * (X1 / (X1 + 1)) * (1 / (1 + X3))

  v3 := 7.5 * k3 * X2^2.5 / (X2^2.5 + 0.25)
  v4 := 12 * k4 * X3 / (X3 + 1)
  v5 := 16 * k5 * X1 / (X1 + 1) * X2 / (X2 + 1)
  v6 := 8 * k6 * X4 / (X4 + 1)

  // ODEs
  X1' = v1 - v2
  X2' = v2 - v3 - v5
  X3' = v3 - v4
  X4' = v5 - v6

  // Initial conditions (basal steady state)
  X1 = 1.0
  X2 = 0.8
  X3 = 1.2
  X4 = 1.0
end

// @SIM T_START=0 T_END=1 N_STEPS=100 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.// Linear Pathway with Michaelis-Menten Kinetics and Competitive Inhibition
// Source: Pozo et al., "Steady-state global optimization of metabolic non-linear
//         dynamic models through recasting into power-law canonical models"
//         BMC Systems Biology 5:137 (2011)
//         Equations (20)-(23)
//
// This paper explicitly cites Savageau & Voit (1987) as reference [36].
//
// Original Michaelis-Menten model (Eq. 20) - 2 variables:
//   dX₁/dt = V₁·X₃ / (K₁(1 + Kᵢ/X₂) + X₃) - V₂·X₁ / (K₂ + X₁)
//   dX₂/dt = V₂·X₁ / (K₂ + X₁) - V₃·X₂² / (K₃² + X₂²)
//
// X₃ is external (fixed), X₂ is competitive inhibitor of first reaction
//
// ==============================================================================
// EXACT RECASTING TO GMA (Eq. 21-23):
// ==============================================================================
// Introduce auxiliary variables:
//   X₄ = K₁(1 + Kᵢ/X₂) + X₃
//   X₅ = K₂ + X₁
//   X₆ = K₃² + X₂²
//
// Recast GMA model (2 → 6 variables):
//   dX₁/dt = V₁·X₃·X₄⁻¹ - V₂·X₁·X₅⁻¹
//   dX₂/dt = V₂·X₁·X₅⁻¹ - V₃·X₂²·X₆⁻¹
//   dX₄/dt = -K₁·Kᵢ·dX₂/dt / X₂² = V₃·K₁·Kᵢ·X₆⁻¹ - V₂·K₁·Kᵢ·X₁·X₅⁻¹·X₂⁻²
//   dX₅/dt = dX₁/dt = V₁·X₃·X₄⁻¹ - V₂·X₁·X₅⁻¹
//   dX₆/dt = 2·X₂·dX₂/dt = 2·V₂·X₁·X₂·X₅⁻¹ - 2·V₃·X₂³·X₆⁻¹
// ==============================================================================

model P2011_linear_pathway_MM()
  // State variables (original)
  compartment cell = 1;var species X1 in cell; var species X2 in cell

  // External (fixed) variable
  X3 := 1.0;
  
  // Kinetic parameters
  V1 := 10.0;
  V2 := 5.0;
  V3 := 5.0;
  K1 := 0.5;
  K2 := 0.5;
  K3 := 0.5;
  Ki := 1.0;
  
  // Original Michaelis-Menten model (Eq. 20)
  // Competitive inhibition: apparent Km = K1·(1 + Ki/X2)
  X1' = V1 * X3 / (K1 * (1 + Ki / X2) + X3) - V2 * X1 / (K2 + X1);
  X2' = V2 * X1 / (K2 + X1) - V3 * X2^2 / (K3^2 + X2^2);
  
  // Initial conditions
  X1 = 1.0; X2 = 1.0;
end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Diabatic CSTR with Arrhenius Kinetics
// Source: Papachristodoulou & Prajna, "Analysis of Non-polynomial Systems
//         using the Sum of Squares Decomposition", Springer (2005), Section 4.4
//
// This paper explicitly cites Savageau & Voit (1987) as reference [14].
//
// System: Continuously Stirred Tank Reactor (CSTR) with first-order exothermic
//         irreversible reaction A -> B
//
// Original ODEs (Eq. 42-43):
//   dC_A/dt = (F/V)(C_Af - C_A) - k0*exp(-Delta_E/(RT))*C_A
//   dT/dt = (F/V)(Tf - T) - (Delta_H/(rho*cp))*k0*exp(-Delta_E/(RT))*C_A - (UA/(V*rho*cp))*(T - Tj)
//
// The exponential Arrhenius term makes this non-polynomial.
//
// ==============================================================================
// RECASTING TO RATIONAL FORM (pp. 17-18):
// ==============================================================================
// After equilibrium shift (x1 = CA/CA0 - 1, x2 = T/T0 - 1):
//
// Introduce auxiliary variable:
//   x3 = exp(Delta_E*x2 / (RT0*(x2+1))) - 1
//
// Dynamics for x3 (chain rule):
//   dx3/dt = [Delta_E / (RT0*(x2+1)^2)] * (x3+1) * dx2/dt
//
// Constraint: x3 > -1 (exponential is always positive)
//
// The recasted 3D system (Eq. 44-46) is now rational in (x1, x2, x3).
// ==============================================================================

model PP2005_CSTR_arrhenius()
  // Variables (in physical coordinates, pre-transformation)
  compartment cell = 1
  var species C_A in cell
  var species T in cell

  // Parameters from Table 1 (p. 17)
  F_V = 1.0
  k0 = 34930800
  Delta_H = -5960
  Delta_E = 11843
  R = 1.987
  rho_cp = 500
  T_f = 25
  C_Af = 10
  UA_V = 150
  T_j = 25
  
  // Arrhenius rate constant (T is in Celsius, convert to Kelvin)
  k := k0 * exp(-Delta_E / (R * (T + 273.15)))
  
  // Original non-polynomial ODEs
  C_A' = F_V * (C_Af - C_A) - k * C_A
  T' = F_V * (T_f - T) + (-Delta_H / rho_cp) * k * C_A - (UA_V / rho_cp) * (T - T_j)
  
  // Initial conditions (at equilibrium from paper: CA0=8.5636, T0=311.171K = 38.02C)
  C_A = 8.5636
  T = 38.02
end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Exact Exponential Recasting (1D → 1D)
// Source: Papachristodoulou & Prajna, "Analysis of Non-polynomial Systems
//         using the Sum of Squares Decomposition", Springer (2005), p. 2
//
// This paper explicitly cites Savageau & Voit (1987) as reference [14].
//
// Original 1st-order ODE with exponential:
//   ẋ(t) = c·e^(-αx(t))
//
// ==============================================================================
// EXACT RECASTING (dimension-preserving):
// ==============================================================================
// "In some cases the recasting is 'exact', in the sense that the transformed
//  system has a polynomial vector field with the same dimension as the original
//  system" (p. 2)
//
// Substitution:
//   p(t) = c·e^(-αx(t))
//
// Derive dynamics for p using chain rule:
//   dp/dt = c·(-α)·e^(-αx)·dx/dt = (-α)·(c·e^(-αx))·(c·e^(-αx))/c
//         = (-α)·p·(p/c) = -α·p²/c
//
// Or if c = 1:
//   dp/dt = -α·p²
//
// This is the same dimension as the original system (1D → 1D).
//
// Note: This is a rare case where recasting does NOT increase dimension.
// Most recastings require auxiliary variables.
// ==============================================================================

model PP2005_exponential_exact()
  // Variables
  compartment cell = 1;var species x in cell

  // Parameters
  c := 1.0; alpha := 1.0
  
  // Original nonpolynomial ODE
  // dx/dt = c·e^(-αx)
  x' = c * exp(-alpha * x)
  
  // Initial condition
  x = 0.0; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Central F-Distribution - Original Form
// Source: Rust & Voit, "Statistical Densities, Cumulatives, Quantiles, and Power..."
//         JASA 85(410):572-578 (1990)
//         Equation (10)
//
// Both papers explicitly cite Savageau & Voit (1987).
//
// Central F density with v1 numerator and v2 denominator degrees of freedom:
//   g(v1, v2, 0; t) = C * t^((v1/2)-1) * (v2 + v1*t)^(-(v1+v2)/2)
//
// Differentiating:
//   g'(t) = ((v1/2)-1)/t * g(t) - (v1(v1+v2)/2)/(v2 + v1*t) * g(t)
//
// Problem: The SUM (v2 + v1*t) in denominator is not S-system compatible.
//
// ==============================================================================
// EXACT RECASTING TO S-SYSTEM (Eq. 10):
// ==============================================================================
// Define auxiliary variables:
//   X1 = t
//   X2 = v2 + v1*t   (the troublesome sum term)
//   X3 = t * g(v1, v2, 0; t)  (product form to handle all v1 > 0)
//   X4 = G(v1, v2, 0; t)  (cumulative)
//
// Recast S-system (1 -> 4 variables):
//   X1' = 1
//   X2' = v1
//   X3' = (v1/2) * X1^(-1) * X3 - (v1(v1+v2)/2) * X2^(-1) * X3
//   X4' = X1^(-1) * X3
//
// The pdf is: g(v1, v2, 0; t) = X1^(-1) * X3
// ==============================================================================

model RV1990_central_F()
  // ORIGINAL ODE (not S-system form due to sum in denominator)
  compartment cell = 1
  var species t in cell
  var species g_var in cell
  var species G in cell

  // Parameters
  v1 = 11
  v2 = 200
  
  // ORIGINAL ODEs
  // g'(t) = ((v1/2)-1)/t * g - (v1(v1+v2)/2)/(v2 + v1*t) * g
  // Note: (v2 + v1*t) is a SUM - not S-system compatible
  t' = 1
  g_var' = (v1 / 2 - 1) / t * g_var - (v1 * (v1 + v2) / 2) / (v2 + v1 * t) * g_var
  G' = g_var
  
  // Initial conditions at t = 1
  // For F(11, 200): f(1) and F(1) from tables
  t = 1.0
  g_var = 0.95
  G = 0.55
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Central Chi-Squared Distribution - Original Form
// Source: Rust & Voit, "Statistical Densities, Cumulatives, Quantiles, and Power..."
//         JASA 85(410):572-578 (1990)
//         Equation (6)
//
// Both papers explicitly cite Savageau & Voit (1987) - see Savageau (1982).
//
// Original chi-squared density with v degrees of freedom:
//   f_c(v; t) = (1/(2^(v/2) · Γ(v/2))) · t^((v/2)-1) · exp(-t/2)
//
// Differentiating:
//   f'(t) = ((v/2) - 1)/t · f(t) - (1/2) · f(t)
//         = ((v-2)/(2t) - 1/2) · f(t)
//
// Problem: When v < 2, the first term has a negative rate constant.
// Paper's solution uses X₂ = t·f(t) to handle all v > 0 universally.
//
// ==============================================================================
// EXACT RECASTING TO S-SYSTEM (Eq. 6):
// ==============================================================================
// Universal S-system representation valid for ALL v > 0:
//   X₁ = t
//   X₂ = t · f_c(v; t)
//   X₃ = F_c(v; t)  (cumulative)
//
// ODEs:
//   X₁' = 1
//   X₂' = (v/2) · X₁⁻¹ · X₂ - (1/2) · X₂
//   X₃' = X₁⁻¹ · X₂
//
// The pdf is: f_c(v; t) = X₁⁻¹ · X₂
// ==============================================================================

model RV1990_central_chisquared()
  // ORIGINAL ODE - direct form
  // This works for v >= 2, but has issue for v < 2
  
  compartment cell = 1;
  species t in cell;
  species f_var in cell;
  species F in cell;

  // Parameters
  v = 6;
  
  // ORIGINAL ODEs
  // f'(t) = ((v/2) - 1)/t · f - (1/2) · f
  // Note: For v < 2, the coefficient (v/2 - 1) < 0 which violates S-system constraints
  t' = 1;
  f_var' = (v / 2 - 1) / t * f_var - 0.5 * f_var;
  F' = f_var;
  
  // Initial conditions at t = v (the mode for v >= 2)
  // At t = v = 6:
  //   f_c(6; 6) ≈ 0.112063448
  //   F_c(6; 6) ≈ 0.5768
  t = 6.0;
  f_var = 0.112063448113;
  F = 0.576810023449;
end

// @SIM T_START=6 T_END=20 N_STEPS=400
// Central t-Distribution Density - Original Form
// Related: test_models1/m17_central_t.ant
// Source: Voit & Rust, "Evaluation of the Noncentral t Distribution with S-Systems"
//         Biom. J. 32(6):681-695 (1990)
//         Equations (2)-(4)
//
// Also in: Rust & Voit, "Statistical Densities, Cumulatives, Quantiles, and Power..."
//          JASA 85(410):572-578 (1990)
//
// Both papers explicitly cite Savageau & Voit (1987).
//
// Original ODE for central t density with v degrees of freedom:
//   f(t) = C · (1 + t²/v)^(-(v+1)/2)
//   f'(t) = -(v+1) · t / (v + t²) · f(t)
//
// This is NOT in S-system form because of the SUM (v + t²) in denominator.
//
// ==============================================================================
// EXACT RECASTING TO S-SYSTEM (Eq. 4):
// ==============================================================================
// Define auxiliary variables:
//   X₁ = t + c    (shifted to avoid zero for log-transform in ESSYNS)
//   X₂ = v + t²   (the troublesome denominator term)
//   X₃ = f(t)     (the density)
//   X₄ = F(t)     (cumulative)
//
// Recast S-system (1 → 4 variables):
//   X₁' = 1
//   X₂' = 2·X₁ - 2·c = 2·t  (derivative of v + t² w.r.t. t)
//   X₃' = c·(v+1)·X₁⁻¹·X₃ - (v+1)·X₁·X₂⁻¹·X₃
//   X₄' = X₃
// ==============================================================================

model RV1990_central_t_density()
  // ORIGINAL ODE (not S-system form due to sum in denominator)
  // t is treated as a state variable marching along with time
  
  compartment cell = 1;
  species t in cell;
  species f_var in cell;
  species F in cell;

  // Parameters
  v = 8;
  
  // ORIGINAL ODEs
  // f'(t) = -(v+1) · t / (v + t²) · f(t)
  // Note: (v + t²) is a SUM - not S-system compatible
  t' = 1;
  f_var' = -(v + 1) * t / (v + t^2) * f_var;
  F' = f_var;
  
  // Initial conditions at t = 0
  // f(0) = Gamma((v+1)/2) / (sqrt(v*pi) * Gamma(v/2))
  // For v = 8: f(0) ≈ 0.3866990209613933
  t = 0.001;  // Small positive value to avoid division issues at t=0
  f_var = 0.3866990209613933;
  F = 0.5;
end

// @SIM T_START=0 T_END=4 N_STEPS=400
// =============================================================================
// Source: Savageau (1988) "Introduction to S-Systems and the Underlying
//         Power-Law Formalism"
//         Math. Comput. Modelling 11:546-551
// Recasting Example 1: Monod chemostat -> Recasting method 1 (Equations 19-20)
// Recasting Example 2: Monod chemostat -> Recasting method 2 (Equation 21)
// =============================================================================
// Time horizon: t ∈ [0, 20] (added for simulation)
//
// Original Monod equations (Equation 19):
//   dX1/dt = α1 * X1 * X2 / (X2 + 1) - X1
//   dX2/dt = (Xr - X2) - β2 * X1 * X2 / (X2 + 1)
//
// where:
//   X1 = cell concentration
//   X2 = substrate concentration (normalized by Ks)
//   Xr = reservoir substrate concentration (normalized)
//   α1 = exponential growth rate constant
//   β2 = α1 / yield coefficient Y
//   Time normalized with respect to dilution rate D
//
// Recast S-system method 1 (Equation 20):
//   Define: X3 = X2 + 1, X4 = Xr - X2
//   X(0) = (X10, X20, X20+1, Xr-X20)
//
//   dX1/dt = α1*X1*X2*X3^(-1) - X1
//   dX2/dt = X4 - β2*X1*X2*X3^(-1)
//   dX3/dt = X4 - β2*X1*X2*X3^(-1)
//   dX4/dt = β2*X1*X2*X3^(-1) - X4
//
// Advantages of this method (from paper):
//   - Original variables X1, X2 retained
//   - Behavior on 2D plane corresponds to 2D manifold in 4D space
//   - Nonzero stable steady state preserved as rest point
//
// Recast S-system method 2 (Equation 21):
//   Define: X4 = X2 (replaces X2)
//           X5 = auxiliary for X2
//           X6 = (X2+1)^(-1), X7 = auxiliary for X6
//   X(0) = (X10, X20, 1, (X20+1)^(-1), 1)
//
//   dX1/dt = α1*X1*X4*X5*X6*X7 - X1
//   dX4/dt = Xr*X5^(-1) - X4
//   dX5/dt = -β2*X1*X5*X6*X7
//   dX6/dt = β2*X1*X4*X5*X6^2*X7 - X6*X6^2*X7
//   dX7/dt = X4*X5*X6*X7^2
//
// Note: Method 2 uses systematic "product rule" decomposition but:
//   - Has one extra variable
//   - Original X2 not explicitly present
//   - Nonzero steady state becomes a "stable trajectory"
//
// NOTE: Parameter values added for simulation.
// =============================================================================

model S1988_Monod_chemostat()
    // Parameters
    alpha1 = 2.0   // Exponential growth rate constant
    beta2 = 4.0    // α1 / yield coefficient Y
    Xr = 5.0       // Reservoir substrate concentration (normalized)
    
    // Original Monod equations
    X1' = alpha1 * X1 * X2 / (X2 + 1) - X1
    X2' = (Xr - X2) - beta2 * X1 * X2 / (X2 + 1)
    
    // Initial conditions
    X1 = 0.1   // Cell concentration
    X2 = 4.0   // Substrate concentration
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Mixed Terms - Reductive Recasting (4 auxiliary variables)
// Source: Savageau, "Finding Multiple Roots of Nonlinear Algebraic Equations
//         Using S-System Methodology"
//         Appl. Math. Comput. 55:187-199 (1993)
//         Equations (15)-(19)
//
// This paper cites Savageau & Voit (1987) as reference [12].
//
// Original ODE (Eq. 15):
//   dX₁/dt + a₁₁X₁² + a₁₂X₁X₂ - a₂₁X₂^g₁ - a₂₂X₁^g₂X₂^g₃ = 0
//
// Rewritten as:
//   dX₁/dt = a₂₁X₂^g₁ + a₂₂X₁^g₂X₂^g₃ - a₁₁X₁² - a₁₂X₁X₂
//
// ==============================================================================
// EXACT RECASTING via Reductive Method (Eq. 16-19):
// ==============================================================================
// This equation has BOTH POSITIVE AND NEGATIVE MULTIPLE TERMS.
// Four auxiliary variables are needed: X₁ = X₂·X₃·X₄·X₅
//
// After the reductive step (Eq. 16-19):
//   dX₂/dt = (g₁₁/g₁₂)α₁·X₂^(g₁₁/g₁₂)·X_...  - β₂·X₂^h₂_...
//   dX₃/dt = similar structure
//   dX₄/dt = similar structure  
//   dX₅/dt = similar structure
//
// Note: Equation (19) is a linear combination of (16)-(18) in steady state
// and is eliminated.
//
// Constraints (Eq. 20-21):
//   X₂ + X₃ = 1  (positive terms constraint)
//   X₄ + X₅ = 1  (negative terms constraint)
//
// This demonstrates reductive recasting for the most general case:
// multiple terms of BOTH signs → 2 auxiliary sets.
// ==============================================================================

model S1993_mixed_terms()
  // Variables
  compartment cell = 1;var species X1 in cell; var species X2 in cell

  // Parameters (example values)
  a11 := 1.0;
  a12 := 0.5;
  a21 := 2.0;
  a22 := 1.5;
  g1 := 0.5;
  g2 := 0.3;
  g3 := 0.7;
  
  // Original ODE with mixed terms (multiple positive, multiple negative)
  // dX₁/dt = a₂₁·X₂^g₁ + a₂₂·X₁^g₂·X₂^g₃ - a₁₁·X₁² - a₁₂·X₁·X₂
  X1' = a21 * X2^g1 + a22 * X1^g2 * X2^g3 - a11 * X1^2 - a12 * X1 * X2;
  
  // Second equation (conservation or independent dynamics)
  X2' = -X2 + 1
  
  // Initial conditions
  X1 = 0.5; X2 = 0.8;
end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Sum with Radical Term - Reductive Recasting
// Source: Savageau, "Finding Multiple Roots of Nonlinear Algebraic Equations
//         Using S-System Methodology"
//         Appl. Math. Comput. 55:187-199 (1993)
//         Equations (4)-(7)
//
// This paper cites Savageau & Voit (1987) as reference [12].
//
// Original ODE (Eq. 4):
//   dX₁/dt + X₁² - √X₁ = 0
//
// Which can be rewritten as:
//   dX₁/dt = √X₁ - X₁²
//
// ==============================================================================
// EXACT RECASTING via Reductive Method (Eq. 5-7):
// ==============================================================================
// The equation has terms with BOTH signs and multiple terms.
// The reductive recasting introduces X₁ = X₂·X₃ and differentiates.
//
// After differentiation and association (reductive step), the recast S-system:
//
//   dX₂/dt = α₁₂·X₂^(1/2) - X₂²        (Eq. 6)
//   dX₃/dt = α₁₂·X₃^(1/2) - X₃²        (Eq. 7)
//
// where the product X₂·X₃ approaches the steady state of X₁.
//
// This demonstrates "reductive recasting" - decomposing a single equation
// with multiple terms into multiple S-system equations.
// ==============================================================================

model S1993_sum_radical()
  // Variables
  compartment cell = 1;var species X1 in cell

  // Original ODE with radical term
  // dX₁/dt = √X₁ - X₁²
  X1' = sqrt(X1) - X1^2
  
  // Initial condition
  X1 = 0.5; end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1988) "S-Systems as a Canonical Nonlinear Form"
//         Math. Comput. Modelling 11:140-145
// Example: Endemic infection with asymptomatics - exact recasting (Eq. 14-15)
//          Based on Kemper (1978) and Cooke (1982)
// =============================================================================
// Time horizon: t ∈ [0, 100]
//
// Original model (Equation 14):
//   dS/dt = γ1*I + γ2*A - S*[g(I) + h(A)]
//   dI/dt = f*S*[g(I) + h(A)] - γ1*I
//   dA/dt = (1-f)*S*[g(I) + h(A)] - γ2*A
//
// With mass action interactions: g(I) = r1*I, h(A) = r2*A
//
// Variables:
//   S = susceptibles (proportion)
//   I = infectives with symptoms (proportion)
//   A = asymptomatics (proportion)
//   S + I + A = 1 (conservation)
//
// Parameters:
//   f = fraction developing symptoms
//   γ1, γ2 = recovery rates
//   r1, r2 = contact rates
//
// Exact S-system recasting (Equation 15):
//   Define: X1=S, X2=I, X3=A
//           X4 = r1*I + r2*A (infection force)
//           X5 = auxiliary for product decomposition
//           X6 = γ1*I + γ2*A (recovery flux)
//           X7 = auxiliary for product decomposition
//
//   dX1/dt = X6*X7^(-1) - X1*X4*X5^(-1)
//   dX2/dt = f*X1*X4*X5^(-1) - γ1*X2
//   dX3/dt = (1-f)*X1*X4*X5^(-1) - γ2*X3
//   dX4/dt = r1*f*X1*X4 - r1*γ1*X2*X5
//   dX5/dt = r2*γ2*X3*X4^(-1)*X5^2 - r2*(1-f)*X1*X5
//   dX6/dt = γ1*f*X1*X4*X5^(-1)*X7 - γ1^2*X2*X7
//   dX7/dt = γ2^2*X3*X6^(-1)*X7^2 - γ2*(1-f)*X1*X4*X5^(-1)*X6^(-1)*X7^2
//
// This is an EXACT recasting of the Kemper/Cooke endemic infection model.
// =============================================================================

model V1988a_endemic_infection()
    // Parameters
    f = 0.5       // Fraction developing symptoms
    gamma1 = 0.1  // Recovery rate for symptomatics
    gamma2 = 0.2  // Recovery rate for asymptomatics
    r1 = 0.5      // Contact rate for symptomatics
    r2 = 0.3      // Contact rate for asymptomatics
    
    // Original equations with mass action (g=r1*I, h=r2*A)
    S' = gamma1*I + gamma2*A - S*(r1*I + r2*A)
    I' = f*S*(r1*I + r2*A) - gamma1*I
    A' = (1-f)*S*(r1*I + r2*A) - gamma2*A
    
    // Initial conditions (fractions sum to 1)
    S = 0.9   // Susceptibles
    I = 0.05  // Infected with symptoms
    A = 0.05  // Asymptomatic carriers
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1988) "S-Systems as a Canonical Nonlinear Form"
//         Math. Comput. Modelling 11:140-145
// Example: Sin/Exp system - detailed exact recasting (Equations 6-10)
// =============================================================================
// Time horizon: t ∈ [0, 20]
//
// Original system (Equation 6):
//   dY/dt = 2 - sin(Y) - Y,     Y(0) = Y0
//   dZ/dt = exp(Y^2) + Y*Z - Z, Z(0) = Z0
//
// Exact S-system recasting (Equation 10):
//   Define auxiliary variables:
//     X1 = Y, X2 = sin(Y)+4, X3 = Z, X4 = exp(Y^2)
//     X5 = cos(Y)+4, X6 = product decomposition
//
//   Recast S-system (renaming X3→X2,...,X7→X6):
//     dX1/dt = X5*X6 - X2
//     dX2/dt = X2 - 4
//     dX3/dt = 2*X1*X3*X5*X6 - 2*X1*X2*X3
//     dX4/dt = 4 - X2
//     dX5/dt = X3*X6^(-1) - X1*X6^(-1)
//     dX6/dt = X1*X6
//
//   Initial conditions:
//     X(0) = (Y0, sin(Y0)+4, exp(Y0^2), cos(Y0)+4, Z0, 1)
//
// This is an EXACT recasting showing sin, exp, and polynomial nonlinearities.
// =============================================================================

model V1988a_sin_exp_system()
    // Original system with sin and exp nonlinearities
    Y' = 2 - sin(Y) - Y
    Z' = exp(Y^2) + Y*Z - Z
    
    // Initial conditions
    Y = 1.0
    Z = 1.0
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1988) "S-Systems as a Canonical Nonlinear Form"
//         Math. Comput. Modelling 11:140-145
// Example: Weibull growth law - exact recasting (Equations 2-4)
// =============================================================================
// Time horizon: t ∈ [0, 20]
//
// Original Weibull growth law (Equation 2):
//   W(t) = Wf * exp[-b*(t+a)^(-C)]
//
// Differentiate to get ODE and recast as S-system (Equations 4):
//   dW/dt = b*C * W * Z^(-1)
//   dZ/dt = -Z
//   where Z = (t+a)^(C+1)
//
// This is an EXACT recasting of the Weibull growth law.
//
// NOTE: Parameter values added for simulation.
// =============================================================================

model V1988a_weibull_growth()
    // Parameters
    Wf = 100.0    // Final/asymptotic weight
    b = 1.0       // Rate parameter
    C = 2.0       // Shape parameter
    a = 1.0       // Time shift
    
    // Differentiating Weibull to get ODE form:
    // W(t) = Wf * exp[-b*(t+a)^(-C)]
    // dW/dt = Wf * exp[-b*(t+a)^(-C)] * b*C*(t+a)^(-C-1)
    //       = W * b*C*(t+a)^(-C-1)
    
    // Original ODE form
    W' = W * b*C*(time+a)^(-C-1)
    
    // Initial condition: W(0) = Wf * exp[-b*a^(-C)]
    W = Wf * exp(-b*a^(-C))
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1988) "New Nonlinear Methodologies for Modeling Molecular
//         and Cellular Systems"
//         Proc. IFAC Modelling and Control in Biomedical Systems, Venice, Italy
// Example: Simple exponential ODE - exact recasting (page 223)
// =============================================================================
// Time horizon: t ∈ [0, 5]
//
// Original ODE:
//   dX/dt = exp(X)
//
// Recast S-system:
//   Define: X1 = X, X2 = exp(X1)
//   From X2 = exp(X1), we have dX2/dt = X2 * dX1/dt
//
//   dX1/dt = X2
//   dX2/dt = X2 * X1' = X2 * X2 = X2^2
//
// This is an EXACT recasting of the exponential ODE.
// Note: Solution blows up (X → ∞) as t → 1 - ln(X0+1).
// =============================================================================

model V1988b_exponential_ode()
    // Original exponential ODE
    X' = exp(X)
    
    // Initial condition (small value to avoid quick blowup)
    X = -2.0
end
// @SIM T_START=0 T_END=7.38 N_STEPS=369 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1988) "New Nonlinear Methodologies for Modeling Molecular
//         and Cellular Systems"
//         Proc. IFAC Modelling and Control in Biomedical Systems, Venice, Italy
// Example: GMA to S-system conversion via product rule (page 223)
// =============================================================================
// Time horizon: t ∈ [0, 20]
//
// Original GMA (Generalized Mass Action) system:
//   dX1/dt = γ1*X1*X2 - γ2*X1^2*X3
//   dX2/dt = X1 - X2
//
// This is a Mass Action system (sum of power-law terms).
// 
// Recast S-system using product rule:
//   Replace X1 with product X3*X4 where:
//     dX3/dt = [γ1*X1*X2 - γ2*X1^2*X3] * X4^(-1)
//     dX4/dt = [γ3*X1*X2^2 - γ4*X1^(-1)*X3^(-1)] * X4^(-1)
//
//   After eliminating X1, the S-system in (X2, X3, X4) is:
//     dX2/dt = X3*X4 - X2
//     dX3/dt = γ1*X2*X3 - γ2*X2^(-1)*X3^2*X4
//     dX4/dt = γ3*X1^2*X4 - γ4*X2^(-1)*X3^(-1)
//
// This demonstrates the product rule for reducing sums to differences.
//
// NOTE: Using simplified original form for simulation.
// =============================================================================

model V1988b_gma_to_ssystem()
    // Parameters
    gamma1 = 1.0
    gamma2 = 0.5
    
    // Original GMA system (sum of power-law terms)
    X1' = gamma1*X1*X2 - gamma2*X1^2*X3
    X2' = X1 - X2
    X3' = 0  // X3 is constant auxiliary (for simplicity)
    
    // Initial conditions
    X1 = 1.0
    X2 = 1.0
    X3 = 1.0
end
// @SIM T_START=0 T_END=6 N_STEPS=300 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1990) "S-System Modelling of Endemic Infections"
//         Comput. Math. Applic. 20(4-6):161-173
// Example: Cooke's endemic infection model - exact recasting (Equation 15)
//          Original: Cooke (1982)
// =============================================================================
// Time horizon: t ∈ [0, 100]
//
// Original Cooke model (Equation 7 with different γ1, γ2):
//   dS/dt = γ1*I + γ2*A - S*[r1*I + r2*A]
//   dI/dt = f*S*[r1*I + r2*A] - γ1*I
//   dA/dt = (1-f)*S*[r1*I + r2*A] - γ2*A
//
// Variables:
//   S = susceptibles (proportion)
//   I = infectives with symptoms (proportion)
//   A = asymptomatics (proportion)
//   S + I + A = 1 (conservation)
//
// Exact S-system recasting (Equation 15):
//   Define: X1=S, X2=I, X3=A
//           X4/X5 = r1*I + r2*A (Z1 in paper)
//           X6/X7 = γ1*I + γ2*A (Z2 in paper)
//
//   dX1/dt = X6*X7^(-1) - X1*X4*X5^(-1)
//   dX2/dt = f*X1*X4*X5^(-1) - γ1*X2
//   dX3/dt = (1-f)*X1*X4*X5^(-1) - γ2*X3
//   dX4/dt = r1*f*X1*X4 - r1*γ1*X2*X5
//   dX5/dt = r2*γ2*X3*X4^(-1)*X5^2 - r2*(1-f)*X1*X5
//   dX6/dt = γ1*f*X1*X4*X5^(-1)*X7 - γ1^2*X2*X7
//   dX7/dt = γ2^2*X3*X6^(-1)*X7^2 - γ2*(1-f)*X1*X4*X5^(-1)*X6^(-1)*X7^2
//
// This is the general form with different recovery rates.
// =============================================================================

model V1990_cooke_endemic()
    // Parameters
    f = 0.8       // Fraction developing symptoms
    gamma1 = 0.2  // Recovery rate for symptomatics
    gamma2 = 0.1  // Recovery rate for asymptomatics (different!)
    r1 = 0.5      // Contact rate for symptomatics
    r2 = 0.3      // Contact rate for asymptomatics
    
    // Original Cooke equations with different recovery rates
    S' = gamma1*I + gamma2*A - S*(r1*I + r2*A)
    I' = f*S*(r1*I + r2*A) - gamma1*I
    A' = (1-f)*S*(r1*I + r2*A) - gamma2*A
    
    // Initial conditions (away from steady state)
    S = 0.9   // Susceptibles
    I = 0.05  // Infected with symptoms
    A = 0.05  // Asymptomatic carriers
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1990) "S-System Modelling of Endemic Infections"
//         Comput. Math. Applic. 20(4-6):161-173
// Example: Endemic infection with exponential influence (Equations 39-41)
// =============================================================================
// Time horizon: t ∈ [0, 100]
//
// Variant model with exponential infection term (Equation 39):
//   dI/dt = α1 * I^g11 * exp(b*A) - γ1*I
//   dA/dt = α2 * I^g21 * A^g22 - γ2*A
//
// This shows infection of symptomatic group enhanced exponentially
// by the number of asymptomatic carriers.
//
// Exact S-system recasting (Equations 40-41):
//   Define: Z = exp(b*A)
//   dZ/dt = α2*b*I^g21*A^(g22)*Z - γ2*b*A*Z
//
// Steady state analysis (Equation 41):
//   Is = (α1*γ1^(-1)*Zs)^(1/(1-g11))
//   As = (α2*γ2^(-1))^(1/(1-g22)) * (α1*γ1^(-1)*Zs)^(g21/((1-g11)(1-g22)))
//   Then solve Zs = exp(b*As) numerically (1D search)
//
// =============================================================================

model V1990_endemic_exp_infection()
    // Parameters
    alpha1 = 0.5  // Infection rate coefficient
    alpha2 = 0.3  // Asymptotic conversion rate
    gamma1 = 0.2  // Recovery rate for symptomatics
    gamma2 = 0.1  // Recovery rate for asymptomatics
    g11 = 0.5     // I self-influence exponent
    g21 = 0.3     // I influence on A
    g22 = 0.7     // A self-influence exponent
    b = 0.1       // Exponential coupling strength
    
    // Original equations with exponential term
    I' = alpha1 * I^g11 * exp(b*A) - gamma1*I
    A' = alpha2 * I^g21 * A^g22 - gamma2*A
    
    // Initial conditions
    I = 0.1   // Infected with symptoms
    A = 0.1   // Asymptomatic carriers
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1990) "S-System Modelling of Endemic Infections"
//         Comput. Math. Applic. 20(4-6):161-173
// Example: Kemper's endemic infection model - exact recasting (Equation 9)
//          Original: Kemper (1978)
// =============================================================================
// Time horizon: t ∈ [0, 100]
//
// Original Kemper model (Equation 7 with γ1 = γ2 = γ):
//   dS/dt = γ*I + γ*A - S*[g(I) + h(A)]
//   dI/dt = f*S*[g(I) + h(A)] - γ*I
//   dA/dt = (1-f)*S*[g(I) + h(A)] - γ*A
//
// With mass action: g(I) = r1*I, h(A) = r2*A
//
// Variables:
//   S = susceptibles (proportion)
//   I = infectives with symptoms (proportion)
//   A = asymptomatics (proportion)
//   S + I + A = 1 (conservation)
//
// Exact S-system recasting (Equation 9):
//   Define: X1=S, X2=I, X3=A
//           X4 = r1*I + r2*A (infection potential)
//           X5 = I + A (fraction infected)
//
//   dX1/dt = γ*X5 - X1*X4
//   dX2/dt = f*X1*X4 - γ*X2
//   dX3/dt = (1-f)*X1*X4 - γ*X3
//   dX4/dt = [r1*f + r2*(1-f)]*X1*X4 - γ*X4
//   dX5/dt = X1*X4 - γ*X5
//
// Steady state (Equation 13):
//   S* = γ/p where p = r1*f + r2*(1-f)
//   I* = f*(p-γ)/p
//   A* = (1-f)*(p-γ)/p
// =============================================================================

model V1990_kemper_endemic()
    // Parameters
    f = 0.8       // Fraction developing symptoms
    gamma_rate = 0.2   // Recovery rate (same for both)
    r1 = 0.5      // Contact rate for symptomatics
    r2 = 0.3      // Contact rate for asymptomatics
    
    // Derived parameter
    p := r1*f + r2*(1-f)  // Infection coefficient
    
    // Original Kemper equations with mass action
    S' = gamma_rate*I + gamma_rate*A - S*(r1*I + r2*A)
    I' = f*S*(r1*I + r2*A) - gamma_rate*I
    A' = (1-f)*S*(r1*I + r2*A) - gamma_rate*A
    
    // Initial conditions (away from steady state)
    S = 0.9   // Susceptibles
    I = 0.05  // Infected with symptoms
    A = 0.05  // Asymptomatic carriers
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1992) "Symmetries of S-Systems"
//         Math. Biosci. 109:19-31
// Example: Blasius equation - exact recasting (pages 28-30)
// =============================================================================
// Time horizon: t ∈ [0, 10]
//
// Original Blasius equation (third-order ODE from boundary layer theory):
//   Y''' = b * Y * Y''
//
// This is a fundamental equation in fluid dynamics describing
// laminar boundary layer flow over a flat plate.
//
// Recast as first-order S-system:
//   Define: X0 = x (independent variable), X1 = Y, X2 = Y', X3 = Y''
//
//   dX1/dX0 = X2
//   dX2/dX0 = X3
//   dX3/dX0 = b * X1 * X3
//
// Note: Parameter b is typically -1/2 for classical Blasius.
//
// Symmetry: Admits one-parameter transformation:
//   Z0 = ρ^(-c)*X0, Z1 = ρ^c*X1, Z2 = ρ^(2c)*X2, Z3 = ρ^(3c)*X3
// =============================================================================

model V1992_blasius_equation()
    // Parameter (classical Blasius uses b = -1/2)
    b = -0.5
    
    // First-order system equivalent to Y''' = b*Y*Y''
    Y' = Yp
    Yp' = Ypp
    Ypp' = b * Y * Ypp
    
    // Initial conditions (typical boundary layer)
    Y = 0.0     // Y(0) = 0
    Yp = 0.0    // Y'(0) = 0
    Ypp = 0.33  // Y''(0) ≈ 0.33 (shooting parameter)
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1992) "Symmetries of S-Systems"
//         Math. Biosci. 109:19-31
// Example: Second-order ODE with logarithm - exact recasting (page 28)
// =============================================================================
// Time horizon: t ∈ [0, 10]
//
// Original second-order ODE (in paper's notation, s is physical time starting at 1):
//   Z'' = Z' * Z' - 2*[1 + ln(s)] * s^(-2) * Z
//
// To avoid singularity at t=0, we use shifted time variable:
//   tau = t + 1  (so at simulation t=0, tau=1, and ln(1)=0 is well-defined)
//
// Recast as S-system (in shifted coordinates):
//   Define: X0 = tau, X1 = 1 + ln(tau), X2 = Z, X3 = dZ/dt
//
//   d(tau)/dt = 1
//   dX1/dt = tau^(-1)
//   dZ/dt = Zp
//   dZp/dt = Z^(-1)*Zp^2 - 2*tau^(-2)*(1+ln(tau))*Z
//
// This demonstrates recasting of equations with logarithmic terms.
//
// Symmetry: Scaling Z and dZ/dt by same factor leaves equation unaltered.
// =============================================================================

model V1992_log_ode()
    // Second-order ODE: Z'' = Z'*Z'/Z - 2*[1+ln(tau)]*tau^(-2)*Z
    // Using shifted time tau = t + 1 to avoid ln(0) singularity
    
    tau' = 1                                       // tau = t + 1
    Z' = Zp
    Zp' = Zp*Zp/Z - 2*(1 + ln(tau))*tau^(-2)*Z
    
    // Initial conditions at t=0 (which corresponds to tau=1, s=1 in original)
    tau = 1.0   // tau(0) = 1, so ln(tau) = 0
    Z = 1.0     // Z(0) = 1
    Zp = 0.5    // Z'(0) = 0.5
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1993) "S-System Modelling of Complex Systems with Chaotic Input"
//         Environmetrics 4(2):153-186
// Example: Blue sky catastrophe - exact recasting (Appendix, Equations A4-A6)
// =============================================================================
// Time horizon: t ∈ [0, 200]
//
// Original blue sky catastrophe (Equation A4):
//   dx/dt = 0.7*y + x - 10*x*y^2
//   dy/dt = C - x + 0.25*sin(1.5*t)
//
// This system is very sensitive to perturbations and initial conditions.
// Trajectories can suddenly escape to infinity (hence "blue sky catastrophe").
//
// Typical parameter: C = 0.097
//
// Exact S-system recasting (Equation A6):
//   Introduce: X1 = x + p, X2 = y + q, X3 = sin(1.5t) + r, X4 = cos(1.5t) + r
//   With constraint: r = 4*(C + p), e.g., p = q = 10, r = 40.388
//
// The system is chaotic with intermittent escapes to infinity.
// =============================================================================

model V1993_blue_sky()
    // Parameter (typical value)
    C = 0.097
    
    // Blue sky catastrophe equations
    x' = 0.7*y + x - 10*x*y^2
    y' = C - x + 0.25*sin(1.5*time)
    
    // Initial conditions
    x = -0.4
    y = 0.388
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1993) "S-System Modelling of Complex Systems with Chaotic Input"
//         Environmetrics 4(2):153-186
// Example: Forced oscillator - exact recasting (Appendix, Equations A1-A3)
// =============================================================================
// Time horizon: t ∈ [0, 200]
//
// Original forced oscillator (Equation A1):
//   x'' + 0.25*x' - x + x^3 = A*sin(t)
//
// This is a Duffing-type forced oscillator with damping.
// Parameter A controls the forcing amplitude and determines chaos vs. periodic.
//
// Recast as first-order S-system (Equation A3):
//   Introduce: X1 = x + p, X2 = x' + q, X3 = A*sin(t) + r, X4 = A*cos(t) + r
//   With constraints: r = p^3 - p + 0.25*q (e.g., p=q=2, r=6.5)
//
//   dX1/dt = X2 - q
//   dX2/dt = X3 - r + p^3 - p + 0.25*q - X1^3 + 3*p*X1^2 - (3*p^2-1)*X1 - 0.25*X2
//   dX3/dt = X4 - r
//   dX4/dt = r - X3
//
// For A ≈ 0.265, the system exhibits chaotic transitions between upper/lower domains.
// =============================================================================

model V1993_forced_oscillator()
    // Forcing amplitude (A ≈ 0.265 for chaos)
    A = 0.265
    
    // Forced Duffing-type oscillator (second order)
    // x'' + 0.25*x' - x + x^3 = A*sin(t)
    x' = v
    v' = x - x^3 - 0.25*v + A*sin(time)
    
    // Initial conditions
    x = 0.0
    v = 0.0
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (1993) "S-System Modelling of Complex Systems with Chaotic Input"
//         Environmetrics 4(2):153-186
// Example: Screw-type Rossler band - exact recasting (Equation 15)
//          Original: Rossler (1979)
// =============================================================================
// Time horizon: t ∈ [0, 100]
//
// Original Rossler system (Equation 11):
//   dx/dt = -y - z
//   dy/dt = x + a*y
//   dz/dt = b*z - c*z + x*z
//
// Rossler parameters:
//   a = 0.5, b = 0.4, c = 4.5
//
// The Rossler band is a classic example of deterministic chaos.
//
// Exact S-system recasting (Equation 15):
//   Shift variables to ensure positivity: p=25, q=50
//   X1 = x + p, X2 = -y + q, X3X4 = z + q
//
//   dX1/dt = X2 - X3*X4
//   dX2/dt = 0.5*X2 - X1
//   dX3/dt = 0.0586*X1*X3*X4^(-1) - 1.984*X3*X4^(-1)
//   dX4/dt = 0.0586*X1*X4 - 0.59*X4
//
// =============================================================================

model V1993_rossler_band()
    // Parameters (Rossler 1979)
    a = 0.5
    b = 0.4
    c = 4.5
    
    // Original Rossler equations (chaos)
    x' = -y - z
    y' = x + a*y
    z' = b*z - c*z + x*z
    
    // Initial conditions (Rossler 1979)
    x = 0.0   // x(0) = 0
    y = 3.0   // y(0) = 3
    z = 0.0   // z(0) = 0
end
// @SIM T_START=0 T_END=12 N_STEPS=240 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// =============================================================================
// Source: Voit (2005) "Smooth bistable S-systems"
//         IEE Proc. Syst. Biol. 152(4):207-213
// Example: Bistable gene expression system (Equations 3-4)
// =============================================================================
// Time horizon: t ∈ [0, 200]
//
// Bistable gene expression system (Figure 2):
//   X1 = gene expression level (mRNA)
//   X2 = protein level
//   X3 = metabolite level
//   X4 = inducer (feedback signal)
//
// Sigmoidal induction function:
//   f(X4) = q1 + q2*X4^n / (q3^n + X4^n)
//
// This creates bistability with hysteresis.
//
// Full system (Equation 4):
//   dX1/dt = (4 + 8*X4^4/(256 + X4^4)) * X3^0.5 - 0.5*X1^0.5
//   dX2/dt = X1^0.5 - 5*X2^0.5
//   dX3/dt = 2*X2 - 3*X3
//   dX4/dt = 3*X3 - 12*X4^0.75
//
// Stable steady states (Equation 9):
//   State 1: (13.598, 7.3964, 4.9309, 1.3218)
//   State 2: (27.251, 29.705, 19.804, 8.4381)
//   Unstable: (19.849, 15.760, 10.507, 3.6241)
//
// =============================================================================

model V2005_bistable_gene()
    // Sigmoidal parameters
    q1 = 4.0      // Basal expression level
    q2 = 8.0      // Maximal additional expression
    q3 = 4.0      // Switch point (q3^n = 256 for n=4)
    n = 4         // Hill coefficient (steepness)
    
    // Sigmoidal induction function
    sigma := q1 + q2*X4^n/(q3^n + X4^n)
    
    // Gene expression system with bistability
    X1' = sigma * X3^0.5 - 0.5*X1^0.5
    X2' = X1^0.5 - 5*X2^0.5
    X3' = 2*X2 - 3*X3
    X4' = 3*X3 - 12*X4^0.75
    
    // Initial conditions (near lower stable state)
    X1 = 10.0
    X2 = 5.0
    X3 = 3.0
    X4 = 1.0
end
// @SIM T_START=0 T_END=3 N_STEPS=300 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Phase-Locked Loop (PLL) Converter Grid Connection
// Source: Zhang et al., IEEE Trans. Power Systems 37(2):1351-1362 (2022)
// Section IV.C: Polynomial Conversion of Power System
//
// Original system (Eq. 7): 2nd-order PLL with trigonometric nonlinearities
//   dx₁/dt = x₂
//   dx₂/dt = -C₁ cos(x₁) x₂ - C₂ sin(x₁) + C₃
//
// where:
//   x₁ = θ_PLL - θ_sep (phase angle relative to stable equilibrium)
//   x₂ = Δω_PLL (angular frequency deviation)
//   C₁ = k_{p,PLL} |V_g| |K| (damping coefficient)
//   C₂ = k_{i,PLL} |V_g| |K| (synchronizing coefficient)
//   C₃ = k_{i,PLL} |Z| |I| sin(θ_Z + θ_C) (power injection term)
//
// Parameters from paper (Section V-A):
//   k_{p,PLL} = 0.32, k_{i,PLL} = 0.37 s⁻¹
//   SCR = 5, X/R = 7
//   Rated: 400V, 10kW
//
// ==============================================================================
// EXACT RECASTING TO POLYNOMIAL FORM (Eq. 17-18):
// ==============================================================================
// The paper explicitly cites Savageau & Voit (1987) [ref 30] for this recasting.
//
// Substitution variables:
//   u₁ = sin(x₁)
//   u₂ = 1 - cos(x₁)
//
// Algebraic constraint (from Pythagorean identity):
//   u₁² + u₂² - 2u₂ = 0
//
// The recast polynomial DAE (Eq. 19):
//   State: (x₁, x₂, u₁, u₂) — 4D with 1 constraint → effective 3D
//
// Dynamics for recast variables (using chain rule):
//   du₁/dt = cos(x₁) · dx₁/dt = (1-u₂) · x₂
//   du₂/dt = sin(x₁) · dx₁/dt = u₁ · x₂
//
// Full polynomial system:
//   dx₁/dt = x₂
//   dx₂/dt = -C₁(1-u₂)x₂ - C₂u₁ + C₃
//   du₁/dt = (1-u₂)x₂
//   du₂/dt = u₁x₂
//   subject to: u₁² + u₂² - 2u₂ = 0
//
// This is polynomial form suitable for SOS programming analysis.
// ==============================================================================

model Z2022_pll_converter()

// Compartment
compartment cell = 1;

// State variables
species x1 in cell;
species x2 in cell;

// PLL control parameters (from paper Section V-A)
kp_pll = 0.32;
ki_pll = 0.37;

// Combined coefficients C1, C2, C3 (derived from grid parameters SCR=5, X/R=7)
C1 = 1.0;
C2 = 1.2;
C3 = 0.3;

// Original trigonometric ODEs (Eq. 7)
x1' = x2;
x2' = -C1 * cos(x1) * x2 - C2 * sin(x1) + C3;

// Initial conditions (near stable equilibrium)
x1 = 0.1;
x2 = 0.0;

end

// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Bergman1989_MinimalGlucoseModel.ant
//
// Source model:
//   Bergman RN (1989)
//   "Toward physiological understanding of glucose tolerance:
//    Minimal-model approach." Diabetes 38(12):1512–1527.
//   (Lilly Lecture 1989; describes the glucose minimal model,
//    glucose effectiveness SG, and insulin sensitivity SI.)
//   Typical values reported for humans:
//     SG ≈ 0.021 min^-1
//     SI ≈ 5×10^-4 min^-1 (µU/mL)^-1
//
// Model summary:
//   G(t)  : plasma glucose concentration (mg/dL)
//   I(t)  : plasma insulin concentration (µU/mL)
//   X(t)  : "remote" insulin effect compartment (min^-1)
//   G_b   : basal glucose
//   I_b   : basal insulin
//
//   dG/dt = - (p_1 + X) * (G - G_b)
//   dX/dt = - p_2 * X + p_3 * (I - I_b)
//   (classic Bergman minimal model form; I(t) is treated as
//    measured input in the original work)
//
// Parameters chosen here:
//   p_1 = S_G = 0.021 min^-1 (mean glucose effectiveness in humans)
//   S_I = p_3/p_2 ≈ 5×10^-4 min^-1 (µU/mL)^-1 (mean insulin sensitivity)
//   p_2 = 0.025 min^-1  (remote insulin decay; τ ≈ 40 min)
//   p_3 = S_I * p_2 = 1.25e-5 min^-2 (µU/mL)^-1
//
//   G_b = 90 mg/dL (typical fasting plasma glucose)
//   I_b = 10 µU/mL (typical fasting insulin)
//
// Initial conditions used here:
//   G(0) = 180 mg/dL   (IV glucose bolus; ~90 mg/dL above basal)
//   X(0) = 0 min^-1    (no initial remote insulin effect)
//   I(0) = I_b          (start at basal insulin)
//
// Note:
//   In practice, I(t) during an FSIGT is taken from measured data
//   (glucose + tolbutamide / insulin injections) and used as an
//   external input. Here we keep a trivial constant I(t) ODE for a
//   self-contained ODE system; for real fits, you’d override I(t)
//   with your experimental time course.

model Bergman1989_MinimalGlucoseModel

  // Compartment
  compartment plasma = 1;

  // Species: state variables
  species G in plasma;
  species X in plasma;
  species I in plasma;

  // Basal (fasting) levels
  const G_b = 90;
  const I_b = 10;

  // Minimal model parameters
  const p_1 = 0.021;
  const p_2 = 0.025;
  const p_3 = 1.25e-5;

  // ODEs
  // Glucose dynamics: deviation from basal (G - G_b)
  G' = - (p_1 + X) * (G - G_b);

  // Remote insulin effect dynamics
  X' = - p_2 * X + p_3 * (I - I_b);

  // Insulin dynamics
  // In the original minimal model, I(t) comes from data.
  // Here we keep insulin at basal as a placeholder:
  I' = 0;

  // Initial conditions
  G = 180;
  X = 0.01;
  I = I_b;

end
// @SIM T_START=0 T_END=200 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// DeYoungKeizer1992_IP3R_SinglePool_Reduced.ant
//
// Source:
//   De Young GW, Keizer J (1992)
//   "A single-pool inositol 1,4,5-trisphosphate-receptor-based model
//    for agonist-stimulated oscillations in Ca2+ concentration."
//   Proc Natl Acad Sci USA 89:9895–9899.
//
// Model type:
//   Single IP3-sensitive Ca2+ pool (ER) + cytosolic Ca2+,
//   with De Young–Keizer IP3R subunit kinetics reduced using
//   a rapid equilibrium approximation for IP3 binding (Eqs. 3a–3d).
//
// State variables (species):
//   Ca   : cytosolic free Ca2+ concentration [Ca2+]_c (µM)
//   x000 : fraction of IP3R subunits with no ligands bound (S_000)
//   x001 : fraction with only inhibitory Ca2+ bound (S_001)
//   x010 : fraction with only activating Ca2+ bound (S_010)
//   x011 : fraction with both Ca2+ sites bound (S_011); here algebraic
//          via conservation (sum over all 8 subunit states = 1).
//
// IP3 binding is assumed fast:
//   x1ik = ([IP3]/d_j) * x0ik,  j = 1 or 3
// so all IP3-bound states are expressed in terms of x000, x001, x010, x011.
// Channel open state is S_110, which obeys
//   x110 = ([IP3]/d1) * x010
// and the single-channel open probability is x110^3.
//
// Ca2+ fluxes:
//   J1 = c1 * ( v1 * x110^3 + v2 ) * (Ca_ER - Ca)
//        (IP3R-mediated flux + leak from ER to cytosol)
//   J2 = v3 * Ca^2 / (Ca^2 + k3^2)
//        (ATP-driven Ca2+ uptake into ER)
//   Ca_ER is determined by conservation:
//     c0 = c1 * [Ca2+]_ER + [Ca2+]_c  →  Ca_ER = (c0 - Ca)/c1
//
// Cytosolic Ca2+ dynamics:
//   dCa/dt = J1 - J2
//
// Subunit kinetics (reduced 4-state system):
//   dx000/dt = -V1 - V3
//   dx001/dt =  V1 - V4
//   dx010/dt =  V3 - V2
//   x011 from conservation (no ODE)
// with
//   V1 = a4 * (Ca * x000 - d4 * x001)
//   V2 = a4 * (Ca * x010 - d4 * x011)
//   V3 = a5 * (Ca * x000 - d5 * x010)
//   V4 = a5 * (Ca * x001 - d5 * x011)
//
// Parameter values (Table 1, all in µM or s^-1):  [Ca2+] in µM.
//   c_0 = 2.0       (total Ca2+ in ER+cytosol, in cytosolic vol units)
//   c_1 = 0.185     (ER volume / cytosolic volume)
//   v_1 = 6.0       (max IP3R-mediated Ca2+ flux, s^-1)
//   v_2 = 0.11      (Ca2+ leak flux constant, s^-1)
//   v_3 = 0.9       (max Ca2+ uptake by pump, µM s^-1)
//   k_3 = 0.1       (Ca2+ activation constant of pump, µM)
//
// Receptor kinetic parameters (a_i in µM^-1 s^-1, d_i in µM):
//   a1 = 400.0      (IP3 binding, not used explicitly in reduced system)
//   a2 = 0.2        (Ca2+ inhibition site, fast binding in full model)
//   a3 = 400.0      (IP3 binding, not used explicitly here)
//   a_4 = 0.2       (Ca2+ inhibition kinetics in reduced system)
//   a_5 = 20.0      (Ca2+ activation kinetics)
//   d_1 = 0.13      (IP3 dissociation constant, low Ca2+ inhibition)
//   d_2 = 1.049     (Ca2+ inhibition, high-IP3 context; not used here)
//   d_3 = 0.9434    (IP3 dissociation constant, high Ca2+ inhibition)
//   d_4 = 0.1445    (Ca2+ inhibition dissociation)
//   d_5 = 0.08234   (Ca2+ activation dissociation)
//
// For illustration, [IP3] is fixed in the oscillatory range:
//   IP3 = 0.5 µM, giving oscillations like Fig. 4A in the paper.

model DeYoungKeizer1992_IP3R_SinglePool_Reduced

  // Compartment (dimensionless; all concentrations in µM)
  compartment cyt = 1;

  // Species
  species Ca   in cyt;
  species x000 in cyt;
  species x001 in cyt;
  species x010 in cyt;

  // --------------------
  // Parameters
  // --------------------
  // Ca2+ pool & flux parameters
  const c_0 = 2.0;
  const c_1 = 0.185;
  const v_1 = 6.0;
  const v_2 = 0.11;
  const v_3 = 0.9;
  const k_3 = 0.1;

  // Receptor kinetic parameters (reduced system)
  const a_4 = 0.2;
  const a_5 = 20.0;
  const d_1 = 0.13;
  const d_3 = 0.9434;
  const d_4 = 0.1445;
  const d_5 = 0.08234;

  // Fixed IP3 concentration (oscillatory regime)
  const IP3 = 0.5;

  // --------------------
  // Algebraic helper variables
  // --------------------

  // ER Ca2+ from conservation c_0 = c_1 * Ca_ER + Ca
  Ca_ER := (c_0 - Ca)/c_1;

  // IP3-bound subunit states via rapid equilibrium:
  // x_110 = (IP3/d_1) * x010  → open subunit fraction
  x_110 := (IP3/d_1) * x010;

  // Overall channel open probability (all 3 subunits in S_110)
  p_open := x_110^3;

  // Ca2+ fluxes
  J_1 := c_1 * ( v_1 * p_open + v_2 ) * (Ca_ER - Ca);
  J_2 := v_3 * Ca^2 / (Ca^2 + k_3^2);

  // Subunit state x011 via full-state conservation:
  // Sum over all 8 states = 1, with x1ik = (IP3/d_j) x0ik.
  // Total = (1 + IP3/d_1)*(x000 + x010) + (1 + IP3/d_3)*(x001 + x011) = 1.
  x_011 := (1 - (x000*(1 + IP3/d_1) + x001*(1 + IP3/d_3) + x010*(1 + IP3/d_1))) / (1 + IP3/d_3);

  // Receptor Ca2+-dependent transition fluxes
  V_1 := a_4 * (Ca * x000 - d_4 * x001);
  V_2 := a_4 * (Ca * x010 - d_4 * x_011);
  V_3 := a_5 * (Ca * x000 - d_5 * x010);
  V_4 := a_5 * (Ca * x001 - d_5 * x_011);

  // --------------------
  // ODEs
  // --------------------

  // Cytosolic Ca2+
  Ca'   = J_1 - J_2;

  // Subunit states (IP3-unbound; IP3-bound ones slaved via equilibrium)
  x000' = - V_1 - V_3;
  x001' =   V_1 - V_4;
  x010' =   V_3 - V_2;
  // x011 has no explicit ODE; it is set algebraically via conservation.

  // --------------------
  // Initial conditions
  // --------------------
  // These are reasonable, not unique; any normalized distribution with
  // 0 <= x000,x001,x010,x011 <= 1 is acceptable. They’re chosen so that
  // x011 lies between 0 and 1 and p_open > 0 at t=0.

  Ca   = 0.1;
  x000 = 0.05;
  x001 = 0.02;
  x010 = 0.05;
  // x011 is computed from the conservation rule above.

end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Dreisigmeyer2008_LacOperon_Lactose_uM.ant
//
// Use µM everywhere for concentrations:
//   l, a, z, l_ext, K_i, K_m_l, K_m_a, eps, c, K_z  are all in µM
//
// Conversions applied:
//   nM -> µM : divide by 1000
//   mM -> µM : multiply by 1000
//
// Rates (min^-1) and dimensionless parameters unchanged.

model Dreisigmeyer2008_LacOperon_Lactose_uM

  // Compartment (dimensionless volume)
  compartment cell = 1;

  // State variables (µM)
  species l in cell;
  species a in cell;
  species z in cell;

  // External lactose (constant input; µM)
  // Original example: 1.0 mM -> 1000 µM
  const l_ext = 1000.0;

  // -----------------------------
  // Parameters
  // -----------------------------

  // Growth dilution
  const growth_rate = 0.02;

  // Permease transport
  const alpha = 600.0;
  const phi   = 0.5;

  // Michaelis constants / saturation constants (µM)
  // Original K_i = 5.0e5 nM -> 500 µM
  const K_i   = 500.0;

  // β-galactosidase lactose metabolism
  const beta  = 2.85e4;
  const nu    = 0.468;
  // Original K_m_l = 2.53 mM -> 2530 µM
  const K_m_l = 2530.0;

  // β-galactosidase allolactose metabolism
  const delta = 2.30e4;
  // Original K_m_a = 1.2 mM -> 1200 µM
  const K_m_a = 1200.0;

  // β-gal expression parameters (µM)
  // Original eps = 34285 nM -> 34.285 µM
  const eps    = 34.285;
  // Original c = 34.3 nM -> 0.0343 µM
  const c      = 0.0343;
  // Original K_z = 1.05e5 nM -> 105 µM
  const K_z    = 105.0;
  const n_Hill = 2.0;

  // -----------------------------
  // ODEs
  // -----------------------------

  // Internal lactose l (µM)
  l' =  alpha * z * (l_ext - phi*l) / (K_i + l + l_ext) - beta * z * l / ((1 + a/K_m_a) * (K_m_l + l)) - growth_rate * l;

  // Allolactose a (µM)
  a' =  nu * beta * z * l / ((1 + a/K_m_a) * (K_m_l + l)) - delta * z * a / ((1 + l/K_m_l) * (K_m_a + a)) - growth_rate * a;

  // β-galactosidase z (µM)
  z' =  c * growth_rate + eps * growth_rate * a^n_Hill / (K_z^n_Hill + a^n_Hill) - growth_rate * z;

  // -----------------------------
  // Initial conditions (µM)
  // -----------------------------
  // Uninduced baseline
  l = 0.0;
  a = 0.0;
  z = c;

end
// @SIM T_START=0 T_END=20 N_STEPS=200 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.// Fink2000_BK_CaWave_WellMixed.ant
//
// Source:
//   Fink CC, Slepchenko B, Moraru II, Watras J, Schaff JC, Loew LM (2000)
//   "An image-based model of calcium waves in differentiated
//    neuroblastoma cells."
//   Biophys J 79:163–183.
//
// This is a spatially lumped (well-mixed) ODE version of the
// image-based PDE model described in the Appendix:
//   - InsP3 dynamics: Eqs. (1–2)
//   - Ca2+ dynamics: Eq. (3)
//   - IP3R channel flux: Eq. (4)
//   - h-gate dynamics: Eq. (5)
//   - SERCA pump: Eq. (6)
//   - ER leak: Eq. (7)
// with parameter values from Tables 2–4.
//
// State variables:
//   Ca   : cytosolic free [Ca2+] (µM)
//   IP3  : cytosolic [InsP3]      (µM)
//   h    : IP3R inactivation gate (0–1)
//
// Geometry, diffusion, detailed buffering, and explicit membrane
// boundary conditions are collapsed into effective parameters.
//

model Fink2000_BK_CaWave_WellMixed

  // Compartment
  compartment cyt = 1;

  // Species (state variables)
  species Ca  in cyt;
  species IP3 in cyt;
  species h   in cyt;

  // -------------------------
  // Parameters (from Tables 2–4)
  // -------------------------

  // InsP3 production & degradation (Eqs. 1–2)
  const J_0     = 20.86;
  const k_0     = 1.188;
  const k_degr  = 0.14;
  const IP3_0   = 0.16;

  // IP3R channel (Eq. 4)
  const J_max   = 3500;
  const K_IP3   = 0.8;
  const K_act   = 0.3;
  const K_inh   = 0.2;
  const k_on    = 2.7;

  // SERCA pump (Eq. 6)
  const V_max   = 3.75;
  const K_p     = 0.27;

  // ER leak (Eq. 7)
  const L      = 0.1;
  const Ca_ER  = 400;

  // Effective ER density scaling (a = a0 * f; here f≈1 averaged)
  const a      = 1.41;

  // Plasma membrane extrusion (Eq. 9 → lumped)
  const g_0    = 8.0;
  const Ca_c   = 0.2;
  const eps_pm = 0.01;

  // -------------------------
  // Helper functions
  // -------------------------

  // IP3R steady activation term m_inf(IP3, Ca)
  m_inf := (IP3/(IP3 + K_IP3)) * (Ca/(Ca + K_act));

  // IP3R channel flux (Li–Rinzel–type form; Eq. 4)
  J_channel := J_max * m_inf * h^3 * (1 - Ca/Ca_ER);

  // SERCA pump flux (Eq. 6)
  J_pump := V_max * Ca^2 / (Ca^2 + K_p^2);

  // ER leak flux (Eq. 7)
  J_leak := L * (1 - Ca/Ca_ER);

  // Plasma membrane extrusion, with threshold Ca_c (Eq. 9 lumped)
  // Smooth approximation of max(0, g_0*(Ca - Ca_c)) using sqrt
  // This is C∞ smooth and matches the original within eps_pm
  J_pm := 0.5 * g_0 * ((Ca - Ca_c) + sqrt((Ca - Ca_c)^2 + eps_pm^2));

  // Time-dependent InsP3 production at the membrane (Eqs. 1–2 lumped)
  J_prod_IP3 := J_0 * exp(-k_0 * time);

  // -------------------------
  // ODEs
  // -------------------------

  // Cytosolic InsP3
  IP3' = J_prod_IP3 - k_degr * (IP3 - IP3_0);

  // IP3R inactivation gate h (Eq. 5)
  h'   = k_on * (K_inh - (Ca + K_inh)*h);

  // Cytosolic Ca2+ (Eq. 3 without diffusion; buffers folded into a)
  Ca'  = a * (J_channel - J_pump + J_leak) - J_pm;

  // -------------------------
  // Initial conditions
  // -------------------------
  // From Table 3 and text:
  //   Ca(0) = 0.05 µM
  //   IP3(0) = IP3_0 = 0.16 µM
  //   h(0) = K_inh / (Ca(0) + K_inh) ≈ 0.8

  Ca  = 0.05;
  IP3 = IP3_0;
  h   = 0.8;

end
// @SIM T_START=0 T_END=2 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Gardner2000_ToggleSwitch.ant
//
// Source:
//   Gardner TS, Cantor CR, Collins JJ (2000)
//   "Construction of a genetic toggle switch in Escherichia coli."
//   Nature 403:339–342. doi:10.1038/35002131
//
// Implementation based on the curated BioModels entry BIOMD0000000507
// (JSim model "Gardner2000 - genetic toggle switch in E.coli").
//
// State variables:
//   R1 : concentration of repressor 1 (e.g. LacI)
//   R2 : concentration of repressor 2 (e.g. TetR)
//
// Dimensionless ODEs:
//   dR1/dt = alpha_1 / (1 + R2^{n_2}) - k_deg1 * R1
//   dR2/dt = alpha_2 / (1 + R1^{n_1}) - k_deg2 * R2
//
// Parameters from BIOMD0000000507:
//   alpha_1 = 156.25   (effective synthesis rate of repressor 1)
//   alpha_2 = 15.6     (effective synthesis rate of repressor 2)
//   n_2     = 2.5      (cooperativity of repression of promoter 2)
//   n_1     = 1.0      (cooperativity of repression of promoter 1)
//   k_deg1 = k_deg2 = 1  (degradation/dilution rates; set as time scale)
//
// Initial conditions (BioModels/JSim):
//   R1(0) = 0
//   R2(0) = 0

model Gardner2000_ToggleSwitch

  // Compartment
  compartment cell = 1;

  // Species (repressor concentrations)
  species R1 in cell;
  species R2 in cell;

  // Parameters
  const alpha_1 = 156.25;
  const alpha_2 = 15.6;
  const n_2     = 2.5;
  const n_1     = 1.0;
  const k_deg1  = 1.0;
  const k_deg2  = 1.0;

  // ODEs: mutually repressive toggle
  R1' = alpha_1 / (1 + R2^n_2) - k_deg1 * R1;
  R2' = alpha_2 / (1 + R1^n_1) - k_deg2 * R2;

  // Initial conditions (uninduced, both low)
  R1 = 0;
  R2 = 0;

end
// @SIM T_START=0 T_END=8 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Goldbeter1991_MinimalMitoticOscillator_Fig3.ant
//
// Goldbeter (1991) minimal mitotic oscillator
// Parameter set chosen to yield sustained oscillations (Fig. 3-style set).
//
// Notes on units:
// - C is in µM, time in minutes.
// - v_i is µM/min.
// - In the cyclin degradation term V_d * X * C/(K_d + C), V_d must have units µM/min
//   for dimensional consistency (common in published parameterizations).
// - M and X are fractions (0..1); K_1..K_4 are dimensionless “reduced” Michaelis constants.

model Goldbeter1991_MinimalMitoticOscillator_Fig3

  // Compartment
  compartment cell = 1;

  // State variables
  species C in cell;
  species M in cell;
  species X in cell;

  // ------------------------------------------------------------------
  // Oscillatory parameter set (Fig. 3-style)
  // ------------------------------------------------------------------

  // Cyclin synthesis and degradation
  const v_i  = 0.025;
  const V_d  = 0.25;
  const K_d  = 0.02;
  const k_d  = 0.01;

  // cdc2 activation–inactivation cycle
  const V_M1 = 3.0;
  const K_c  = 0.5;
  const K_1  = 0.005;
  const V_2  = 1.5;
  const K_2  = 0.005;

  // Protease activation–inactivation cycle
  const V_M3 = 1.0;
  const K_3  = 0.005;
  const V_4  = 0.5;
  const K_4  = 0.005;

  // Helper expressions
  V_1 := V_M1 * C / (K_c + C);
  V_3 := V_M3 * M;

  // ------------------------------------------------------------------
  // ODEs
  // ------------------------------------------------------------------

  // Cyclin
  C' = v_i - V_d * X * C / (K_d + C) - k_d * C;

  // Active cdc2 kinase
  M' = V_1 * (1 - M) / (K_1 + 1 - M) - V_2 * M / (K_2 + M);

  // Active cyclin protease
  X' = V_3 * (1 - X) / (K_3 + 1 - X) - V_4 * X / (K_4 + X);

  // ------------------------------------------------------------------
  // Initial conditions
  // ------------------------------------------------------------------
  C = 0.01;
  M = 0.01;
  X = 0.01;

end
// @SIM T_START=0 T_END=80 N_STEPS=800 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.// Kholodenko2000_MAPK_8species.ant
//
// Source:
//   Kholodenko BN (2000)
//   "Negative feedback and ultrasensitivity can bring about oscillations
//    in the mitogen-activated protein kinase cascades."
//   Eur J Biochem 267(6):1583–1588. PMID:10712587
//
// Implementation based on the curated SBML model BIOMD0000000010
// (BioModels) and the Morpheus MAPK_SBML.xml import.
//
// Species (all dimensionless concentration units):
//   MKKK,    MKKK_P   : level-1 kinase (unphosphorylated / phosphorylated)
//   MKK,     MKK_P,
//   MKK_PP             : level-2 kinase (0,1,2 phosphates)
//   MAPK,    MAPK_P,
//   MAPK_PP           : level-3 kinase (0,1,2 phosphates)
//
// Dynamics:
//   Michaelis–Menten-type activation/deactivation at each level,
//   with negative feedback from MAPK_PP on activation of MKKK
//   via the factor (1 + (MAPK_PP / Ki)^n) in the V1 term.
//
// This is the classic 8-ODE cascade used to demonstrate
// ultrasensitivity + negative feedback → sustained oscillations.

model Kholodenko2000_MAPK_8species

  // Compartment
  compartment cyt = 1;

  // Species
  species MKKK    in cyt;
  species MKKK_P  in cyt;
  species MKK     in cyt;
  species MKK_P   in cyt;
  species MKK_PP  in cyt;
  species MAPK    in cyt;
  species MAPK_P  in cyt;
  species MAPK_PP in cyt;

  // Parameters (from BIOMD0000000010 / Morpheus MAPK_SBML.xml)

  // Top level (MKKK)
  const V1  = 2.5;
  const K1  = 10;
  const V2  = 0.25;
  const KK2 = 8;
  const Ki  = 9;
  const n   = 1;

  // Middle level (MKK)
  const k3  = 0.025;
  const KK3 = 15;
  const k4  = 0.025;
  const KK4 = 15;
  const V5  = 0.75;
  const KK5 = 15;
  const V6  = 0.75;
  const KK6 = 15;

  // Bottom level (MAPK)
  const k7  = 0.025;
  const KK7 = 15;
  const k8  = 0.025;
  const KK8 = 15;
  const V9  = 0.5;
  const KK9 = 15;
  const V10 = 0.5;
  const KK10 = 15;

  // Compartment "volume" factor (just 1 here)
  const uVol = 1;

  // Helper: feedback term denominator 1 + (MAPK_PP / Ki)^n
  fb_den := 1 + (MAPK_PP / Ki)^n;

  // ODEs

  // Level 1: MKKK / MKKK_P
  MKKK'   = - V1 * MKKK / (fb_den * (K1 + MKKK)) + V2 * MKKK_P / (KK2 + MKKK_P);

  MKKK_P' =   V1 * MKKK / (fb_den * (K1 + MKKK)) - V2 * MKKK_P / (KK2 + MKKK_P);

  // Level 2: MKK, MKK_P, MKK_PP
  MKK'    = - k3 * MKKK_P * MKK / (KK3 + MKK) + V6 * MKK_P / (KK6 + MKK_P);

  MKK_P'  = k3 * MKKK_P * MKK / (KK3 + MKK) - uVol * k4 * MKKK_P * MKK_P / (KK4 + MKK_P) + uVol * V5 * MKK_PP / (KK5 + MKK_PP) - V6 * MKK_P / (KK6 + MKK_P);

  MKK_PP' =   k4 * MKKK_P * MKK_P / (KK4 + MKK_P) - V5 * MKK_PP / (KK5 + MKK_PP);

  // Level 3: MAPK, MAPK_P, MAPK_PP
  MAPK'   = - k7 * MKK_PP * MAPK / (KK7 + MAPK) + V10 * MAPK_P / (KK10 + MAPK_P);

  MAPK_P' = k7 * MKK_PP * MAPK / (KK7 + MAPK) - k8 * MKK_PP * MAPK_P / (KK8 + MAPK_P) + uVol * V9 * MAPK_PP / (KK9 + MAPK_PP) - V10 * MAPK_P / (KK10 + MAPK_P);

  MAPK_PP'=   k8 * MKK_PP * MAPK_P / (KK8 + MAPK_P) - V9 * MAPK_PP / (KK9 + MAPK_PP);

  // Initial conditions (from BIOMD0000000010 / Morpheus MAPK_SBML.xml)
  MKKK    = 90;
  MKKK_P  = 10;
  MKK     = 280;
  MKK_P   = 10;
  MKK_PP  = 10;
  MAPK    = 280;
  MAPK_P  = 10;
  MAPK_PP = 10;

end
// @SIM T_START=0 T_END=200 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Krishna2006_NFkB_3Variable_Core.ant
//
// Core NF-κB feedback loop reduced from the Hoffmann et al. (2002)
// IκB–NF-κB signaling module.
//
// Source (reduction):
//   Krishna S, Jensen MH, Sneppen K (2006)
//   "Minimal model of spiky oscillations in NF-κB signaling."
//   Proc Natl Acad Sci USA 103:10840–10845.
//   (Parameter values taken from the Hoffmann et al. NF-κB module.)
//
// Original source module (full network):
//   Hoffmann A, Levchenko A, Scott ML, Baltimore D (2002)
//   "The IκB–NF-κB signaling module: Temporal control and
//    selective gene activation."
//   Science 298:1241–1245.
//
// Variables (dimensionless):
//   Nn : nuclear NF-κB (normalized concentration)
//   Im : IκB mRNA (normalized)
//   I  : cytoplasmic IκB (normalized)
//
// ODEs (Krishna et al., eqs. (1a–c)):
//   dNn/dt = A * (1 - Nn)/(eps + I) - B * I * Nn / (delta + Nn)
//   dIm/dt = Nn^2 - Im
//   dI/dt  = Im - C * (1 - Nn) * I / (eps + I)
//
// Parameter set for sustained spiky oscillations (Fig. 2):
//   A     = 0.007
//   B     = 954.5
//   C     = 0.035
//   delta = 0.029
//   eps   = 2e-5
//
// Time unit: minutes (inherited from Hoffmann et al.).
//
// Initial conditions: not specified in the paper; here we choose
//   Nn(0) = 0, Im(0) = 0, I(0) = 0
// as a simple OFF-like starting point. Any point in the basin of
// the limit cycle is acceptable for testing.

model Krishna2006_NFkB_3Variable_Core

  // Compartment
  compartment cell = 1;

  // State variables (dimensionless)
  species Nn in cell;
  species Im in cell;
  species I  in cell;

  // Parameters (dimensionless)
  const A     = 0.007;
  const B     = 954.5;
  const C     = 0.035;
  const delta = 0.029;
  const eps   = 2e-5;

  // ODEs

  // Nuclear NF-κB
  Nn' = A * (1 - Nn)/(eps + I) - B * I * Nn/(delta + Nn);

  // IκB mRNA
  Im' = Nn^2 - Im;

  // Cytoplasmic IκB
  I'  = Im - C * (1 - Nn) * I/(eps + I);

  // Initial conditions (chosen)
  Nn = 0;
  Im = 0;
  I  = 0;

end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Lander2009_OE_p1_feedback.ant
//
// Source:
//   Lander AD, Gokoffski KK, Wan FYM, Nie Q, Calof AL (2009)
//   "Cell lineages and the logic of proliferative control."
//   PLoS Biol 7(1):e1000015. doi:10.1371/journal.pbio.1000015
//
// Model type:
//   Unbranched 3-stage cell lineage (stem -> INP -> ORN) with
//   negative feedback from ORNs onto the INP replication probability p1.
//   This corresponds to the OE example with feedback on p1 in Fig. 3D/E.
//
// State variables (species):
//   X_0 : stem cells (Sox2+/Mash1+), normalized to initial stem-cell pool
//   X_1 : INPs (transit-amplifying Ngn1+ progenitors)
//   X_2 : ORNs (terminally differentiated neurons)
//
// Parameters (from Fig. 3E caption, with v_1 set as time scale):
//   p_0   : stem-cell replication probability
//   p_1   : baseline INP replication probability
//   v_0   : stem-cell division rate (v_0/v_1 = 0.506)
//   v_1   : INP division rate (set to 1.0)
//   d     : ORN death rate (d/v_1 = 0.0138)
//   g     : feedback gain on p_1 (p_1eff = p_1 / (1 + g*X_2))
//
// Scenario:
//   Regeneration after ORN ablation.
//   At t = 0, ORNs are removed (X_2 = 0), stem pool normalized (X_0 = 1),
//   and X_1 is near its steady-state value for this parameter set.

model Lander2009_OE_p1_feedback

  // Compartments
  compartment tissue = 1;

  // Species: cell numbers (scaled)
  species X_0 in tissue;
  species X_1 in tissue;
  species X_2 in tissue;

  // Parameters (Fig. 3E)
  const p_0 = 0.5;
  const p_1 = 0.942;
  const v_0 = 0.506;
  const v_1 = 1.0;
  const d   = 0.0138;
  const g   = 0.0449;

  // Effective INP replication probability (feedback from ORNs)
  p_1eff := p_1/(1 + g*X_2);

  // ODEs (rate rules)
  // X_0: stem cells
  X_0' = (2*p_0 - 1)*v_0*X_0;

  // X_1: INPs
  X_1' = 2*(1 - p_0)*v_0*X_0 + (2*p_1eff - 1)*v_1*X_1;

  // X_2: ORNs
  X_2' = 2*(1 - p_1eff)*v_1*X_1 - d*X_2;

  // Initial conditions
  // X_0 normalized to 1 (initial stem-cell pool)
  X_0 = 1;

  // X_1 chosen near steady state for this parameter set
  // (approximate solution of steady-state equations with feedback)
  X_1 = 0.7916;

  // ORNs ablated at t = 0 (regeneration experiment)
  X_2 = 0;

end
// @SIM T_START=0 T_END=12 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// LevBarOr2000_p53_Mdm2.ant
//
// Source:
//   Lev Bar-Or R, Maya R, Segel LA, Alon U, Levine AJ, Oren M (2000)
//   "Generation of oscillations by the p53–Mdm2 feedback loop:
//    A theoretical and experimental study."
//   Proc Natl Acad Sci USA 97(21):11250–11255.
//   doi:10.1073/pnas.210171597
//
// Model summary (Eqs. 1–7):
//   p53(t)       : p53 protein level (arbitrary units, scaled to basal)
//   Mdm2(t)      : Mdm2 protein level (arbitrary units, scaled to basal)
//   I(t)         : intermediary for delayed p53-dependent Mdm2 induction
//   signal(t)    : p53-activating damage signal
//   threshold(t) : delayed threshold that damps inhibition of degradation
//
// ODEs (with '·' written as '*'):
//   dp53/dt = source_p53
//             - p53 * Mdm2 * degradation
//             - dp53 * p53                      (Eq. 1)
//
//   dMdm2/dt = p1
//              + p2max * I^n / (Km^n + I^n)    (Hill-type Mdm2 induction)
//              - dMdm2 * Mdm2                  (Eq. 2)
//
//   dI/dt = activity * p53 - kdelay * I        (Eq. 3)
//
//   activity = c1 * signal / (1 + c2 * Mdm2 * p53)   (Eq. 4)
//
//   d(signal)/dt = - repair * signal          (Eq. 5)
//
//   degradation = degradation_basal - (kdeg * signal - threshold)   (Eq. 6)
//
//   d(threshold)/dt = - kdamp * threshold * signal0,
//   with threshold(0) = kdeg * signal0, signal0 = signal(t=0).      (Eq. 7)
//
// Parameter set and initial conditions are taken from the Fig. 2 caption.
//
//   source_p53      = 0.5
//   dp53            = 2.5e-4
//   p1              = 2.35e-3
//   p2max           = 0.03
//   n               = 50
//   Km              = 25
//   dMdm2           = 0.05
//   c1              = 1.52e-2
//   c2              = 0.01
//   kdelay          = 1.52e-2
//   repair          = 1.0e-4
//   degradation_basal = 2.0
//   kdeg            = 1.93
//   kdamp           = 0.05
//
//   p53(0)          = 5.3
//   Mdm2(0)         = 0.047
//   signal(0)       = 1.0
//   I(0)            = 0.0   (not specified; taken as zero)
//   threshold(0)    = kdeg * signal(0) = 1.93
//
// All variables are dimensionless; time is in minutes (Fig. 2 axes).

model LevBarOr2000_p53_Mdm2

  // Compartment
  compartment cell = 1;

  // Species (state variables)
  species p53       in cell;
  species Mdm2      in cell;
  species I         in cell;
  species signal    in cell;
  species threshold in cell;

  // ------------------------
  // Parameters
  // ------------------------

  // p53 synthesis & degradation
  const source_p53        = 0.5;
  const d_p53             = 2.5e-4;

  // Mdm2 production & degradation
  const p_1               = 2.35e-3;
  const p_2max            = 0.03;
  const n                 = 50;
  const K_m               = 25;
  const d_Mdm2            = 0.05;

  // Activity / delay parameters
  const c_1               = 1.52e-2;
  const c_2               = 0.01;
  const k_delay           = 1.52e-2;

  // Damage signal decay
  const repair            = 1.0e-4;

  // Degradation modulation
  const degradation_basal = 2.0;
  const k_deg             = 1.93;
  const k_damp            = 0.05;

  // Initial damage level used as constant signal_0 in Eq. 7
  const signal_0          = 1.0;

  // ------------------------
  // Helper expressions (algebraic rules)
  // ------------------------

  // p53 transcriptional activity
  activity := c_1 * signal / (1 + c_2 * Mdm2 * p53);

  // Effective p53 degradation strength
  degradation := degradation_basal - (k_deg * signal - threshold);

  // ------------------------
  // ODEs
  // ------------------------

  // p53 protein
  p53' = source_p53 - p53 * Mdm2 * degradation - d_p53 * p53;

  // Mdm2 protein (Hill function inlined: I^n / (K_m^n + I^n))
  Mdm2' = p_1 + p_2max * I^n / (K_m^n + I^n) - d_Mdm2 * Mdm2;

  // Intermediary I (delayed p53-dependent Mdm2 induction)
  I' = activity * p53 - k_delay * I;

  // Damage signal
  signal' = - repair * signal;

  // Threshold damping the inhibition of p53 degradation
  threshold' = - k_damp * threshold * signal_0;

  // ------------------------
  // Initial conditions (Fig. 2)
  // ------------------------

  p53       = 5.3;
  Mdm2      = 0.047;
  signal    = signal_0;
  I         = 0.0;
  threshold = k_deg * signal_0;

end
// @SIM T_START=0 T_END=400 N_STEPS=800 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Lipniacki2006_Autorepression_2D.ant
//
// Source:
//   Lipniacki T, Paszek P, Marciniak-Czochra A, Brasier AR, Kimmel M (2006)
//   "Transcriptional stochasticity in gene expression."
//   J Theor Biol 238(2):348–367. doi:10.1016/j.jtbi.2005.05.032
//
// Deterministic (thermodynamic) limit of a stochastically regulated
// auto-repressive gene with n copies.
//
// Scaled variables (cf. Eqs. (7–10), (15–16) in the paper):
//   x(t) : normalized mRNA level
//   y(t) : normalized protein level
//
// ODEs (thermodynamic limit):
//   dx/dt = -x + n*c / (c + b*y)
//   dy/dt =  r*(x - y)
//
// Here we take the "near thermodynamic limit" parameter set used
// in their Fig. 4: n = 1, c = 6, b = 3, r = 0.2.
//
// This gives a 2D, rational-feedback negative autoregulation system,
// directly traceable to Lipniacki et al.'s analysis of stochastic
// gene expression, but purely deterministic and small enough for
// S-system / GMA recasting stress tests.

model Lipniacki2006_Autorepression_2D

  // Compartment
  compartment cell = 1;

  // State variables
  species x in cell;
  species y in cell;

  // Parameters (dimensionless, from example in the paper)
  const n = 1.0;
  const c = 6.0;
  const b = 3.0;
  const r = 0.2;

  // ODEs: deterministic limit of auto-repressive gene
  x' = -x + n*c / (c + b*y);
  y' =  r*(x - y);

  // Initial conditions (simple OFF-like start used in their examples)
  x = 0;
  y = 0;

end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// ManganAlon2003_CoherentFFL_AND.ant
//
// Source:
//   Mangan S, Alon U (2003)
//   "The coherent feedforward loop serves as a sign-sensitive delay
//    element in transcription networks."
//   J Mol Biol 334(2):197–204. doi:10.1016/j.jmb.2003.09.049
//
// Model:
//   Type-1 coherent feed-forward loop (AND gate at Z):
//     X activates Y;
//     X and Y jointly activate Z (AND logic).
//
//   ODEs (Materials and Methods):
//     dY/dt = By + b1 * f(X, Kxy) - a1 * Y
//     dZ/dt = b2 * f(X, Kxz) * f(Y, Kyz) - a2 * Z
//
//   with Hill activation:
//     f(u, K) = u^H / (K^H + u^H)
//
//   Simulation parameters used in Fig. 4(a,b):
//     a1 = a2 = 1
//     b1 = b2 = 1
//     H = 2
//     Kxy = Kxz = Kyz = 0.5
//     By = 0
//   The stimulus Sx is represented by X = 1 (ON) or X = 0 (OFF).
//
//   This is a 2-dimensional nonlinear ODE with Hill-type terms;
//   X is treated here as a constant input parameter.

model ManganAlon2003_CoherentFFL_AND

  // Compartment
  compartment cell = 1;

  // Species (state variables)
  species Y in cell;
  species Z in cell;

  // Input transcription factor X (treated as constant stimulus Sx)
  const X = 1;

  // Parameters (Fig. 4 parameter set)
  const B_y   = 0;
  const b_1   = 1;
  const b_2   = 1;
  const a_1   = 1;
  const a_2   = 1;
  const H     = 2;
  const K_xy  = 0.5;
  const K_xz  = 0.5;
  const K_yz  = 0.5;

  // ODEs (Hill activation inlined: f(u, K) = u^H / (K^H + u^H))
  
  // Y: activated by X, with basal production B_y
  Y' = B_y + b_1 * X^H / (K_xy^H + X^H) - a_1 * Y;

  // Z: AND gate of X and Y (product of two Hill activations)
  Z' = b_2 * (X^H / (K_xz^H + X^H)) * (Y^H / (K_yz^H + Y^H)) - a_2 * Z;

  // Initial conditions
  // Not fixed in the paper; natural choice is near-zero expression
  // before an ON step of X. Using 0.01 (well below K thresholds of 0.5)
  // to avoid numerical issues with negative exponents in recast.
  Y = 0.01;
  Z = 0.01;

end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// McMillen2002_RelaxationOscillator.ant
//
// Source:
//   McMillen D, Kopell N, Hasty J, Collins JJ (2002)
//   "Synchronizing genetic relaxation oscillators by intercell signaling."
//   Proc Natl Acad Sci USA 99(2):679–684. doi:10.1073/pnas.0226422999
//
// Model:
//   Single genetic relaxation oscillator with quorum-sensing feedback,
//   dimensionless form (Eqs. 4–7). Variables:
//     x : CII (autocatalytic activator)
//     y : FtsH (protease for CII)
//     l : LuxI (AI synthase)
//     a : intracellular autoinducer (AI)
//   Time τ is already nondimensionalized.
//
// For a single synchronized oscillator we approximate
//   a_e = Q * a
// so that the intracellular AI dynamics reduce to the same form
// used for a synchronized population in the paper.
//
// ============================================================================
// PATHOLOGICAL CASE: MANIFOLD DRIFT IN RECAST
// ============================================================================
//
// The S-system recast of this model exhibits severe manifold drift.
// While the recast is algebraically exact (passes symbolic and numerical
// pointwise validation), trajectory integration diverges over time.
//
// ROOT CAUSE: LIFTED RATIONAL FUNCTIONS
//
// The original ODEs contain rational Hill-type terms:
//   - (1 + alpha*x^4) / (1 + x^4)   (PRE promoter activation)
//   - (1 + beta*a^2) / (1 + a^2)    (lux promoter activation)
//
// S-system recasting lifts these denominators to auxiliary variables:
//   - Y_1 := 1 + x^4        (denominator of PRE Hill term)
//   - Y_2 := 1 + a^2        (denominator of lux Hill term)
//
// Each auxiliary gets an ODE derived via chain rule:
//   - Y_1' = 4*x^3 * x'     (correct derivative of 1 + x^4)
//   - Y_2' = 2*a * a'       (correct derivative of 1 + a^2)
//
// THE MANIFOLD DRIFT PROBLEM:
//
// The algebraic constraints Y_1 = 1 + x^4 and Y_2 = 1 + a^2 define
// constraint manifolds in the extended state space. On these manifolds,
// the original and recast dynamics are EXACTLY equivalent.
//
// However, numerical integration accumulates small errors at each timestep.
// These errors cause the trajectory to drift OFF the constraint manifold:
//   - Y_1 ≠ 1 + x^4 (deviation grows with time)
//   - Y_2 ≠ 1 + a^2 (deviation grows with time)
//
// Once off the manifold, the recast dynamics no longer match the original.
// This is classic "MANIFOLD DRIFT" - a well-known problem in differential-
// algebraic systems (DAEs) when constraints are differentiated.
//
// VALIDATION RESULTS:
//    - Symbolic equivalence: PASS (Δ ≡ 0 on the constraint manifold)
//    - Numerical pointwise: PASS (max error ~1e-16 when constraints enforced)
//    - Trajectory comparison: FAIL (99% error by t=7.67 due to drift)
//
// MITIGATION STRATEGIES (not implemented in ssys):
//    1. ASSIGNMENT RULES: Output Y_1 := 1 + x^4 as algebraic constraints
//       instead of ODEs. This prevents drift but changes the model structure.
//    2. MANIFOLD PROJECTION: Periodically re-project the trajectory back
//       onto the constraint manifold during integration.
//    3. DAE SOLVERS: Use differential-algebraic equation solvers that
//       enforce algebraic constraints natively (e.g., IDA from SUNDIALS).
//    4. STABILIZATION: Add drift-correction terms to the auxiliary ODEs
//       that push the trajectory back toward the manifold.
//
// REFERENCES:
//    - Ascher, U. M., & Petzold, L. R. (1998). Computer Methods for ODEs
//      and DAEs. SIAM. Chapter 10: Differential-Algebraic Equations.
//    - Hairer, E., & Wanner, G. (1996). Solving ODEs II: Stiff and DAE
//      Problems. Springer. Chapter VII: Constrained Systems.
//
// ============================================================================

//----------------------------
// Model
//----------------------------
model McMillen2002_RelaxationOscillator

  // Compartment
  compartment cell = 1;

  // Species (dimensionless concentrations)
  species x in cell;
  species y in cell;
  species l in cell;
  species a in cell;

  // Parameters (dimensionless; from parameter discussion in the paper)
  // Hill nonlinearities
  const alpha  = 600;
  const beta   = 10;

  // Production / copy-number prefactors
  const m_x    = 10;
  const m_y    = 1;
  const mu_x   = 50;
  const mu_l   = 50;

  // Degradation / dilution rates
  const gamma_x  = 0.5;
  const gamma_y  = 0.5;
  const gamma_l  = 25;
  const gamma_a  = 0.2;

  // Proteolytic degradation of x by y
  const gamma_xy = 5;

  // AI synthesis / transport
  const mu_a   = 0.4;
  const D_a    = 120;
  const Q      = 0.6;

  // Effective extracellular AI level for a synchronized population
  a_e := Q * a;

  //----------------------------
  // ODEs (dimensionless time τ)
  //----------------------------
  // Note: Hill functions f(x) and g(a) are inlined directly
  // f(x) = (1 + alpha*x^4) / (1 + x^4)  (PRE promoter activated by CII)
  // g(a) = (1 + beta*a^2) / (1 + a^2)   (lux promoter activated by AI)

  // CII (x)
  x' = m_x * (1 + alpha*x^4) / (1 + x^4) - gamma_xy * x * y - gamma_x * x + mu_x * (1 + beta*a^2) / (1 + a^2);

  // FtsH (y)
  y' = m_y * (1 + alpha*x^4) / (1 + x^4) - gamma_y * y;

  // LuxI (l)
  l' = mu_l * (1 + alpha*x^4) / (1 + x^4) - gamma_l * l;

  // Intracellular AI (a)
  // Exchange with extracellular AI ~ D_a * (a_e - a)
  a' = mu_a * l - D_a * (a - a_e) - gamma_a * a;

  //----------------------------
  // Initial conditions
  //----------------------------
  // The paper does not fix specific numeric ICs; here we choose a simple
  // non-negative state that reliably converges to the relaxation limit cycle.
  x = 0;
  y = 0;
  l = 0;
  a = 0;

end
// @SIM T_START=0 T_END=0.1 N_STEPS=100 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Mueller2006_RepLeaky_n3.ant
//
// Source:
//   Müller S, Hofbauer J, Endler L, Flamm C, Widder S, Schuster P (2006)
//   "A generalized model of the repressilator."
//   J Math Biol 53:905–937. doi:10.1007/s00285-006-0035-9
//
// Model:
//   "RepLeaky" repressilator (leaky transcription, cooperative repression),
//   rescaled form for free protein (x_i) and mRNA (y_i) concentrations,
//   with n = 3 identical genes in a cycle.
//   This is Eq. (52) specialized with F(x) from Eq. (23b) and M(x) from Eq. (53)
//   in the paper.
//
// State variables (species):
//   x1, x2, x3 : free protein concentrations (dimensionless)
//   y1, y2, y3 : mRNA concentrations (dimensionless)
//
// Parameters:
//   delta  : leakiness δ (ratio of repressed to unrepressed transcription)
//   h      : Hill coefficient in s(x) = x^h / (1 + x^h)
//   alpha  : combined production parameter α
//   beta   : degradation ratio β = d_P / d_R
//   gam    : binding parameter γ (strength of repressor binding)
//            (Note: 'gamma' is reserved in Antimony for the gamma function)
//
// Dynamics:
//   dx_i/dt = beta * (y_i - x_i) / M(x_i)
//   dy_i/dt = alpha * f(x_{i-1}) - y_i
//   with indices modulo 3, and
//   s(x)  = x^h / (1 + x^h)
//   f(x)  = (1 - delta) * (1 - s(x)) + delta
//   M(x)  = 1 + gamma * h * x^(h-1) / (1 + x^h)^2

model Mueller2006_RepLeaky_n3

  // Compartment
  compartment cell = 1;

  // Species: free proteins and mRNAs
  species x1 in cell;
  species x2 in cell;
  species x3 in cell;

  species y1 in cell;
  species y2 in cell;
  species y3 in cell;

  // Core parameters (dimensionless)
  const delta = 1.0e-3;
  const h     = 2;
  const alpha = 2.0;
  const beta  = 1.0;
  const gam   = 1.0;

  // Helper assignment rules
  // s_i = x_i^h / (1 + x_i^h)
  s1 := x1^h / (1 + x1^h);
  s2 := x2^h / (1 + x2^h);
  s3 := x3^h / (1 + x3^h);

  // f_i = (1 - delta) * (1 - s_i) + delta
  f1 := (1 - delta) * (1 - s1) + delta;
  f2 := (1 - delta) * (1 - s2) + delta;
  f3 := (1 - delta) * (1 - s3) + delta;

  // M_i = 1 + gam * h * x_i^(h-1) / (1 + x_i^h)^2
  M1 := 1 + gam * h * x1^(h - 1) / (1 + x1^h)^2;
  M2 := 1 + gam * h * x2^(h - 1) / (1 + x2^h)^2;
  M3 := 1 + gam * h * x3^(h - 1) / (1 + x3^h)^2;

  // ODEs for n = 3 (indices modulo 3: 1←3, 2←1, 3←2)

  // Proteins
  x1' = beta * (y1 - x1) / M1;
  x2' = beta * (y2 - x2) / M2;
  x3' = beta * (y3 - x3) / M3;

  // mRNAs
  y1' = alpha * f3 - y1;  // gene 1 repressed by protein 3
  y2' = alpha * f1 - y2;  // gene 2 repressed by protein 1
  y3' = alpha * f2 - y3;  // gene 3 repressed by protein 2

  // Initial conditions (not specified in the paper; chosen as a simple test case)
  x1 = 0.1;
  x2 = 0.2;
  x3 = 0.3;

  y1 = 0.1;
  y2 = 0.1;
  y3 = 0.1;

end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Ozbudak2004_LacOperon_Simplified.ant
//
// Source model:
//   Ozbudak EM, Thattai M, Lim HN, Shraiman BI, van Oudenaarden A (2004)
//   "Multistability in the lactose utilization network of Escherichia coli."
//   Nature 427:737–740. doi:10.1038/nature02298
//
// This is the standard reduced ODE model of the lac bistable switch,
// in the form summarized from their Supplementary Information:
//
//   dx/dt =  beta * y - x
//   dy/dt =  alpha / ( 1 + (rho - 1)/(1 + x^2) ) - y
//
// where:
//   x(t)  : intracellular TMG (dimensionless, scaled)
//   y(t)  : LacY permease level (relative expression)
//
// Parameters alpha, rho, beta are functions of extracellular glucose (G)
// and TMG (T). Here we fix them to a concrete set corresponding to
// no glucose and intermediate TMG in the bistable region, using the
// fitted forms reported for alpha(G), rho, and beta(T,G).

model Ozbudak2004_LacOperon_Simplified

  // Compartment (dimensionless)
  compartment cell = 1;

  // State variables
  species x in cell;
  species y in cell;

  // Parameters (from fits to Ozbudak et al. SI, for G = 0, T ≈ 30 mM)
  //
  // alpha(G) = 84.4 / (1 + (G/8.1)^1.2) + 16.1
  // rho      = 167.1
  // beta(T,G) = beta_T(T) * beta_G(G),
  //   beta_T(T) = 1.23e-3 * T^0.6, beta_G(G>10) ≈ 65
  //
  // For G = 0 mM and T = 30 mM, this gives approximately:
  //   alpha ≈ 100.5
  //   rho   = 167.1
  //   beta  ≈ 0.62
  //
  const alpha = 100.5;
  const rho   = 167.1;
  const beta  = 0.62;

  // Effective inhibition function from LacI, after eliminating R:
  //   1 + R/R0 = 1 + (rho - 1)/(1 + x^2)
  inhib := 1 + (rho - 1)/(1 + x^2);

  // ODEs
  // Intracellular TMG
  x' = beta * y - x;

  // LacY (permease) expression
  y' = alpha / inhib - y;

  // Initial conditions corresponding to an "uninduced" state:
  //   x(0) = 0 (no internal TMG)
  //   y(0) ≈ alpha/rho (basal expression)
  x = 0;
  y = alpha/rho;

end
// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Rosenfeld2002_NegativeAutoregulation_2D.ant
//
// Source:
//   Rosenfeld N, Elowitz MB, Alon U (2002)
//   "Negative autoregulation speeds the response times
//    of transcription networks."
//   J Mol Biol 323(5):785–793. doi:10.1016/S0022-2836(02)00994-4
//
// 2D model with explicit mRNA:
//   m(t) : mRNA for autorepressed gene
//   x(t) : autorepressor protein (TetR–GFP)
//
//   dm/dt = b_m / (1 + x/k) - a_m * m
//   dx/dt = b_p * m        - a_p * x
//
// Parameters chosen so that in the fast-mRNA limit (a_m ≫ a_p)
// the system reduces to the 1D model
//   dx/dt = b2 / (1 + x/k) - a * x
// with
//   a  = ln(2)    ≈ 0.6931
//   k  = 1
//   b_2 = 100*a   ≈ 69.31
//
// Mapping:
//   a_p = a
//   a_m = 5*a
//   b_p = 1
//   b_m = b_2 * a_m
// so that b_p * b_m / a_m = b_2.
//
// Initial conditions: no mRNA, no protein at induction.

model Rosenfeld2002_NegativeAutoregulation_2D

  // Compartment
  compartment cell = 1;

  // State variables
  species m in cell;
  species x in cell;

  // Core parameters
  const k   = 1.0;
  const a_p = 0.6931471805599453;
  const a_m = 3.4657359027997265;
  const b_2 = 69.31471805599453;

  // Derived parameters for 2D model
  const b_p = 1.0;
  const b_m = 240.22650695910073;

  // ODEs
  // mRNA: transcription repressed by x, first-order decay
  m' = b_m / (1 + x/k) - a_m * m;

  // Protein: produced from mRNA, diluted/degraded
  x' = b_p * m - a_p * x;

  // Initial conditions: OFF at induction
  m = 0;
  x = 0;

end
// @SIM T_START=0 T_END=6 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Samoilov2005_FutileCycle.ant
// Deterministic enzymatic futile cycle model from:
//   Samoilov M, Plyasunov S, Arkin AP (2005)
//   "Stochastic amplification and signaling in enzymatic futile cycles
//    through noise-induced bistability with oscillations."
//   Proc Natl Acad Sci USA 102(7):2310–2315. doi:10.1073/pnas.0406841102
//
// This is the underlying mass-action ODE system (no external noise)
// corresponding to the enzymatic futile cycle in Fig. 1 and the
// parameter set used in Fig. 3 of the paper (X, X*, E1, E2, C1, C2).
// Species are molecule counts; time units follow the paper's convention.
//
// ============================================================================
// PATHOLOGICAL CASE: SEVERE STIFFNESS IN RECAST
// ============================================================================
//
// The S-system recast of this model exhibits severe numerical stiffness.
// While the recast is algebraically exact (passes symbolic and numerical
// pointwise validation), trajectory integration fails due to stiffness.
//
// ROOT CAUSES:
//
// 1. RATE CONSTANT SPAN (inherent in chemistry):
//    - k1_r = 2e4 vs k1_f = 40 (500x ratio)
//    - k1_cat = 1e4, k2_cat = 5e3 (fast catalytic steps)
//    - This creates inherent fast/slow timescale separation.
//
// 2. POOL CONSTRUCTION WITH NEAR-ZERO INITIAL CONDITIONS:
//    - S-system recasting uses pool construction: each ODE term gets an
//      auxiliary variable X_t1, X_t2, etc., where X = X_t1 * X_t2 * ...
//    - The pool formula creates terms with NEGATIVE EXPONENTS like X_t1^(-1)
//      in the ODEs for other auxiliaries.
//    - When X(0) = 0.01 (near zero), the auxiliary X_t1 starts near zero.
//    - X_t1^(-1) then produces HUGE values, causing numerical instability.
//
// 3. STIFFNESS AMPLIFICATION:
//    - Original model: 6 species, mild stiffness from rate constant span
//    - Recast model: 18+ auxiliaries (3 terms per species × 6 species)
//    - Each auxiliary has negative exponents from other auxiliaries
//    - Eigenvalue spread is dramatically amplified
//
// VALIDATION RESULTS:
//    - Symbolic equivalence: PASS (Δ ≡ 0)
//    - Numerical pointwise: PASS (max error ~1e-16)
//    - Trajectory comparison: FAIL (stiffness causes solver failure or error)
//
// ============================================================================

model Samoilov2005_FutileCycle

  //-------- Compartments --------
  compartment cell = 1;

  //-------- Species (molecule numbers) --------
  species X in cell;        // unmodified substrate X
  species X_star in cell;   // modified substrate X*
  species E1 in cell;       // forward enzyme (X -> X*)
  species C1 in cell;       // E1–X complex
  species E2 in cell;       // reverse enzyme (X* -> X)
  species C2 in cell;       // E2–X* complex

  //-------- Parameters (from Fig. 3 caption) --------
  // "Reaction mechanism given in Expression 7" parameters:
  //   k1+ , k1− , k1_cat : forward branch (E1 + X ⇌ C1 → E1 + X*)
  //   k2+ , k2− , k2_cat : reverse branch (E2 + X* ⇌ C2 → E2 + X)
  //
  // All rate constants are in the same (paper's) units.

  const k1_f   = 40;        // k1+  (E1 + X -> C1)
  const k1_r   = 2e4;       // k1-  (C1 -> E1 + X)
  const k1_cat = 1e4;       // k1_cat (C1 -> E1 + X*)

  const k2_f   = 200;       // k2+  (E2 + X* -> C2)
  const k2_r   = 100;       // k2-  (C2 -> E2 + X*)
  const k2_cat = 5e3;       // k2_cat (C2 -> E2 + X)

  //-------- Reactions (Expression 7 mechanism) --------
  // Forward branch: X --(E1)--> X*
  R1: E1 + X  -> C1;             k1_f   * E1 * X;
  R2: C1      -> E1 + X;         k1_r   * C1;
  R3: C1      -> E1 + X_star;    k1_cat * C1;

  // Reverse branch: X* --(E2)--> X
  R4: E2 + X_star -> C2;         k2_f   * E2 * X_star;
  R5: C2         -> E2 + X_star; k2_r   * C2;
  R6: C2         -> E2 + X;      k2_cat * C2;

  //-------- Initial conditions (Fig. 3 simulation) --------
  // From the figure caption:
  //   E1(t=0) = 20
  //   E2(t=0) = 50
  //   X(t=0)  = 0
  //   X*(t=0) = 2000
  //   complexes start empty
  //
  // This choice fixes:
  //   total substrate X_tot = X + X* = 2000
  //   total enzymes E1_tot = E1 + C1 = 20
  //                     E2_tot = E2 + C2 = 50

  X       = 0.01;  // Perturbed from 0 to avoid numerical stiffness
  X_star  = 2000;
  E1      = 20;
  C1      = 0.01;  // Perturbed from 0 to avoid numerical stiffness in recast
  E2      = 50;
  C2      = 0.01;  // Perturbed from 0 to avoid numerical stiffness in recast

end
// @SIM T_START=0 T_END=0.0018 N_STEPS=180 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Sel'kov glycolytic oscillator (dimensionless form)
//   dx/dt = -x + a*y + x^2*y
//   dy/dt =  b - a*y - x^2*y
//
// Original biology & model:
//   E. E. Sel'kov, "Self-oscillations in glycolysis. I. A simple kinetic model,"
//   European Journal of Biochemistry 4:79–86, 1968.
//
// Example parameter set giving a stable limit cycle:
//   T. Das & M. Acharyya, "Transient behaviour towards the stable limit cycle
//   in the Selkov model of Glycolysis: A physiological disorder,"
//   arXiv:2005.09190, 2020 (they use a = 0.08, b = 0.6).

model Selkov_1968()

  // Species (dimensionless concentrations)
  species x, y;

  // Parameters
  a = 0.08;
  b = 0.6;

  // Dynamics (using prime notation for ssys parser)
  x' = -x + a*y + x^2*y;
  y' =  b - a*y - x^2*y;

  // Initial conditions (generic off-fixed-point start; adjust as needed)
  x = 1.0;
  y = 1.0;

end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// WeberRaymondMunsky2018_Model2_LambdaA.ant
//
// Source:
//   Weber L, Raymond W, Munsky B (2018)
//   "Identification of gene regulation models from single-cell data."
//   Physical Biology 15(5):055001.
//
// Deterministic 3-state promoter + mRNA model (Model 2):
//   States:
//     S1(t), S2(t), S3(t) : probabilities (fractions) of promoter
//                           being in states 1, 2, 3
//     R(t)               : mean mRNA copy number
//
//   ODEs (Eqs. 3–6):
//     dS1/dt = -k12(t)*S1 + k21(t)*S2
//     dS2/dt =  k12(t)*S1 - (k21(t) + k23(t))*S2 + k32(t)*S3
//     dS3/dt =  k23(t)*S2 - k32(t)*S3
//     dR/dt  =  k_r2*S2 + k_r3*S3 - gamma*R
//
//   Time-dependent input:
//     Y1(t) = 0,                                  t ≤ 5
//           = 1 - cos(2π t / 30),               5 < t < 70
//           = 0,                                  t ≥ 70
//
//   Only k23 is input-dependent in Model 2:
//     k23(t) = max(0, k23_0 + beta*Y1(t))
//   All other k_ij(t) are constant: k_ij(t) = k_ij(0).
//
//   Parameter set Λ_A (Model 2):
//     [k12_0, k23_0, k21_0, k32_0, k_r2, k_r3, beta, gamma]
//       = [3, -0.4, 2.5, 1, 9, 2, 1, 0.8]
//
//   Initial conditions (t = 0):
//     S1(0) = 1, S2(0) = 0, S3(0) = 0, R(0) = 0
//   (all promoters OFF, no mRNA)

model WeberRaymondMunsky2018_Model2_LambdaA

  // Constants and parameters
  // Note: 'pi' is a built-in constant in Antimony, no need to define it

  // Base transition rates k_ij(0)
  const k_12_0  = 3;
  const k_23_0  = -0.4;
  const k_21_0  = 2.5;
  const k_32_0  = 1;

  // Transcription and degradation parameters
  const k_r_2   = 9;
  const k_r_3   = 2;
  const beta    = 1;
  const gam     = 0.8;

  // Smooth approximation parameters
  const k_steep = 5.0;
  const eps_k   = 0.01;

  // Time-dependent input Y_1(t)
  // Smooth approximation of time window 5 < t < 70 using tanh sigmoids
  // H_on turns on at t=5, H_off turns off at t=70
  H_on  := 0.5*(1 + tanh(k_steep*(time - 5)));
  H_off := 0.5*(1 + tanh(k_steep*(70 - time)));
  Y_1   := (1 - cos(2*pi*time/30)) * H_on * H_off;

  // Effective transition rates
  k_12 := k_12_0;
  k_21 := k_21_0;
  k_32 := k_32_0;

  // k_23(t) = max(0, k_23_0 + beta*Y_1(t)) via smooth ReLU approximation
  k_23_raw := k_23_0 + beta*Y_1;
  k_23 := 0.5 * (k_23_raw + sqrt(k_23_raw^2 + eps_k^2));

  // ODEs (Promoter state probabilities and mean mRNA)
  S_1' = -k_12*S_1 + k_21*S_2;
  S_2' =  k_12*S_1 - (k_21 + k_23)*S_2 + k_32*S_3;
  S_3' =  k_23*S_2 - k_32*S_3;
  R'   =  k_r_2*S_2 + k_r_3*S_3 - gam*R;

  // Initial conditions
  S_1 = 1;
  S_2 = 0;
  S_3 = 0;
  R   = 0;

end
// @SIM T_START=0 T_END=100 N_STEPS=500 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
// Xiong2018_ThreeVariable_ContactKilling_Inhibitor.ant
//
// Source:
//   Xiong L, Cooper R, Tsimring LS (2018)
//   "Coexistence and Pattern Formation in Bacterial Mixtures
//    with Contact-Dependent Killing."
//   Biophys J 114:1741–1750.
//   This Antimony file uses the rescaled three-variable model
//   from the Supporting Material (Eqs. S21–S23) with diffusion
//   terms dropped (spatially homogeneous ODE version).
//
//   Equations (well-mixed; no ∇² terms):
//     dn_1/dt = (gamma_1/(1 + A))*n_1*(1 - n_1 - n_2) - delta*n_1 - kappa*n_1*n_2
//     dn_2/dt = n_2*(1 - n_1 - n_2) - delta*n_2
//     dA/dt   = gamma_A*n_1 - delta_A*A
//
//   n_1, n_2 : rescaled local densities of strains 1 and 2 (0–1 range)
//   A        : rescaled inhibitor concentration
//
//   Parameter set from Movies 1–2 and Fig. S5/S6 of the SI:
//     gamma_1 = 4.5
//     delta   = 0.01
//     kappa   = 0.03
//     gamma_A = 0.04
//     delta_A = 0.02
//   (gamma_2 has been scaled to 1 in these variables.)
//
//   The paper uses random spatial initial conditions; here we pick
//   concrete homogeneous ICs inside the carrying capacity (n_1 + n_2 < 1)
//   for ODE testing.
//------------------------------------------------------------------

model Xiong2018_ThreeVariable_ContactKilling_Inhibitor

  // Compartment (dimensionless volume)
  compartment env = 1;

  // State variables (species)
  species n_1 in env;
  species n_2 in env;
  species A   in env;

  // Parameters (rescaled, from SI)
  const gamma_1 = 4.5;
  const delta   = 0.01;
  const kappa   = 0.03;

  const gamma_A = 0.04;
  const delta_A = 0.02;

  // ODEs (spatially uniform three-variable model)

  // Strain 1: logistic growth with inhibition by A,
  // natural death, and contact-dependent killing by strain 2.
  n_1' = (gamma_1/(1 + A)) * n_1 * (1 - n_1 - n_2) - delta * n_1 - kappa * n_1 * n_2;

  // Strain 2: logistic growth with same carrying capacity and death rate.
  // (No direct effect of A in the base three-variable model.)
  n_2' = n_2 * (1 - n_1 - n_2) - delta * n_2;

  // Inhibitor A: produced by strain 1, decays linearly.
  A'   = gamma_A * n_1 - delta_A * A;

  // Initial conditions
  // Paper uses random spatial ICs; here we choose homogeneous values
  // within the carrying capacity for a concrete ODE test case.
  n_1 = 0.4;
  n_2 = 0.4;
  A   = 0.0;

end
// @SIM T_START=0 T_END=100 N_STEPS=500 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
