// McMillen2002_RelaxationOscillator.ant
//
// Source:
//   McMillen D, Kopell N, Hasty J, Collins JJ (2002)
//   "Synchronizing genetic relaxation oscillators by intercell signaling."
//   Proc Natl Acad Sci USA 99(2):679–684. doi:10.1073/pnas.0226422999
//
// Model:
//   Single genetic relaxation oscillator with quorum-sensing feedback,
//   dimensionless form (Eqs. 4–7). Variables:
//     x : CII (autocatalytic activator)
//     y : FtsH (protease for CII)
//     l : LuxI (AI synthase)
//     a : intracellular autoinducer (AI)
//   Time τ is already nondimensionalized.
//
// For a single synchronized oscillator we approximate
//   a_e = Q * a
// so that the intracellular AI dynamics reduce to the same form
// used for a synchronized population in the paper.

//----------------------------
// Model
//----------------------------
model McMillen2002_RelaxationOscillator

  // Compartment
  compartment cell = 1;

  // Species (dimensionless concentrations)
  species x in cell;     // CII
  species y in cell;     // FtsH
  species l in cell;     // LuxI
  species a in cell;     // intracellular AI

  // Parameters (dimensionless; from parameter discussion in the paper)
  // Hill nonlinearities
  const alpha  = 600;    // promoter strength for x,y,l
  const beta   = 10;     // activation strength of x by AI

  // Production / copy-number prefactors
  const m_x    = 10;     // max production factor for x,y from PRE promoter
  const m_y    = 1;
  const mu_x   = 50;     // AI-activated x production
  const mu_l   = 50;     // LuxI production from PRE

  // Degradation / dilution rates
  const gamma_x  = 0.5;  // degradation/dilution of x
  const gamma_y  = 0.5;  // degradation/dilution of y
  const gamma_l  = 25;   // degradation/dilution of l
  const gamma_a  = 0.2;  // degradation/dilution of a

  // Proteolytic degradation of x by y
  const gamma_xy = 5;    // effective x–y interaction strength

  // AI synthesis / transport
  const mu_a   = 0.4;    // AI production from LuxI
  const D_a    = 120;    // AI exchange with extracellular medium
  const Q      = 0.6;    // effective coupling / extracellular volume factor

  // Effective extracellular AI level for a synchronized population
  a_e := Q * a;

  //----------------------------
  // ODEs (dimensionless time τ)
  //----------------------------
  // Note: Hill functions f(x) and g(a) are inlined directly
  // f(x) = (1 + alpha*x^4) / (1 + x^4)  (PRE promoter activated by CII)
  // g(a) = (1 + beta*a^2) / (1 + a^2)   (lux promoter activated by AI)

  // CII (x)
  x' = m_x * (1 + alpha*x^4) / (1 + x^4)    // production from PRE
       - gamma_xy * x * y                   // proteolysis by FtsH
       - gamma_x * x                        // dilution/degradation
       + mu_x * (1 + beta*a^2) / (1 + a^2); // AI-activated production

  // FtsH (y)
  y' = m_y * (1 + alpha*x^4) / (1 + x^4)    // production from PRE
       - gamma_y * y;                        // dilution/degradation

  // LuxI (l)
  l' = mu_l * (1 + alpha*x^4) / (1 + x^4)   // production from PRE
       - gamma_l * l;                        // dilution/degradation

  // Intracellular AI (a)
  // Exchange with extracellular AI ~ D_a * (a_e - a)
  a' = mu_a * l               // synthesis by LuxI
       - D_a * (a - a_e)      // exchange with medium
       - gamma_a * a;         // dilution/degradation

  //----------------------------
  // Initial conditions
  //----------------------------
  // The paper does not fix specific numeric ICs; here we choose a simple
  // non-negative state that reliably converges to the relaxation limit cycle.
  x = 0;
  y = 0;
  l = 0;
  a = 0;

end
// @SIM T_START=0 T_END=12 N_STEPS=400
