// Linear Pathway with Michaelis-Menten Kinetics and Competitive Inhibition
// Source: Pozo et al., "Steady-state global optimization of metabolic non-linear
//         dynamic models through recasting into power-law canonical models"
//         BMC Systems Biology 5:137 (2011)
//         Equations (20)-(23)
//
// This paper explicitly cites Savageau & Voit (1987) as reference [36].
//
// Original Michaelis-Menten model (Eq. 20) - 2 variables:
//   dXâ‚پ/dt = Vâ‚پآ·Xâ‚ƒ / (Kâ‚پ(1 + Kلµ¢/Xâ‚‚) + Xâ‚ƒ) - Vâ‚‚آ·Xâ‚پ / (Kâ‚‚ + Xâ‚پ)
//   dXâ‚‚/dt = Vâ‚‚آ·Xâ‚پ / (Kâ‚‚ + Xâ‚پ) - Vâ‚ƒآ·Xâ‚‚آ² / (Kâ‚ƒآ² + Xâ‚‚آ²)
//
// Xâ‚ƒ is external (fixed), Xâ‚‚ is competitive inhibitor of first reaction
//
// ==============================================================================
// EXACT RECASTING TO GMA (Eq. 21-23):
// ==============================================================================
// Introduce auxiliary variables:
//   Xâ‚„ = Kâ‚پ(1 + Kلµ¢/Xâ‚‚) + Xâ‚ƒ
//   Xâ‚… = Kâ‚‚ + Xâ‚پ
//   Xâ‚† = Kâ‚ƒآ² + Xâ‚‚آ²
//
// Recast GMA model (2 â†’ 6 variables):
//   dXâ‚پ/dt = Vâ‚پآ·Xâ‚ƒآ·Xâ‚„âپ»آ¹ - Vâ‚‚آ·Xâ‚پآ·Xâ‚…âپ»آ¹
//   dXâ‚‚/dt = Vâ‚‚آ·Xâ‚پآ·Xâ‚…âپ»آ¹ - Vâ‚ƒآ·Xâ‚‚آ²آ·Xâ‚†âپ»آ¹
//   dXâ‚„/dt = -Kâ‚پآ·Kلµ¢آ·dXâ‚‚/dt / Xâ‚‚آ² = Vâ‚ƒآ·Kâ‚پآ·Kلµ¢آ·Xâ‚†âپ»آ¹ - Vâ‚‚آ·Kâ‚پآ·Kلµ¢آ·Xâ‚پآ·Xâ‚…âپ»آ¹آ·Xâ‚‚âپ»آ²
//   dXâ‚…/dt = dXâ‚پ/dt = Vâ‚پآ·Xâ‚ƒآ·Xâ‚„âپ»آ¹ - Vâ‚‚آ·Xâ‚پآ·Xâ‚…âپ»آ¹
//   dXâ‚†/dt = 2آ·Xâ‚‚آ·dXâ‚‚/dt = 2آ·Vâ‚‚آ·Xâ‚پآ·Xâ‚‚آ·Xâ‚…âپ»آ¹ - 2آ·Vâ‚ƒآ·Xâ‚‚آ³آ·Xâ‚†âپ»آ¹
// ==============================================================================

model P2011_linear_pathway_MM()
  // State variables (original)
  compartment cell = 1;var species X1 in cell; var species X2 in cell

  // External (fixed) variable
  X3 := 1.0;
  
  // Kinetic parameters
  V1 := 10.0;
  V2 := 5.0;
  V3 := 5.0;
  K1 := 0.5;
  K2 := 0.5;
  K3 := 0.5;
  Ki := 1.0;
  
  // Original Michaelis-Menten model (Eq. 20)
  // Competitive inhibition: apparent Km = K1آ·(1 + Ki/X2)
  X1' = V1 * X3 / (K1 * (1 + Ki / X2) + X3) - V2 * X1 / (K2 + X1);
  X2' = V2 * X1 / (K2 + X1) - V3 * X2^2 / (K3^2 + X2^2);
  
  // Initial conditions
  X1 = 1.0; X2 = 1.0;
end
// @SIM T_START=0; T_END=20; N_STEPS =400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
