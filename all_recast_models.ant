gamma_y = 0.5;
m_x = 10;
m_y = 1;
mu_a = 0.4;
mu_l = 50;
mu_x = 50;

// Assignment rules (from original model)
a_e := Q * a;

Y_1 = 1;
Y_2 = 1;
a = 0;
l = 0;
x = 0;
y = 0;

Y_1' = 2*D_a*a*a_e + 2*a*l*mu_a - (2*D_a*a^2 + 2*a^2*gamma_a);
Y_2' = 4*Y_2^-1*m_x*x^3 + 4*Y_1^-1*mu_x*x^3 + 4*Y_2^-1*alpha*m_x*x^7 + 4*Y_1^-1*a^2*beta*mu_x*x^3 - (4*gamma_x*x^4 + 4*gamma_xy*x^4*y);
a' = D_a*a_e + l*mu_a - (D_a*a + a*gamma_a);
l' = Y_2^-1*mu_l + Y_2^-1*alpha*mu_l*x^4 - (gamma_l*l);
x' = Y_2^-1*m_x + Y_1^-1*mu_x + Y_2^-1*alpha*m_x*x^4 + Y_1^-1*a^2*beta*mu_x - (gamma_x*x + gamma_xy*x*y);
y' = Y_2^-1*m_y + Y_2^-1*alpha*m_y*x^4 - (gamma_y*y);
endmodel Mueller2006_recast()

compartment cell = 1;

species Z_1 in cell;
species Z_10 in cell;
species Z_11 in cell;
species Z_12 in cell;
species Z_2 in cell;
species Z_3 in cell;
species Z_4 in cell;
species Z_5 in cell;
species Z_6 in cell;
species Z_7 in cell;
species Z_8 in cell;
species Z_9 in cell;

// ========================================================================
// RECAST METADATA
// ========================================================================
// Recast variables: 12
// Original variables: 6
// Parameters: 14
// ========================================================================

// ========================================================================
// VARIABLE MAPPING
// ========================================================================
// x1 = Z_1*Z_2
// x2 = Z_3*Z_4
// x3 = Z_5*Z_6
// y1 = Z_7*Z_8
// y2 = Z_9*Z_10
// y3 = Z_11*Z_12
// ========================================================================

// ========================================================================
// PARAMETERS (copied from original)
// ========================================================================
M1 = 0;
M2 = 0;
M3 = 0;
alpha = 2;
beta = 1;
delta = 0.001;
f1 = 0;
f2 = 0;
f3 = 0;
gam = 1;
h = 2;
s1 = 0;
s2 = 0;
s3 = 0;

// ========================================================================
// ASSIGNMENT RULES (time-dependent quantities)
// ========================================================================
M1 := 1 + gam * h * pow(x1, h - 1) / pow(1 + pow(x1, h), 2);
M2 := 1 + gam * h * pow(x2, h - 1) / pow(1 + pow(x2, h), 2);
M3 := 1 + gam * h * pow(x3, h - 1) / pow(1 + pow(x3, h), 2);
f1 := (1 - delta) * (1 - s1) + delta;
f2 := (1 - delta) * (1 - s2) + delta;
f3 := (1 - delta) * (1 - s3) + delta;
s1 := pow(x1, h) / (1 + pow(x1, h));
s2 := pow(x2, h) / (1 + pow(x2, h));
s3 := pow(x3, h) / (1 + pow(x3, h));

// ========================================================================
// INITIAL CONDITIONS (auxiliary variables)
// ========================================================================
Z_1 = 0.1;
Z_10 = 1;
Z_11 = 0.1;
Z_12 = 1;
Z_2 = 1;
Z_3 = 0.2;
Z_4 = 1;
Z_5 = 0.3;
Z_6 = 1;
Z_7 = 0.1;
Z_8 = 1;
Z_9 = 0.1;

// ========================================================================
// OBSERVABLE VARIABLES (reconstructed from auxiliaries)
// ========================================================================
x1 := Z_1 * Z_2;
x2 := Z_3 * Z_4;
x3 := Z_5 * Z_6;
y1 := Z_7 * Z_8;
y2 := Z_9 * Z_10;
y3 := Z_11 * Z_12;

// ========================================================================
// S-SYSTEM DYNAMICS
// ========================================================================
Z_1' = beta*M1^-1*Z_2^-1*Z_7*Z_8 - 0;
Z_2' = 0 - beta*M1^-1*Z_2;
Z_3' = beta*M2^-1*Z_10*Z_4^-1*Z_9 - 0;
Z_4' = 0 - beta*M2^-1*Z_4;
Z_5' = beta*M3^-1*Z_11*Z_12*Z_6^-1 - 0;
Z_6' = 0 - beta*M3^-1*Z_6;
Z_7' = 0 - Z_7;
Z_8' = alpha*f3*Z_7^-1 - 0;
Z_9' = 0 - Z_9;
Z_10' = alpha*f1*Z_9^-1 - 0;
Z_11' = 0 - Z_11;
Z_12' = alpha*f2*Z_11^-1 - 0;
end

// @SIM T_START=0 T_END=10 N_STEPS=400 EPS_INIT=1e-06
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.model Ozbudak2004_recast()

compartment cell = 1;

species Z_1 in cell;
species Z_2 in cell;
species Z_3 in cell;
species Z_4 in cell;

// ========================================================================
// RECAST METADATA
// ========================================================================
// Recast variables: 4
// Original variables: 2
// Parameters: 4
// ========================================================================

// ========================================================================
// VARIABLE MAPPING
// ========================================================================
// x = Z_1*Z_2
// y = Z_3*Z_4
// ========================================================================

// ========================================================================
// PARAMETERS (copied from original)
// ========================================================================
alpha = 100.5;
beta = 0.62;
inhib = 0;
rho = 167.1;

// ========================================================================
// ASSIGNMENT RULES (time-dependent quantities)
// ========================================================================
inhib := 1 + (rho - 1) / (1 + pow(x, 2));

// ========================================================================
// INITIAL CONDITIONS (auxiliary variables)
// ========================================================================
// NOTE: Initial conditions near 1e-06 are used to approximate zero
//       This prevents numerical instability from negative exponents
//       while maintaining dynamics qualitatively equivalent to zero ICs
Z_1 = 1e-06;
Z_2 = 1;
Z_3 = 0.601436;
Z_4 = 1;

// ========================================================================
// OBSERVABLE VARIABLES (reconstructed from auxiliaries)
// ========================================================================
x := Z_1 * Z_2;
y := Z_3 * Z_4;

// ========================================================================
// S-SYSTEM DYNAMICS
// ========================================================================
Z_1' = 0 - Z_1;
Z_2' = beta*Z_1^-1*Z_3*Z_4 - 0;
Z_3' = 0 - Z_3;
Z_4' = alpha*inhib^-1*Z_3^-1 - 0;
end

