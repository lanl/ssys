// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-06
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.model HBF1998_three_wave_recast()

compartment cell = 1;

species x1 in cell;
species x2 in cell;
species x3 in cell;

// GMA (Generalized Mass Action) format
// Multiple flux channels with different kinetic orders preserved exactly
//
// NOTE: Canonical S-system recast was not attempted because:
//   would create 13 auxiliaries for 3 variables (>4x expansion)
//
// Using GMA format preserves exact dynamics with better numerical properties.

// Parameters (from original model)
cell = 1;

// Assignment rules (from original model)
N11 := 0.5;
N12 := 0.3;
N13 := 0.2;
N21 := 0.3;
N22 := 0.4;
N23 := 0.3;
N31 := 0.2;
N32 := 0.3;
N33 := 0.5;
gamma_rate := 0.5;
omega1 := -0.1;
omega2 := -0.1;
omega3 := -0.1;

x1 = 1;
x2 = 0.8;
x3 = 0.6;

x1' = N11*x1^3 + omega1*x1 + N12*x1*x2^2 + N13*x1*x3^2 + gamma_rate*x2*x3;
x2' = N22*x2^3 + omega2*x2 + N21*x1^2*x2 + N23*x2*x3^2;
