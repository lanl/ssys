// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-06
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.model Weber2018_recast()

compartment cell = 1;

species R in cell;
species S_1 in cell;
species S_2 in cell;
species S_3 in cell;
species T in cell;

// GMA (Generalized Mass Action) format
// Multiple flux channels with different kinetic orders preserved exactly
// Cannot be reduced to canonical S-system form without loss of information

// ========================================================================
// AUXILIARY DEFINITIONS (for lifted variables)
// ========================================================================
// T := time
// ========================================================================

// Parameters (from original model)
R = 0;
S_1 = 1;
S_2 = 0;
S_3 = 0;
beta = 1;
eps_k = 0.01;
gam = 0.8;
k_12_0 = 3;
k_21_0 = 2.5;
k_23_0 = -0.4;
k_32_0 = 1;
k_r_2 = 9;
k_r_3 = 2;
k_steep = 5;

// Assignment rules (from original model)
H_off := 0.5 * (1 + tanh(k_steep * (70 - T)));
H_on := 0.5 * (1 + tanh(k_steep * (T - 5)));
Y_1 := (1 - cos(2 * pi * T / 30)) * H_on * H_off;
k_12 := k_12_0;
k_21 := k_21_0;
k_23 := 0.5 * (k_23_raw + sqrt(pow(k_23_raw, 2) + pow(eps_k, 2)));
k_23_raw := k_23_0 + beta * Y_1;
k_32 := k_32_0;

T = 0;

R' = S_2*k_r_2 + S_3*k_r_3 - (R*gam);
S_1' = S_2*k_21 - (S_1*k_12);
S_2' = S_1*k_12 + S_3*k_32 - (S_2*k_21 + S_2*k_23);
S_3' = S_2*k_23 - (S_3*k_32);
T' = 1;
endmodel Xiong2018_recast()

compartment env = 1;

species A in env;
species Y_1 in env;
species n_1 in env;
species n_2 in env;

// GMA (Generalized Mass Action) format
// Multiple flux channels with different kinetic orders preserved exactly
// Cannot be reduced to canonical S-system form without loss of information

// ========================================================================
// AUXILIARY DEFINITIONS (for lifted variables)
// ========================================================================
// Y_1 := A + 1
// ========================================================================

// Parameters (from original model)
delta = 0.01;
delta_A = 0.02;
env = 1;
gamma_1 = 4.5;
gamma_A = 0.04;
kappa = 0.03;

A = 0;
Y_1 = 1;
n_1 = 0.4;
n_2 = 0.4;

A' = gamma_A*n_1 - (A*delta_A);
Y_1' = gamma_A*n_1 - (A*delta_A);
n_1' = Y_1^-1*gamma_1*n_1 - (delta*n_1 + Y_1^-1*gamma_1*n_1^2 + kappa*n_1*n_2 + Y_1^-1*gamma_1*n_1*n_2);
n_2' = n_2 - (n_2^2 + delta*n_2 + n_1*n_2);
end