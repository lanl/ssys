Z_1' = B*Y_1^-1*Z_1^2*c^2 + Y_1^-1*Z_1*a*b*c^2 - (Y_1^-1*Z2*Z_1*c^2 + B*Y_1^-1*Z1*Z_1^2*c^2 + Y_1^-1*Z2*Z_1*b*c^2);
