// ========================================================================
// Y_1 := Z_1^2 + Z_2^2
// ========================================================================

// Parameters (from original model)
default_compartment = 1;

Y_1 = 9;
Z_1 = 3;
Z_2 = 0;
Z_3 = 0;

Y_1' = 0 - (2*Y_1^-0.5*Z_1^2*Z_3 + 2*Y_1^-0.5*Z_2^2*Z_3);
Z_1' = 0 - (Z_2 + Y_1^-0.5*Z_1*Z_3);
Z_2' = Z_1 - (Y_1^-0.5*Z_2*Z_3);
Z_3' = Y_1^-0.5*Z_1;
endmodel m29_time_varying_beta_recast()

compartment default_compartment = 1;

species Z_1 in default_compartment;
species Z_2 in default_compartment;
species Z_3 in default_compartment;
species Z_4 in default_compartment;
species Z_5 in default_compartment;
species Z_6 in default_compartment;
species Z_7 in default_compartment;

// ========================================================================
// RECAST METADATA
// ========================================================================
// Recast variables: 7
// Original variables: 4
// Parameters: 11
// ========================================================================

// ========================================================================
// VARIABLE MAPPING
// ========================================================================
// I = Z_1*Z_2
// R = Z_3*Z_4
// S = Z_5*Z_6
// t = Z_7
// ========================================================================

// ========================================================================
// PARAMETERS (copied from original)
// ========================================================================
I0 = 1;
R0 = 0;
S0 = 100000;
beta0 = 3e-06;
beta1 = 1.5e-05;
beta_t = 0;
delta = 0.05;
gamma_rate = 0.1;
k = 1;
tau0 = 5;
tau1 = 200;

// ========================================================================
// ASSIGNMENT RULES (time-dependent quantities)
// ========================================================================
beta_t := beta0 * 0.5 * ((exp(2 * k * (t - tau0)) - 1) / (exp(2 * k * (t - tau0)) + 1) - (exp(2 * k * (t - tau1)) - 1) / (exp(2 * k * (t - tau1)) + 1)) + beta1 * 0.5 * ((exp(2 * k * (t - tau1)) - 1) / (exp(2 * k * (t - tau1)) + 1) + 1);

// ========================================================================
// INITIAL CONDITIONS (auxiliary variables)
// ========================================================================
Z_1 = 1;
Z_2 = 1;
Z_3 = 0;
Z_4 = 1;
Z_5 = 100000;
Z_6 = 1;
Z_7 = 0;

// ========================================================================
// OBSERVABLE VARIABLES (reconstructed from auxiliaries)
// ========================================================================
I := Z_1 * Z_2;
R := Z_3 * Z_4;
S := Z_5 * Z_6;
t := Z_7;

// ========================================================================
// S-SYSTEM DYNAMICS
// ========================================================================
Z_1' = 0 - gamma_rate*Z_1;
Z_2' = beta_t*Z_2*Z_5*Z_6 - 0;
Z_3' = gamma_rate*Z_1*Z_2*Z_4^-1 - 0;
Z_4' = 0 - delta*Z_4;
Z_5' = delta*Z_3*Z_4*Z_6^-1 - 0;
Z_6' = 0 - beta_t*Z_1*Z_2*Z_6;
Z_7' = 1 - 0;
end

