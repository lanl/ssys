d2 = 1;
d3 = 1;
default_compartment = 1;
k1 = 5;
k2 = 1.5;
k3 = 1.2;
n = 3;

// ========================================================================
// INITIAL CONDITIONS (auxiliary variables)
// ========================================================================
X1 = 1;
X2 = 1;
X3 = 1;
Y_1 = 1.125;

// ========================================================================
// S-SYSTEM DYNAMICS
// ========================================================================
X1' = k1*Y_1^-1 - d1*X1;
X2' = k2*X1 - d2*X2;
X3' = k3*X2 - d3*X3;
Y_1' = k3*n*K^-n*X2*X3^(n - 1) - d3*n*(X3/K)^n;
endmodel m19_RM_predator_prey_recast()

compartment default_compartment = 1;

species Y_1 in default_compartment;
species x in default_compartment;
species y in default_compartment;

// GMA (Generalized Mass Action) format
// Multiple flux channels with different kinetic orders preserved exactly
// Cannot be reduced to canonical S-system form without loss of information

// ========================================================================
// AUXILIARY DEFINITIONS (for lifted variables)
// ========================================================================
// Y_1 := a*h*x + 1
// ========================================================================

// Parameters (from original model)
K = 10;
a = 0.5;
default_compartment = 1;
e = 0.6;
h = 0.4;
m = 0.2;
r = 1;

Y_1 = 1.4;
x = 2;
y = 1;

Y_1' = a*h*r*x - (K^-1*a*h*r*x^2 + Y_1^-1*a^2*h*x*y);
x' = r*x - (K^-1*r*x^2 + Y_1^-1*a*x*y);
y' = Y_1^-1*a*e*x*y - (m*y);
endmodel m20_Briggs_Haldane_recast()

compartment default_compartment = 1;

species Z_1 in default_compartment;
species Z_2 in default_compartment;
species Z_3 in default_compartment;
species Z_4 in default_compartment;
species Z_5 in default_compartment;
species Z_6 in default_compartment;
species Z_7 in default_compartment;
species Z_8 in default_compartment;

// ========================================================================
// RECAST METADATA
// ========================================================================
// Recast variables: 8
// Original variables: 3
// Parameters: 4
// ========================================================================

// ========================================================================
// VARIABLE MAPPING
// ========================================================================
// C = Z_1*Z_2*Z_3*Z_4
// P = Z_5
// S = Z_6*Z_7*Z_8
// ========================================================================

// ========================================================================
// PARAMETERS (copied from original)
// ========================================================================
E_T = 1;
k_1 = 1;
k_2 = 0.3;
k_m_1 = 0.5;

// ========================================================================
// INITIAL CONDITIONS (auxiliary variables)
// ========================================================================
// NOTE: Initial conditions near 1e-06 are used to approximate zero
//       This prevents numerical instability from negative exponents
//       while maintaining dynamics qualitatively equivalent to zero ICs
Z_1 = 1e-06;
Z_2 = 1;
Z_3 = 1;
Z_4 = 1;
Z_5 = 0;
Z_6 = 1;
Z_7 = 1;
Z_8 = 1;

// ========================================================================
// OBSERVABLE VARIABLES (reconstructed from auxiliaries)
// ========================================================================
C := Z_1 * Z_2 * Z_3 * Z_4;
P := Z_5;
S := Z_6 * Z_7 * Z_8;

// ========================================================================
// S-SYSTEM DYNAMICS
// ========================================================================
Z_1' = 0 - k_2*Z_1;
Z_2' = 0 - k_m_1*Z_2;
Z_3' = E_T*k_1*Z_1^-1*Z_2^-1*Z_4^-1*Z_6*Z_7*Z_8 - 0;
Z_4' = 0 - k_1*Z_4*Z_6*Z_7*Z_8;
Z_5' = k_2*Z_1*Z_2*Z_3*Z_4 - 0;
Z_6' = k_m_1*Z_1*Z_2*Z_3*Z_4*Z_7^-1*Z_8^-1 - 0;
Z_7' = k_1*Z_1*Z_2*Z_3*Z_4*Z_7 - 0;
Z_8' = 0 - E_T*k_1*Z_8;
end

// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-06
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.model m21_Haldane_chemostat_recast()

compartment default_compartment = 1;

species Z_1 in default_compartment;
species Z_2 in default_compartment;
species Z_3 in default_compartment;
species Z_4 in default_compartment;
species Z_5 in default_compartment;

// ========================================================================
// RECAST METADATA
// ========================================================================
// Recast variables: 5
// Original variables: 2
// Parameters: 7
// ========================================================================

// ========================================================================
// VARIABLE MAPPING
// ========================================================================
// S = Z_1*Z_2*Z_3
// X = Z_4*Z_5
// ========================================================================

// ========================================================================
// PARAMETERS (copied from original)
// ========================================================================
D = 0.1;
K_I = 2;
K_S = 0.5;
S_in = 5;
Y_xs = 0.5;
mu = 0;
mu_max = 1;

// ========================================================================
// ASSIGNMENT RULES (time-dependent quantities)
// ========================================================================
mu := mu_max * S / (K_S + S + pow(S, 2) / K_I);

// ========================================================================
// INITIAL CONDITIONS (auxiliary variables)
// ========================================================================
Z_1 = 4;
Z_2 = 1;
Z_3 = 1;
Z_4 = 0.1;
Z_5 = 1;

// ========================================================================
// OBSERVABLE VARIABLES (reconstructed from auxiliaries)
// ========================================================================
S := Z_1 * Z_2 * Z_3;
X := Z_4 * Z_5;

// ========================================================================
// S-SYSTEM DYNAMICS
// ========================================================================
Z_1' = D*S_in*Z_2^-1*Z_3^-1 - 0;
Z_2' = 0 - D*Z_2;
Z_3' = 0 - mu*Y_xs^-1*Z_1^-1*Z_2^-1*Z_4*Z_5;
Z_4' = mu*Z_4 - 0;
Z_5' = 0 - D*Z_5;
end

