V_4 := a_5 * (Ca * x001 - d_5 * x_011);
p_open := pow(x_110, 3);
x_011 := (1 - (x000 * (1 + IP3 / d_1) + x001 * (1 + IP3 / d_3) + x010 * (1 + IP3 / d_1))) / (1 + IP3 / d_3);
x_110 := IP3 / d_1 * x010;

// ========================================================================
// INITIAL CONDITIONS (auxiliary variables)
// ========================================================================
Z_1 = 0.1;
Z_2 = 1;
Z_3 = 0.05;
Z_4 = 1;
Z_5 = 0.02;
Z_6 = 1;
Z_7 = 0.05;
Z_8 = 1;

// ========================================================================
// OBSERVABLE VARIABLES (reconstructed from auxiliaries)
// ========================================================================
Ca := Z_1 * Z_2;
x000 := Z_3 * Z_4;
x001 := Z_5 * Z_6;
x010 := Z_7 * Z_8;

// ========================================================================
// S-SYSTEM DYNAMICS
// ========================================================================
Z_1' = J_1*Z_2^-1 - 0;
Z_2' = 0 - J_2*Z_1^-1;
Z_3' = 0 - V_1*Z_4^-1;
Z_4' = 0 - V_3*Z_3^-1;
Z_5' = V_1*Z_6^-1 - 0;
Z_6' = 0 - V_4*Z_5^-1;
Z_7' = V_3*Z_8^-1 - 0;
Z_8' = 0 - V_2*Z_7^-1;
end

