species Y_3 in default_compartment;
species Y_4 in default_compartment;

// GMA (Generalized Mass Action) format
// Multiple flux channels with different kinetic orders preserved exactly
// Cannot be reduced to canonical S-system form without loss of information

// ========================================================================
// AUXILIARY DEFINITIONS (for lifted variables)
// ========================================================================
// Y_1 := X_3 + 0.005
// Y_2 := X_3 + 1
// Y_3 := X_3*(X_5 + 1) + 1
// Y_4 := X_3^2 + X_6^2
// ========================================================================

// Parameters (from original model)
X_4 = 0.05;
X_5 = 0.5;
X_6 = 50;
X_7 = 150;
default_compartment = 1;
tau = 0.1;

X_1 = 2;
X_2 = 12;
X_3 = 25;
Y_1 = 25.005;
Y_2 = 26;
Y_3 = 38.5;
Y_4 = 3125;

X_1' = Y_3^-1*tau + X_3*Y_3^-1*tau - (0.9*X_1*tau + X_1*X_4*tau);
X_2' = X_1*X_4*tau - (0.1*X_1*tau);
X_3' = X_3*X_7*Y_1^-1*tau + 0.0022*X_3*X_5*Y_2^-1*tau - (X_1*tau + 0.02*X_2*tau + X_2*X_4*tau + X_3*X_4*tau + X_3^2*X_6^2*Y_4^-1*tau + 7.5*X_3*X_4*X_7*Y_1^-1*tau);
Y_1' = X_3*X_7*Y_1^-1*tau + 0.0022*X_3*X_5*Y_2^-1*tau - (X_1*tau + 0.02*X_2*tau + X_2*X_4*tau + X_3*X_4*tau + X_3^2*X_6^2*Y_4^-1*tau + 7.5*X_3*X_4*X_7*Y_1^-1*tau);
Y_2' = X_3*X_7*Y_1^-1*tau + 0.0022*X_3*X_5*Y_2^-1*tau - (X_1*tau + 0.02*X_2*tau + X_2*X_4*tau + X_3*X_4*tau + X_3^2*X_6^2*Y_4^-1*tau + 7.5*X_3*X_4*X_7*Y_1^-1*tau);
Y_3' = X_3*X_7*Y_1^-1*tau + 0.0022*X_3*X_5*Y_2^-1*tau + 0.0022*X_3*X_5^2*Y_2^-1*tau + X_3*X_5*X_7*Y_1^-1*tau - (X_1*tau + 0.02*X_2*tau + X_1*X_5*tau + X_2*X_4*tau + X_3*X_4*tau + 0.02*X_2*X_5*tau + X_2*X_4*X_5*tau + X_3*X_4*X_5*tau + X_3^2*X_6^2*Y_4^-1*tau + X_3^2*X_5*X_6^2*Y_4^-1*tau + 7.5*X_3*X_4*X_7*Y_1^-1*tau + 7.5*X_3*X_4*X_5*X_7*Y_1^-1*tau);
Y_4' = 2*X_3^2*X_7*Y_1^-1*tau + 0.0044*X_3^2*X_5*Y_2^-1*tau - (2*X_1*X_3*tau + 2*X_3^2*X_4*tau + 0.04*X_2*X_3*tau + 2*X_2*X_3*X_4*tau + 2*X_3^3*X_6^2*Y_4^-1*tau + 15*X_3^2*X_4*X_7*Y_1^-1*tau);
endmodel m16_normal_dens_recast()

