Z_3' = 1*k_4*Z_2^-1*Z_4^-1*Z_5^-1*Z_7*Z_8 - 0;
Z_4' = 0 - 1*k_2*Z_4;
Z_5' = 0 - 1*k_3*Z_5;
Z_6' = 1*k_2*Z_2*Z_3*Z_4*Z_5 - 0;
