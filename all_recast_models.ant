k_pT = 1.66054e-07;
n = 4;

P_R0 = 9090.91;
P_R1 = 0;
P_R2 = 0;
P_R3 = 0;
P_R4 = 0;
P_T0 = 90909.1;
P_T1 = 0;
P_T2 = 0;
P_T3 = 0;
P_T4 = 0;
S = 100000;

P_R0' = 1*P_R1*k_mR + 1*P_T0*k_pL_0 - (1*P_R0*k_mL_0 + 4*P_R0*S*k_pR);
P_R1' = 1*P_T1*k_pL_1 + 2*P_R2*k_mR + 4*P_R0*S*k_pR - (1*P_R1*k_mL_1 + 1*P_R1*k_mR + 3*P_R1*S*k_pR);
P_R2' = 1*P_T2*k_pL_2 + 3*P_R3*k_mR + 3*P_R1*S*k_pR - (1*P_R2*k_mL_2 + 2*P_R2*k_mR + 2*P_R2*S*k_pR);
P_R3' = 1*P_T3*k_pL_3 + 4*P_R4*k_mR + 2*P_R2*S*k_pR - (1*P_R3*k_mL_3 + 3*P_R3*k_mR + 1*P_R3*S*k_pR);
P_R4' = 1*P_T4*k_pL_4 + 1*P_R3*S*k_pR - (1*P_R4*k_mL_4 + 4*P_R4*k_mR);
P_T0' = 1*P_R0*k_mL_0 + 1*P_T1*k_mT - (1*P_T0*k_pL_0 + 4*P_T0*S*k_pT);
P_T1' = 1*P_R1*k_mL_1 + 2*P_T2*k_mT + 4*P_T0*S*k_pT - (1*P_T1*k_mT + 1*P_T1*k_pL_1 + 3*P_T1*S*k_pT);
P_T2' = 1*P_R2*k_mL_2 + 3*P_T3*k_mT + 3*P_T1*S*k_pT - (1*P_T2*k_pL_2 + 2*P_T2*k_mT + 2*P_T2*S*k_pT);
P_T3' = 1*P_R3*k_mL_3 + 4*P_T4*k_mT + 2*P_T2*S*k_pT - (1*P_T3*k_pL_3 + 3*P_T3*k_mT + 1*P_T3*S*k_pT);
P_T4' = 1*P_R4*k_mL_4 + 1*P_T3*S*k_pT - (1*P_T4*k_pL_4 + 4*P_T4*k_mT);
S' = 1*P_R1*k_mR + 1*P_T1*k_mT + 2*P_R2*k_mR + 2*P_T2*k_mT + 4*P_R4*k_mR + 4*P_T4*k_mT + 3*P_R3*k_mR + 3*P_T3*k_mT - (1*P_R3*S*k_pR + 1*P_T3*S*k_pT + 2*P_R2*S*k_pR + 2*P_T2*S*k_pT + 4*P_R0*S*k_pR + 4*P_T0*S*k_pT + 3*P_R1*S*k_pR + 3*P_T1*S*k_pT);
end

