species l in cell;
species z in cell;

// GMA (Generalized Mass Action) format
// Multiple flux channels with different kinetic orders preserved exactly
// Cannot be reduced to canonical S-system form without loss of information

// ========================================================================
// AUXILIARY DEFINITIONS (for lifted variables)
// ========================================================================
// Y_1 := 1 + a/K_m_a
// Y_2 := 1 + l/K_m_l
// Y_3 := K_i + l + l_ext
// Y_4 := K_m_a + a
// Y_5 := K_m_l + l
// Y_6 := K_z^n_Hill + a^n_Hill
// ========================================================================

// Parameters (from original model)
K_i = 500;
K_m_a = 1200;
K_m_l = 2530;
K_z = 105;
alpha = 600;
beta = 28500;
c = 0.0343;
cell = 1;
delta = 23000;
eps = 34.285;
growth_rate = 0.02;
l_ext = 1000;
n_Hill = 2;
nu = 0.468;
phi = 0.5;

Y_1 = 1;
Y_2 = 1;
Y_3 = 1500;
Y_4 = 1200;
Y_5 = 2530;
Y_6 = 11025;
a = 0;
l = 0;
z = 0.0343;

Y_1' = K_m_a^-1*Y_1^-1*Y_5^-1*beta*l*nu*z - (K_m_a^-1*a*growth_rate + K_m_a^-1*Y_2^-1*Y_4^-1*a*delta*z);
Y_2' = K_m_l^-1*Y_3^-1*alpha*l_ext*z - (K_m_l^-1*growth_rate*l + K_m_l^-1*Y_3^-1*alpha*l*phi*z + K_m_l^-1*Y_1^-1*Y_5^-1*beta*l*z);
Y_3' = Y_3^-1*alpha*l_ext*z - (growth_rate*l + Y_3^-1*alpha*l*phi*z + Y_1^-1*Y_5^-1*beta*l*z);
Y_4' = Y_1^-1*Y_5^-1*beta*l*nu*z - (a*growth_rate + Y_2^-1*Y_4^-1*a*delta*z);
Y_5' = Y_3^-1*alpha*l_ext*z - (growth_rate*l + Y_3^-1*alpha*l*phi*z + Y_1^-1*Y_5^-1*beta*l*z);
Y_6' = Y_1^-1*Y_5^-1*a^(n_Hill - 1)*beta*l*n_Hill*nu*z - (a^n_Hill*growth_rate*n_Hill + Y_2^-1*Y_4^-1*a^n_Hill*delta*n_Hill*z);
a' = Y_1^-1*Y_5^-1*beta*l*nu*z - (a*growth_rate + Y_2^-1*Y_4^-1*a*delta*z);
l' = Y_3^-1*alpha*l_ext*z - (growth_rate*l + Y_3^-1*alpha*l*phi*z + Y_1^-1*Y_5^-1*beta*l*z);
z' = c*growth_rate + Y_6^-1*a^n_Hill*eps*growth_rate - (growth_rate*z);
endmodel Fink2000_recast()

compartment cyt = 1;

species Ca in cyt;
species IP3 in cyt;
species T in cyt;
species h in cyt;

// GMA (Generalized Mass Action) format
// Multiple flux channels with different kinetic orders preserved exactly
// Cannot be reduced to canonical S-system form without loss of information

// ========================================================================
// AUXILIARY DEFINITIONS (for lifted variables)
// ========================================================================
// T := time
// ========================================================================

// Parameters (from original model)
Ca_ER = 400;
Ca_c = 0.2;
IP3_0 = 0.16;
J_0 = 20.86;
J_max = 3500;
K_IP3 = 0.8;
K_act = 0.3;
K_inh = 0.2;
K_p = 0.27;
L = 0.1;
V_max = 3.75;
a = 1.41;
cyt = 1;
eps_pm = 0.01;
g_0 = 8;
k_0 = 1.188;
k_degr = 0.14;
k_on = 2.7;

// Assignment rules (from original model)
J_channel := J_max * m_inf * pow(h, 3) * (1 - Ca / Ca_ER);
J_leak := L * (1 - Ca / Ca_ER);
J_pm := 0.5 * g_0 * (Ca - Ca_c + sqrt(pow(Ca - Ca_c, 2) + pow(eps_pm, 2)));
J_prod_IP3 := J_0 * exp(-k_0 * T);
J_pump := V_max * pow(Ca, 2) / (pow(Ca, 2) + pow(K_p, 2));
m_inf := IP3 / (IP3 + K_IP3) * (Ca / (Ca + K_act));

Ca = 0.05;
IP3 = 0.16;
T = 0;
h = 0.8;

Ca' = J_channel*a + J_leak*a - (J_pm + J_pump*a);
IP3' = J_prod_IP3 + IP3_0*k_degr - (IP3*k_degr);
T' = 1;
h' = K_inh*k_on - (Ca*h*k_on + K_inh*h*k_on);
endmodel Gardner2000_recast()

