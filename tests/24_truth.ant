////////////////////////////////////////////////////////////////////////////////
// 24_scalarExpLog_truth.ant
//
// Savageau & Voit 1987, Eqs. (16)–(17)
// Exact S-system recast of dZ/dt = exp[(ln Z)^2] via two lifting steps.
// Variables:
//   X1 = Z
//   X2 = exp[(ln Z)^2]
//   X3 = ln Z
//
// Final S-system (Eq. (17)):
//   X1' = X2
//   X2' = 2 X1^-1 X2^2 X3
//   X3' = X1^-1 X2
////////////////////////////////////////////////////////////////////////////////

model 24_scalarExpLog_truth()

  species X1, X2, X3;

  // S-system dynamics
  X1' = X2;
  X2' = 2*X1^-1*X2^2*X3;
  X3' = X1^-1*X2;

  // Initial conditions corresponding to Z(0) = 2
  // X1(0) = Z(0)
  // X3(0) = log Z(0)
  // X2(0) = exp[(log Z(0))^2]
  X1 = 2;
  X3 = log(2);
  X2 = exp((log(2))^2);

end