model 27_spiral_SSystem_exact()

  // Exact S-system recast of:
  //   t' = 1
  //   Z' = (Z - t)/(Z + t)
  //
  // Transformation:
  //   p   = 5
  //   X1  = Z + p
  //   X2  = t + p
  //   X3  = Z + t
  //
  // Inverse:
  //   Z = X1 - p
  //   t = X2 - p
  //
  // Check:
  //   Z' = X1' = X1/X3 - X2/X3 = (X1 - X2)/X3 = (Z - t)/(Z + t)
  //   t' = X2' = 1
  //   X3 = Z + t ⇒ X3' = Z' + t' = (Z - t)/(Z + t) + 1
  //                 = 2Z/(Z + t) = 2 X1/X3 - 2p/X3

  species X1, X2, X3;

  p = 5;

  // Dynamics (each RHS has 1–2 power-law monomials)
  X1' =  X1*(X3^(-1))  -  X2*(X3^(-1));       // two monomials
  X2' =  1;                                   // single monomial
  X3' =  2*X1*(X3^(-1))  -  2*p*(X3^(-1));    // two monomials

  // Initial conditions corresponding to t=0, Z=4
  X1 = 9;   // Z + p = 4 + 5
  X2 = 5;   // t + p = 0 + 5
  X3 = 4;   // Z + t = 4 + 0

  // Optional observables for original variables
  var t_obs, Z_obs;
  t_obs := X2 - p;
  Z_obs := X1 - p;

end