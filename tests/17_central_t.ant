model central_t_original()
  // Central t density: f'(t) = -((nu+1)*t/(nu + t^2)) * f(t)
  species t, f
  nu = 8                   // degrees of freedom (example)

  t' = 1
  f' = - ( (nu+1) * t / (nu + t^2) ) * f

  // ICs (example): start at t=0 with exact value
  // f(0) = Gamma((nu+1)/2) / (sqrt(nu*pi) * Gamma(nu/2))
  t = 0
  f = gamma((nu+1)/2) / (sqrt(nu*pi) * gamma(nu/2))
end