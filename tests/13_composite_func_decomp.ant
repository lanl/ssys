model composite_func_decomp()

  // Original general ODE (composite function), used to illustrate recasting Operation (3)
  // in Voit (1988), "NEW NONLINEAR METHODOLOGIES FOR MODELING MOLECULAR AND CELLULAR SYSTEMS".
  // Example: x' = exp(x) (see discussion around decomposition of composite functions).
  // This is a synthetic test case to exercise the recaster's handling of exp() via variable introduction.

  species X;

  k = -0.5; // no finite-time explosion for k < 0

  // Dynamics
  X' = exp(k*X); // X >= 0 for X(0) >= 0

  // Initial condition (placeholder)
  X = 0.0; // non-negative initial condition

  // Notes:
  // * No parameters appear in the paper's minimal example; treat as unit scaling.
  // * Recasting typically introduces an auxiliary variable Z = exp(X) to obtain S-system form.
end
// @SIM T_START=0 T_END=20 N_STEPS=400
