// van der Pol oscillator
// ODEs:
//   x' = y
//   y' = mu*(1 - x^2)*y - x
// ICs: x(0)=2, y(0)=1
// Params: mu=5

model van_der_Pol()
  // initial conditions
  x = 2
  y = 1

  // parameter
  mu = 5

  // flows (mass-action-style reactions with general rate laws)
  R1:  -> x; y
  R2:  -> y; mu*(1 - x^2)*y - x
end