////////////////////////////////////////////////////////////////////////////////
// 24_scalarExpLog.ant
//
// Savageau & Voit 1987, Eq. (15)
//   dZ/dt = exp[(ln Z)^2],  Z(0) = 2
// Here we write it with natural log as log(Z) for SymPy compatibility.
////////////////////////////////////////////////////////////////////////////////

model 24_scalarExpLog()

  // One-dimensional ODE with composite non–power-law RHS
  species Z;

  // Dynamics: Z' = exp[(log Z)^2]
  Z' = exp((log(Z))^2);

  // Initial condition from the paper
  Z = 2;

end