model 25_CSTR_original_from_SSystem()

  // Parameters
  A   = 1;      // example values; can be symbolic
  B   = 1;
  a   = 0.5;
  b   = 1;
  c   = 1;
  Z10 = 0.2;
  Z20 = 0.2;

  species Z1, Z2;

  // Original ODEs consistent with the S-system you provided:
  Z1' = -Z1 + A*(1 - Z1)*exp(c*Z2/(c + Z2));
  Z2' = -Z2 + B*(1 - Z1)*exp(c*Z2/(c + Z2)) - b*(Z2 - a);

  // Initial conditions
  Z1 = Z10;
  Z2 = Z20;

end