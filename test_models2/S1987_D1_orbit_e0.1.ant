// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem D1 - Orbit equation, eccentricity e=0.1 (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Eccentricity: e = 0.1
// Initial conditions: Z1(0) = 1-e = 0.9
//                     Z2(0) = 0
//                     Z3(0) = 0
//                     Z4(0) = sqrt((1+e)/(1-e)) = sqrt(1.1/0.9) ≈ 1.1055
//
// Original ODEs (2-body orbit problem):
//   dZ1/dt = Z3
//   dZ2/dt = Z4
//   dZ3/dt = -Z1*(Z1^2 + Z2^2)^(-3/2)
//   dZ4/dt = -Z2*(Z1^2 + Z2^2)^(-3/2)
//
// Recast S-system (8 variables):
//   Define: X1=Z1+3, X2=Z2+3, X3=Z3+5, X4=Z4+5, X5=Z1^2+Z2^2
//   Then replace X5 by product X5*X6*X7*X8
//
//   dX1/dt = X3 - 5
//   dX2/dt = X4 - 5
//   dX3/dt = 3*(X5*X6*X7*X8)^(-3/2) - X1*(X5*X6*X7*X8)^(-3/2)
//   dX4/dt = 3*(X5*X6*X7*X8)^(-3/2) - X2*(X5*X6*X7*X8)^(-3/2)
//   (additional equations for X5-X8, see paper)
// =============================================================================

model S1987_D1_orbit_e0p1()
    // Orbital mechanics with eccentricity e = 0.1
    e = 0.1
    
    Z1' = Z3
    Z2' = Z4
    Z3' = -Z1*(Z1^2 + Z2^2)^(-3/2)
    Z4' = -Z2*(Z1^2 + Z2^2)^(-3/2)
    
    // Initial conditions
    Z1 = 1 - e           // = 0.9
    Z2 = 0
    Z3 = 0
    Z4 = ((1+e)/(1-e))^(1/2)  // ≈ 1.1055
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
