// Mixed Terms - Reductive Recasting (4 auxiliary variables)
// Source: Savageau, "Finding Multiple Roots of Nonlinear Algebraic Equations
//         Using S-System Methodology"
//         Appl. Math. Comput. 55:187-199 (1993)
//         Equations (15)-(19)
//
// This paper cites Savageau & Voit (1987) as reference [12].
//
// Original ODE (Eq. 15):
//   dXв‚Ѓ/dt + aв‚Ѓв‚ЃXв‚ЃВІ + aв‚Ѓв‚‚Xв‚ЃXв‚‚ - aв‚‚в‚ЃXв‚‚^gв‚Ѓ - aв‚‚в‚‚Xв‚Ѓ^gв‚‚Xв‚‚^gв‚ѓ = 0
//
// Rewritten as:
//   dXв‚Ѓ/dt = aв‚‚в‚ЃXв‚‚^gв‚Ѓ + aв‚‚в‚‚Xв‚Ѓ^gв‚‚Xв‚‚^gв‚ѓ - aв‚Ѓв‚ЃXв‚ЃВІ - aв‚Ѓв‚‚Xв‚ЃXв‚‚
//
// ==============================================================================
// EXACT RECASTING via Reductive Method (Eq. 16-19):
// ==============================================================================
// This equation has BOTH POSITIVE AND NEGATIVE MULTIPLE TERMS.
// Four auxiliary variables are needed: Xв‚Ѓ = Xв‚‚В·Xв‚ѓВ·Xв‚„В·Xв‚…
//
// After the reductive step (Eq. 16-19):
//   dXв‚‚/dt = (gв‚Ѓв‚Ѓ/gв‚Ѓв‚‚)О±в‚ЃВ·Xв‚‚^(gв‚Ѓв‚Ѓ/gв‚Ѓв‚‚)В·X_...  - ОІв‚‚В·Xв‚‚^hв‚‚_...
//   dXв‚ѓ/dt = similar structure
//   dXв‚„/dt = similar structure  
//   dXв‚…/dt = similar structure
//
// Note: Equation (19) is a linear combination of (16)-(18) in steady state
// and is eliminated.
//
// Constraints (Eq. 20-21):
//   Xв‚‚ + Xв‚ѓ = 1  (positive terms constraint)
//   Xв‚„ + Xв‚… = 1  (negative terms constraint)
//
// This demonstrates reductive recasting for the most general case:
// multiple terms of BOTH signs в†’ 2 auxiliary sets.
// ==============================================================================

model S1993_mixed_terms()
  // Variables
  var species X1 in compartment  // Original variable
  var species X2 in compartment  // Second variable (from 2D system)
  
  compartment = 1

  // Parameters (example values)
  a11 := 1.0    // Coefficient of negative term Xв‚ЃВІ
  a12 := 0.5    // Coefficient of negative term Xв‚ЃXв‚‚  
  a21 := 2.0    // Coefficient of positive term Xв‚‚^gв‚Ѓ
  a22 := 1.5    // Coefficient of positive term Xв‚Ѓ^gв‚‚В·Xв‚‚^gв‚ѓ
  g1 := 0.5     // Exponent
  g2 := 0.3     // Exponent
  g3 := 0.7     // Exponent
  
  // Original ODE with mixed terms (multiple positive, multiple negative)
  // dXв‚Ѓ/dt = aв‚‚в‚ЃВ·Xв‚‚^gв‚Ѓ + aв‚‚в‚‚В·Xв‚Ѓ^gв‚‚В·Xв‚‚^gв‚ѓ - aв‚Ѓв‚ЃВ·Xв‚ЃВІ - aв‚Ѓв‚‚В·Xв‚ЃВ·Xв‚‚
  X1' = a21 * X2^g1 + a22 * X1^g2 * X2^g3 - a11 * X1^2 - a12 * X1 * X2
  
  // Second equation (conservation or independent dynamics)
  X2' = -X2 + 1  // Example: X2 approaches 1
  
  // Initial conditions
  X1 = 0.5
  X2 = 0.8
end
// @SIM T_START=0 T_END=20 N_STEPS=400
