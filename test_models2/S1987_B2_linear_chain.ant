// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Problem B2 - Linear chemical reaction chain (Appendix A)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z1(0) = 2, Z2(0) = 0, Z3(0) = 1
//
// Original ODEs:
//   dZ1/dt = -Z1 + Z2
//   dZ2/dt = Z1 - 2*Z2 + Z3
//   dZ3/dt = Z2 - Z3
//
// Recast S-system (4 variables):
//   Define: X1 = Z1 + p, X2 = Z2 + p, X3 = Z3 + p, X4 = X1 + X3
//   where p = 2 (arbitrary positive constant)
//   X(0) = (4, 2, 3, 7)
//
//   dX1/dt = X2 - X1
//   dX2/dt = X4 - 2*X2
//   dX3/dt = X2 - X3
//   dX4/dt = 2*X2 - X4
//
// This represents a linear system of chemical reactions.
// =============================================================================

model S1987_B2_linear_chain()
    // Linear chemical chain (requires translation for S-system form)
    Z1' = -Z1 + Z2
    Z2' = Z1 - 2*Z2 + Z3
    Z3' = Z2 - Z3
    
    // Initial conditions
    Z1 = 2
    Z2 = 0
    Z3 = 1
end
// @SIM T_START=0 T_END=6 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
