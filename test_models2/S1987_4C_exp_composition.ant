// =============================================================================
// Source: Savageau & Voit (1987) "Recasting Nonlinear Differential Equations
//         as S-Systems: A Canonical Nonlinear Form"
//         Math. Biosci. 87:83-115
// Example: Section 4C - Exponential composition (Equations 15-17)
// =============================================================================
// Time horizon: t ∈ [0, 20]
// Initial conditions: Z(0) = 2
//
// Original ODE:
//   dZ/dt = exp[(ln Z)^2]
//
// Recast S-system (3 variables):
//   Define: X1 = Z, X2 = exp[(ln X1)^2], X3 = ln X1
//   X1(0) = 2, X2(0) = exp[(ln 2)^2], X3(0) = ln 2
//
//   dX1/dt = X2
//   dX2/dt = 2 * X1^(-1) * X2^2 * X3
//   dX3/dt = X1^(-1) * X2
//
// Constraints (invariant):
//   X2 = exp[(ln X1)^2]
//   X3 = ln X1
// =============================================================================

model S1987_4C_exp_composition()
    // Rate constant (controls timescale)
    // Small k prevents overflow while preserving S-system structure
    k = 0.001
    
    // Original single ODE (with rate constant)
    Z' = k * exp(ln(Z)^2)
    
    // Initial condition
    Z = 2
end
// @SIM T_START=0 T_END=20 N_STEPS=400 EPS_INIT=1e-6
// Note: Zero-valued initial conditions are replaced with EPS_INIT during recasting.
